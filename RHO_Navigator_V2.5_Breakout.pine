// ═══════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

// @function Processes entry confirmation for UTB/DTB entries in 3 modes:
//           "Immediate" — enter on the UTB/DTB bar itself (original behavior, most trades)
//           "Close Confirmation" — enter after N consecutive bars close beyond the breakout zone
//              (filters wick traps with minimal delay)
//           "Retest" — wait for a full pullback to the broken band and bounce confirmation
//              (fewest trades but highest conviction)
//           Volume confirmation: optionally require above-avg volume on the breakout bar.
// @returns  tuple with updated state and int entryAction: 0=none, +1=short, -1=long
processEntryConfirmation(
     bool _pendShort, int _pendShortBar, float _pendShortLvl, bool _retestTouchedShort,
     bool _pendLong, int _pendLongBar, float _pendLongLvl, bool _retestTouchedLong,
     int _holdCount,
     bool _sellTrigUtb, bool _buyTrigDtb,
     float _loP, float _upP,
     float _utbZone, float _dtbZone,
     string _mode, int _maxBars, float _zoneATR, int _holdBarsReq,
     bool _maFilterOkShort, bool _maAlignOkShort,
     bool _maFilterOkLong, bool _maAlignOkLong,
     float _posSize, float _atr, float _high, float _low, float _close, float _open) =>

    bool pShort = _pendShort, int pShortBar = _pendShortBar, float pShortLvl = _pendShortLvl, bool rtShort = _retestTouchedShort
    bool pLong = _pendLong, int pLongBar = _pendLongBar, float pLongLvl = _pendLongLvl, bool rtLong = _retestTouchedLong
    int holdCnt = _holdCount
    int action = 0

    bool isImmediate = _mode == "Immediate"
    bool isCloseConf = _mode == "Close Confirmation"
    bool isRetest    = _mode == "Retest"

    // ═══ UTB just fired (Short breakout signal) ═══
    if _sellTrigUtb
        if isImmediate
            // Enter on the same bar
            if _posSize == 0 and _maFilterOkShort and _maAlignOkShort
                action := +1
        else
            // Both Close Confirmation and Retest: go pending
            pShort := true
            pShortBar := bar_index
            // Close Confirmation: confirm against the UTB zone (more extreme)
            // Retest: pull back to the lower band (the broken level)
            pShortLvl := isCloseConf ? _utbZone : _loP
            rtShort := false
            holdCnt := 0
            // Cancel any pending long
            pLong := false, pLongBar := na, pLongLvl := na, rtLong := false

    // ═══ DTB just fired (Long breakout signal) ═══
    if _buyTrigDtb
        if isImmediate
            if _posSize == 0 and _maFilterOkLong and _maAlignOkLong
                action := -1
        else
            pLong := true
            pLongBar := bar_index
            // Close Confirmation: confirm against the DTB zone (more extreme)
            // Retest: pull back to the upper band (the broken level)
            pLongLvl := isCloseConf ? _dtbZone : _upP
            rtLong := false
            holdCnt := 0
            pShort := false, pShortBar := na, pShortLvl := na, rtShort := false

    // ═══ Process pending SHORT ═══
    if pShort and action == 0
        // Expire if too many bars have passed
        if not na(pShortBar) and (bar_index - pShortBar) > _maxBars
            pShort := false, pShortBar := na, pShortLvl := na, rtShort := false, holdCnt := 0
        else if not na(pShortLvl)
            if isCloseConf
                // Close Confirmation: count consecutive closes below the UTB zone
                if _close < pShortLvl
                    holdCnt += 1
                else
                    holdCnt := 0
                if holdCnt >= _holdBarsReq
                    if _posSize == 0 and _maFilterOkShort and _maAlignOkShort
                        action := +1
                    pShort := false, pShortBar := na, pShortLvl := na, rtShort := false, holdCnt := 0

            else if isRetest
                // Retest: wait for pullback to band then bounce
                float retestCeil = pShortLvl + _zoneATR * _atr
                // Phase 1: detect price pulling back UP into the retest zone
                if not rtShort and _high >= pShortLvl and _high <= retestCeil
                    rtShort := true
                // Phase 2: after touching retest zone, enter on bearish confirmation
                if rtShort and _close < pShortLvl and _close < _open
                    if _posSize == 0 and _maFilterOkShort and _maAlignOkShort
                        action := +1
                    pShort := false, pShortBar := na, pShortLvl := na, rtShort := false, holdCnt := 0

    // ═══ Process pending LONG ═══
    if pLong and action == 0
        if not na(pLongBar) and (bar_index - pLongBar) > _maxBars
            pLong := false, pLongBar := na, pLongLvl := na, rtLong := false, holdCnt := 0
        else if not na(pLongLvl)
            if isCloseConf
                // Close Confirmation: count consecutive closes above the DTB zone
                if _close > pLongLvl
                    holdCnt += 1
                else
                    holdCnt := 0
                if holdCnt >= _holdBarsReq
                    if _posSize == 0 and _maFilterOkLong and _maAlignOkLong
                        action := -1
                    pLong := false, pLongBar := na, pLongLvl := na, rtLong := false, holdCnt := 0

            else if isRetest
                float retestFloor = pLongLvl - _zoneATR * _atr
                if not rtLong and _low <= pLongLvl and _low >= retestFloor
                    rtLong := true
                if rtLong and _close > pLongLvl and _close > _open
                    if _posSize == 0 and _maFilterOkLong and _maAlignOkLong
                        action := -1
                    pLong := false, pLongBar := na, pLongLvl := na, rtLong := false, holdCnt := 0

    [pShort, pShortBar, pShortLvl, rtShort, pLong, pLongBar, pLongLvl, rtLong, holdCnt, action]


// @function Computes the SL price, whether it's from an extended line, and the ext reference price.
// @param    dir +1 for short (UTB), -1 for long (DTB)
// @param    _fromExt true if the UTB/DTB was triggered from extended lines
// @param    _extPrice the extended line price (ES1 for short, ER1 for long)
// @param    _bandPrice the channel band price (lower for short, upper for long)
// @param    _slBuffer ATR buffer multiplier
// @param    _atr current ATR value
// @returns  [fixedSL, slFromExt, extSlRef]
computeBreakoutSL(int dir, bool _fromExt, float _extPrice, float _bandPrice, float _slBuffer, float _atr) =>
    float sl = na
    bool fromExt = false
    float extRef = float(na)
    if _fromExt and not na(_extPrice)
        sl := dir == +1 ? (_extPrice + _slBuffer * _atr) : (_extPrice - _slBuffer * _atr)
        fromExt := true
        extRef := _extPrice
    else
        sl := dir == +1 ? (_bandPrice + _slBuffer * _atr) : (_bandPrice - _slBuffer * _atr)
    [sl, fromExt, extRef]

// @function Returns the upper/lower bounds for the back-inside check.
//           Uses ER1 > channel upper, ES1 > channel lower.
//           ER2/ES2 excluded because UTB/DTB zones are based on ER1/ES1.
getInsideBounds(float _upP, float _loP,
     bool _erConf, line _erLine,
     bool _esConf, line _esLine) =>
    float _upper = _upP
    float _lower = _loP
    if _erConf and not na(_erLine)
        _upper := line.get_price(_erLine, bar_index)
    if _esConf and not na(_esLine)
        _lower := line.get_price(_esLine, bar_index)
    [_upper, _lower]


sendAlert(string ev, float price, string trend) =>
    string alertBody = utils.buildEventAlert(ev, price, trend, syminfo.ticker, timeframe.period, useWebhookJSON)
    alert(alertBody, alert.freq_once_per_bar)

sendSignalAlert(string ev, float px, float tp1, float tp2, float sl, bool breakEntry = false) =>
    string alertBody = utils.buildSignalAlert(ev, px, tp1, tp2, sl, syminfo.ticker, timeframe.period, useWebhookJSON, breakEntry)
    alert(alertBody, alert.freq_once_per_bar)

sendSimpleAlert(string message) =>
    string alertBody = utils.buildSimpleAlert(message, syminfo.ticker, timeframe.period, useWebhookJSON)
    alert(alertBody, alert.freq_once_per_bar)

sendBodyAlert(string body) =>
    string alertBody = utils.buildBodyAlert(body, syminfo.ticker, useWebhookJSON)
    alert(alertBody, alert.freq_once_per_bar)

// @function Computes for the score of a linear regression channel
// @params  Linear Regression Channel values to check
// @returns [comp, utilPct, widthScore, hitsTotal, 0.0, nz(avgWidthAtr)]
qualityScore(int length, float intercept, float slope, float stdDev, float pearsonR, float devMult, atrS) =>
    float ph = ta.pivothigh(high, 10, 10)
    float pl = ta.pivotlow(low,   10, 10)

    int   period_1     = length - 1
    int   insideCount  = 0
    float sumWidthAtr  = 0.0
    int   widthCount   = 0
    int   hitsUp       = 0
    int   hitsDn       = 0

    float mid = intercept
    for int t = 0 to period_1
        // Bands for this bar (no ATR needed)
        float upT = mid + devMult * stdDev
        float loT = mid - devMult * stdDev

        // Count "inside" unconditionally — this is pure geometry
        if low[t] >= loT and high[t] <= upT
            insideCount += 1

        // Use ATR only where it exists
        float atrT = atrS[t]
        if not na(atrT)
            float widthT = upT - loT
            sumWidthAtr += widthT / atrT
            widthCount  += 1

            // FIX: Only count pivot hits for bars AT or AFTER the effective init bar
            // This ensures pivot counting is consistent regardless of execution path
            int barAtT = bar_index - t
            bool barIsValid = na(EFFECTIVE_INIT_BAR_INDEX) or (barAtT >= EFFECTIVE_INIT_BAR_INDEX)
            
            if barIsValid
                bool isPH = not na(ph[t])
                bool isPL = not na(pl[t])
                if isPH
                    float distUp = math.abs(ph[t] - upT)
                    if distUp <= 0.15 * atrT
                        hitsUp += 1
                if isPL
                    float distLo = math.abs(pl[t] - loT)
                    if distLo <= 0.15 * atrT
                        hitsDn += 1

        mid += slope

    // Utilization: fraction of bars inside (always defined)
    float utilPct = utils.clamp01(insideCount / math.max(1.0, length))

    // Width sanity: average only over valid ATR points; if none, use neutral 0.5
    float avgWidthAtr = widthCount > 0 ? (sumWidthAtr / widthCount) : na
    float widthScore  = na(avgWidthAtr)
         ? 0.5
         : utils.clamp01(1.0 - math.min(1.0, math.abs(avgWidthAtr - idealWidthAtr) / math.max(0.0001, widthToleranceAtr)))

    // Hits: normalize with harmonic balance; if ATR was never available, this stays 0
    float hitsTotal      = hitsUp + hitsDn
    float hitsNormCount  = utils.clamp01(hitsTotal / math.max(1.0, hitsTarget))
    float halfTarget     = math.max(0.5, hitsTarget * 0.5)
    float uNorm          = utils.clamp01(hitsUp / halfTarget)
    float dNorm          = utils.clamp01(hitsDn / halfTarget)
    float balanceHM      = (uNorm + dNorm > 0) ? (2.0 * uNorm * dNorm) / (uNorm + dNorm) : 0.0
    float hitsScorePivot = utils.clamp01(0.6 * balanceHM + 0.4 * hitsNormCount)

    float weightSum = wUtil + wWidth + wHits
    float comp = weightSum > 0
         ? utils.clamp01((wUtil * utilPct + wWidth * widthScore + wHits * hitsScorePivot) / weightSum)
         : hitsScorePivot

    [comp, utilPct, widthScore, hitsTotal, 0.0, nz(avgWidthAtr)]


// @function Computes for the composite score of the period/channel checked
// @params  Linear Regression Channel values to check
// @returns _c Computed composite score
getComp(int length, float intercept, float slope, float stdDev, float pearsonR, float devMult, atrS) =>
    [_c, _u, _w, _h, _p, _a] = qualityScore(length, intercept, slope, stdDev, pearsonR, devMult, atrS)
    _c


// @function Computes for the best combination of period's composite score and deviation using Golden Iteration
// @params  Linear Regression Channel values to check and the number of iterations
// @returns [bestComp, bestDv] - returns Best Computed Period and Deviation
goldenBestDev(
     int length, float intercept, float slope, float stdDev, float pearsonR,
     float dMin, float dMax, int iters, atrS) =>
    float lo  = math.min(dMin, dMax)
    float hi  = math.max(dMin, dMax)
    float phi = 0.61803398875
    float a = lo, b = hi
    float c = b - (b - a) * phi
    float d = a + (b - a) * phi

    float compC = getComp(length, intercept, slope, stdDev, pearsonR, c, atrS)
    float compD = getComp(length, intercept, slope, stdDev, pearsonR, d, atrS)

    int n = math.max(2, iters)
    for i = 0 to n - 1
        if compC < compD
            a := c
            c := d
            compC := compD
            d := a + (b - a) * phi
            compD := getComp(length, intercept, slope, stdDev, pearsonR, d, atrS)
        else
            b := d
            d := c
            compD := compC
            c := b - (b - a) * phi
            compC := getComp(length, intercept, slope, stdDev, pearsonR, c, atrS)

    float bestDv = (a + b) * 0.5
    float bestComp = getComp(length, intercept, slope, stdDev, pearsonR, bestDv, atrS)
    [bestComp, bestDv]


// @function Composite calculation for Best Period and Deviation
// @params  Linear Regression Channel values to check and the number of iterations
// @returns [bestComp, bestDv] - returns Best Computed Period and Deviation
compositeBestForPeriod(int length, float intercept, float slope, float stdDev, float pearsonR, float[] devCands, float[] devSingle, atrS) =>
    goldenBestDev(length, intercept, slope, stdDev, pearsonR, devMin, devMax, goldenIters, atrS)


// @function Creates a "NC" - New Channel label and retains the number of NC label visible in the chart to specified MAX_CHANNEL_CHANGE_LABELS
createChannelChangeLabel() =>
    label newLabel = label.new(bar_index, high, "NC", style=label.style_label_down, color=LBL_NC_COL, textcolor=LBL_TEXT_COL, size=size.tiny)
    array.push(CHANNEL_CHANGE_LABELS, newLabel)
    // Remove oldest labels if we have more than MAX_CHANNEL_CHANGE_LABELS
    while array.size(CHANNEL_CHANGE_LABELS) > MAX_CHANNEL_CHANGE_LABELS
        label oldLabel = array.shift(CHANNEL_CHANGE_LABELS)
        label.delete(oldLabel)


// @function Captures the previous "Weak" / "Blue" Channel
// @returns [newMid, newUp, newLo, newFU, newFL]
capturePrevDevWeak() =>

    line newMid   = na
    line newUp    = na
    line newLo    = na
    linefill newFU = na
    linefill newFL = na

    if LT_FROZEN and not na(LT_LINE_MID) and not na(LT_LINE_UP) and not na(LT_LINE_LO)
        color midC  = color.new(color.blue,  85)
        color bandC = color.new(color.blue,  85)
        color fillC = color.new(color.blue, 90)

        newMid := line.new(line.get_x1(LT_LINE_MID), line.get_y1(LT_LINE_MID),
                           line.get_x2(LT_LINE_MID), line.get_y2(LT_LINE_MID),
                           extend=extend.right, width=1, color=midC, style=line.style_dashed)
        newUp  := line.new(line.get_x1(LT_LINE_UP), line.get_y1(LT_LINE_UP),
                           line.get_x2(LT_LINE_UP), line.get_y2(LT_LINE_UP),
                           extend=extend.right, width=1, color=bandC)
        newLo  := line.new(line.get_x1(LT_LINE_LO), line.get_y1(LT_LINE_LO),
                           line.get_x2(LT_LINE_LO), line.get_y2(LT_LINE_LO),
                           extend=extend.right, width=1, color=bandC)
        newFU := linefill.new(newUp,  newMid, color=fillC), newFL := linefill.new(newMid, newLo,  color=fillC)

        array.push(DEV_MIDS, newMid), array.push(DEV_UPS, newUp), array.push(DEV_LOS, newLo)
        array.push(DEV_FILLUS, newFU), array.push(DEV_FILLLS, newFL)

    [newMid, newUp, newLo, newFU, newFL]


// @function Archives previous channels, "Green" for Good and "Blue" for Weak Previous Channel
// @returns didArchive true if channel has been archived
archiveCurrentChannelIfGood() =>
    bool didArchive = false
    if LT_FROZEN and not na(LT_LINE_MID) and not na(LT_LINE_UP) and not na(LT_LINE_LO)
        float spNow = na(LT_SCORE) ? na : LT_SCORE * 100.0
        bool strongByScore = not na(spNow) and spNow >= strongScorePct
        bool strongActive  = strongByScore or STRONG_PROMOTED

        // NEW: if NOT strong → keep a single BLUE ghost of the outgoing channel
        if not strongActive
            [DEV_MID, DEV_UP, DEV_LO, DEV_FILLU, DEV_FILLL] = capturePrevDevWeak()

            if not na(midG)
                utils.deleteArchive(midG, upG, loG, upMidFillG, loMidFillG)

        while array.size(DEV_MIDS) > 1
            line     midOld = array.shift(DEV_MIDS)
            line     upOld  = array.shift(DEV_UPS)
            line     loOld  = array.shift(DEV_LOS)
            linefill fuOld  = array.shift(DEV_FILLUS)
            linefill flOld  = array.shift(DEV_FILLLS)
            utils.deleteArchive(midOld, upOld, loOld, fuOld, flOld)

        // existing gray-archive behavior for strong channels
        if strongActive
            // (your original read-geometry + gray clone code)
            int   x1m = line.get_x1(LT_LINE_MID), x2m = line.get_x2(LT_LINE_MID)
            float y1m = line.get_y1(LT_LINE_MID), y2m = line.get_y2(LT_LINE_MID)
            int   x1u = line.get_x1(LT_LINE_UP),  x2u = line.get_x2(LT_LINE_UP)
            float y1u = line.get_y1(LT_LINE_UP),  y2u = line.get_y2(LT_LINE_UP)
            int   x1l = line.get_x1(LT_LINE_LO),  x2l = line.get_x2(LT_LINE_LO)
            float y1l = line.get_y1(LT_LINE_LO),  y2l = line.get_y2(LT_LINE_LO)

            line midA = line.new(x1m, y1m, x2m, y2m, extend=extend.right, width=1, color=ARCH_MID_COL,  style=line.style_dashed)
            line upA  = line.new(x1u, y1u, x2u, y2u, extend=extend.right, width=1, color=ARCH_BAND_COL, style=line.style_solid)
            line loA  = line.new(x1l, y1l, x2l, y2l, extend=extend.right, width=1, color=ARCH_BAND_COL, style=line.style_solid)
            linefill fu = linefill.new(upA,  midA, color=ARCH_FILL_COL)
            linefill fl = linefill.new(midA, loA,  color=ARCH_FILL_COL)

            // Delete any previous green archive before pushing new one
            while array.size(ARCH_MID) > 0
                line     midOldA = array.shift(ARCH_MID)
                line     upOldA  = array.shift(ARCH_UP)
                line     loOldA  = array.shift(ARCH_LO)
                linefill fuOldA  = array.shift(ARCH_FILLU)
                linefill flOldA  = array.shift(ARCH_FILLL)
                utils.deleteArchive(midOldA, upOldA, loOldA, fuOldA, flOldA)

            array.push(ARCH_MID, midA), array.push(ARCH_UP, upA), array.push(ARCH_LO, loA)
            array.push(ARCH_FILLU, fu), array.push(ARCH_FILLL, fl)

            while array.size(DEV_MIDS) > 0
                line     midOld = array.shift(DEV_MIDS)
                line     upOld  = array.shift(DEV_UPS)
                line     loOld  = array.shift(DEV_LOS)
                linefill fuOld  = array.shift(DEV_FILLUS)
                linefill flOld  = array.shift(DEV_FILLLS)
                utils.deleteArchive(midOld, upOld, loOld, fuOld, flOld)

            didArchive := true
    didArchive


// @function Creates label for historical backfill function and pushes them to BACKFILLED_LABELS array
// @params Label styling attributes to be pass
makeBackfillLbl(label_style, string txt, float y, color col, bx) =>
    label lb = label.new(bx, y, text = txt, style = label_style, textcolor = LBL_TEXT_COL, size = size.tiny, color = col)
    array.push(BACKFILLED_LABELS, lb)


// @function Clear all Extended lines hits
clearAllHitLabels() =>
    utils.deleteAllLabels(ER_HIT_LABELS), utils.deleteAllLabels(ES_HIT_LABELS)
    utils.deleteAllLabels(ER2_HIT_LABELS), utils.deleteAllLabels(ES2_HIT_LABELS)

// @function Captures a snapshot of core channel line prices (R/M/S) before a channel change
// @description Called RIGHT BEFORE lines are deleted so we preserve the last known values
//              for users who are still in a trade from the previous channel.
snapshotPrevChannel() =>
    float snapUpper = na, float snapLower = na, float snapMid = na

    if not na(LT_LINE_UP)
        snapUpper := line.get_price(LT_LINE_UP, bar_index)
    if not na(LT_LINE_LO)
        snapLower := line.get_price(LT_LINE_LO, bar_index)
    if not na(LT_LINE_MID)
        snapMid := line.get_price(LT_LINE_MID, bar_index)

    string snapTrend = na(LT_SLOPE) ? na : (-LT_SLOPE) > 0 ? "Uptrend" : (-LT_SLOPE) < 0 ? "Downtrend" : "Sideways"

    [snapUpper, snapLower, snapMid, snapTrend]

// @function Formats price estimate for panel
// @params Floating price to be formatted
// @returns Returns "-" if it's na hence returns price as string
fmt(float x) =>
    na(x) ? "—" : str.tostring(x, format.mintick)

// ═══════════════════════════════════════════════════════════════════════════
// PRECOMPUTE CHANNEL PERIODS
// ═══════════════════════════════════════════════════════════════════════════
LT_CHANGED_THIS_BAR := false, LT_REVERSAL_THIS_BAR := false
UTB_THIS_BAR := false, DTB_THIS_BAR := false, UTR_THIS_BAR := false
DTR_THIS_BAR := false, UTA_THIS_BAR := false, DTA_THIS_BAR := false
bool TRU_THIS_BAR = false, bool TRD_THIS_BAR = false

// ── Capture live channel prices BEFORE any channel deletion/recreation
// Only update when NOT in a position — once in a trade, freeze these values
// so the SL always references the channel that was active at entry time.
if not na(LT_LINE_UP)
    STRAT_LIVE_UPPER := line.get_price(LT_LINE_UP, bar_index)
if not na(LT_LINE_LO)
    STRAT_LIVE_LOWER := line.get_price(LT_LINE_LO, bar_index)

// Precompute for periods
var int[] ChannelPeriods = array.new_int()

if array.size(ChannelPeriods) == 0
    for _period = periodMin to periodMax by periodStep
        array.push(ChannelPeriods, _period)

float[] StdDevs = array.new_float(), float[] Pearsons = array.new_float(), float[] Slopes = array.new_float()
float[] Intercepts = array.new_float(), float[] Scores = array.new_float()

if (array.size(ChannelPeriods) > 0)
    for i = 0 to array.size(ChannelPeriods) - 1
        [_stdDev, _pearson, _slope, _intercept] = utils.CalculateDev(close, ChannelPeriods.get(i))

        array.push(StdDevs, _stdDev)
        array.push(Pearsons, _pearson)
        array.push(Slopes, _slope)
        array.push(Intercepts, _intercept)

bool valuesNotEmpty = (array.size(StdDevs) > 0) and (array.size(Pearsons) > 0) and
                     (array.size(Slopes) > 0) and (array.size(Intercepts) > 0)


// Build arrays for backfill (once, or maintain incrementally)
var float[] highHistory = array.new_float(), var float[] lowHistory = array.new_float()

// Update on each bar
array.unshift(highHistory, high)
array.unshift(lowHistory, low)
if array.size(highHistory) > 5000
    array.pop(highHistory)
    array.pop(lowHistory)

// ───────────────────────── START DATETIME SHIFT → FULL RESET
var int  LAST_EFFECTIVE_INIT_BAR_INDEX = na
var bool START_DATE_SHIFTED            = false


// ═══════════════════════════════════════════════════════════════════════════
// RESET VARIABLES ON STARTING DATETIME SHIFT
// Only check shifts on the last bar (where last_bar_index actually updates live)
// ═══════════════════════════════════════════════════════════════════════════

if barstate.islast and not na(EFFECTIVE_INIT_BAR_INDEX)
    START_DATE_SHIFTED := not na(LAST_EFFECTIVE_INIT_BAR_INDEX) and (EFFECTIVE_INIT_BAR_INDEX != LAST_EFFECTIVE_INIT_BAR_INDEX)

    if START_DATE_SHIFTED

        // bind init to the shifted window start
        PENDING_REINIT := true
        PENDING_INIT_BAR_INDEX := EFFECTIVE_INIT_BAR_INDEX

        // force INIT_BAR_INDEX to the real shifted start (so logic references the right anchor)
        INIT_BAR_INDEX := EFFECTIVE_INIT_BAR_INDEX

        // Kill active/frozen drawings
        LT_LINE_MID := utils.deleteLine(LT_LINE_MID), LT_LINE_UP := utils.deleteLine(LT_LINE_UP), LT_LINE_LO := utils.deleteLine(LT_LINE_LO)
        if not na(LT_FILL_U)
            linefill.delete(LT_FILL_U), linefill.delete(LT_FILL_L), LT_FILL_U := na, LT_FILL_L := na

        LT_LINE_BUYZONE := utils.deleteLine(LT_LINE_BUYZONE)
        LT_LINE_SELLZONE := utils.deleteLine(LT_LINE_SELLZONE)
        LT_LINE_UTBZONE := utils.deleteLine(LT_LINE_UTBZONE)
        LT_LINE_DTBZONE := utils.deleteLine(LT_LINE_DTBZONE)
        LT_LINE_BUYSL := utils.deleteLine(LT_LINE_BUYSL)
        LT_LINE_SELLSL := utils.deleteLine(LT_LINE_SELLSL)
        LT_LINE_ER_MINZONE := utils.deleteLine(LT_LINE_ER_MINZONE)
        LT_LINE_ES_MINZONE := utils.deleteLine(LT_LINE_ES_MINZONE)

        LT_LINE_ER := utils.deleteLine(LT_LINE_ER)
        LT_LINE_ES := utils.deleteLine(LT_LINE_ES)
        LT_LINE_ER_SELLZONE := utils.deleteLine(LT_LINE_ER_SELLZONE)
        LT_LINE_ER_DTBZONE := utils.deleteLine(LT_LINE_ER_DTBZONE)
        LT_LINE_ES_BUYZONE := utils.deleteLine(LT_LINE_ES_BUYZONE)
        LT_LINE_ES_UTBZONE := utils.deleteLine(LT_LINE_ES_UTBZONE)

        LT_LINE_ER2 := utils.deleteLine(LT_LINE_ER2)
        LT_LINE_ER2_SELLZONE := utils.deleteLine(LT_LINE_ER2_SELLZONE)
        LT_LINE_ER2_DTBZONE := utils.deleteLine(LT_LINE_ER2_DTBZONE)
        LT_LINE_ES2 := utils.deleteLine(LT_LINE_ES2)
        LT_LINE_ES2_BUYZONE := utils.deleteLine(LT_LINE_ES2_BUYZONE)
        LT_LINE_ES2_UTBZONE := utils.deleteLine(LT_LINE_ES2_UTBZONE)
        
        LT_ER_OFFSET := na, LT_ER_CONFIRMED := false, LT_ES_OFFSET := na, LT_ES_CONFIRMED := false
        LT_ER_BAR := na, LT_ES_BAR := na, LT_ER2_OFFSET := na, LT_ER2_CONFIRMED := false
        LT_ES2_OFFSET := na, LT_ES2_CONFIRMED := false, LT_ER2_BAR := na, LT_ES2_BAR := na

        // Clear candidate tracking on channel change
        CANDIDATE_ER_OFFSET := na, CANDIDATE_ER_BAR := na, CANDIDATE_ER_HIT_COUNT := 0, CANDIDATE_ER_LAST_HIT_BAR := na
        CANDIDATE_ES_OFFSET := na, CANDIDATE_ES_BAR := na, CANDIDATE_ES_HIT_COUNT := 0, CANDIDATE_ES_LAST_HIT_BAR := na

        // Clear previous extended lines on channel change
        PREV_LT_LINE_ER := utils.deleteLine(PREV_LT_LINE_ER)
        PREV_LT_LINE_ES := utils.deleteLine(PREV_LT_LINE_ES)

        utils.deleteAllLines(longTermLines), utils.deleteAllFills(longTermFills)

        utils.deleteAllLines(ARCH_MID),  utils.deleteAllLines(ARCH_UP),  utils.deleteAllLines(ARCH_LO)
        utils.deleteAllFills(ARCH_FILLU), utils.deleteAllFills(ARCH_FILLL)
        array.clear(ARCH_MID), array.clear(ARCH_UP), array.clear(ARCH_LO)
        array.clear(ARCH_FILLU), array.clear(ARCH_FILLL)
        ARCH_CHANNEL_AGE := 0

        utils.deleteAllLines(DEV_MIDS), utils.deleteAllLines(DEV_UPS), utils.deleteAllLines(DEV_LOS)
        utils.deleteAllFills(DEV_FILLUS), utils.deleteAllFills(DEV_FILLLS)
        array.clear(DEV_MIDS), array.clear(DEV_UPS), array.clear(DEV_LOS)
        array.clear(DEV_FILLUS), array.clear(DEV_FILLLS)

        DEV_MID := utils.deleteLine(DEV_MID)
        DEV_UP := utils.deleteLine(DEV_UP)
        DEV_LO := utils.deleteLine(DEV_LO)

        if not na(DEV_FILLU)
            linefill.delete(DEV_FILLU), DEV_FILLU := na
        if not na(DEV_FILLL)
            linefill.delete(DEV_FILLL), DEV_FILLL := na

        // ── 3) Clear labels + hit windows
        utils.deleteAllLabels(SR_LABELS), utils.deleteAllLabels(REV_LABELS), utils.deleteAllLabels(EVT_LABELS), utils.deleteAllLabels(BUY_SIG_LABELS)
        utils.deleteAllLabels(SELL_SIG_LABELS), utils.deleteAllLabels(CHANNEL_CHANGE_LABELS), utils.deleteAllLabels(BACKFILLED_LABELS)
        array.clear(UP_HIT_BARS), array.clear(DN_HIT_BARS), array.clear(MR_HIT_BARS), array.clear(MS_HIT_BARS)
        MRHITS_CNT := 0, MSHITS_CNT := 0
        // ── Mark channel changed for mid-trade SL fallback
        if strategy.position_size != 0
            STRAT_CH_CHANGED := true
        LT_FROZEN := false, HAS_EVER_FROZEN := false, LT_PERIOD := na, LT_SLOPE := na, LT_INTERCEPT := na, LT_STD := na, LT_SCORE := na, LT_DEVMULT := na, LT_START_BAR := na
        UP_OUTSIDE_COUNT := 0, DN_OUTSIDE_COUNT := 0, FULL_OUTSIDE_COUNT := 0, AFTER_BREAK_DIR := 0, BREAK_LATCH := false, BREAK_DIR := 0, BREAK_EVENT_COUNT := 0, LAST_BREAK_BAR := na
        HAD_UTB := false, HAD_DTB := false, HAD_UTA := false, HAD_DTA := false
        PENDING_RETEST_SHORT := false, PENDING_RETEST_SHORT_BAR := na, PENDING_RETEST_SHORT_LVL := na, RETEST_TOUCHED_SHORT := false, PENDING_RETEST_LONG := false, PENDING_RETEST_LONG_BAR := na, PENDING_RETEST_LONG_LVL := na, RETEST_TOUCHED_LONG := false, PENDING_HOLD_COUNT := 0
        SRHITS_UP := 0, SRHITS_DN := 0, STRONG_PROMOTED := false, GOOD_ALERTED := false
        LAST_UPPER_LABELBAR := na, LAST_LOWER_LABELBAR := na, LAST_MR_LABELBAR := na, LAST_MS_LABELBAR := na, MR_ARMED := true, MS_ARMED := true

        BUY_ARMED := false, BUY_ARMED_BAR := na, SELL_ARMED := false, SELL_ARMED_BAR := na, BUY_REF_PENDING := false
        BUY_REF_BAR := na, BUY_REF_HIGH := na, BUY_REF_ZONE_PRICE := na, BUY_REF_SL_PRICE := na
        SKIP_NORMAL_SELL := false, SKIP_NORMAL_BUY := false

        SELL_REF_PENDING := false, SELL_REF_BAR := na, SELL_REF_LOW := na, SELL_REF_ZONE_PRICE := na, SELL_REF_SL_PRICE := na
        SELL_ARMED_ER := false, SELL_ARMED_ER_BAR := na, BUY_ARMED_ES := false, BUY_ARMED_ES_BAR := na, SELL_ER_REF_PENDING := false
        SELL_ER_REF_BAR := na, SELL_ER_REF_LOW := na, SELL_ER_REF_ZONE_PRICE := na, SELL_ER_REF_SL_PRICE := na, BUY_ES_REF_PENDING := false
        BUY_ES_REF_BAR := na, BUY_ES_REF_HIGH := na, BUY_ES_REF_ZONE_PRICE := na, BUY_ES_REF_SL_PRICE := na, ER_HIT_COUNT := 0, ER_LAST_HIT_BAR := na
        ES_HIT_COUNT := 0, ES_LAST_HIT_BAR := na

        CANDIDATE_ER_OFFSET := na, CANDIDATE_ER_BAR := na, CANDIDATE_ER_HIT_COUNT := 0, CANDIDATE_ER_LAST_HIT_BAR := na
        CANDIDATE_ES_OFFSET := na, CANDIDATE_ES_BAR := na, CANDIDATE_ES_HIT_COUNT := 0, CANDIDATE_ES_LAST_HIT_BAR := na

        clearAllHitLabels()

        // Reset ER2/ES2 state on sliding window shift
        LT_ER2_OFFSET := na, LT_ES2_OFFSET := na, LT_ER2_BAR := na, LT_ES2_BAR := na, LT_ER2_CONFIRMED := false, LT_ES2_CONFIRMED := false, ER2_HIT_COUNT := 0
        ER2_LAST_HIT_BAR := na, ES2_HIT_COUNT := 0, ES2_LAST_HIT_BAR := na, PENDING_ER2_OFFSET := na, PENDING_ER2_HIGH := na, PENDING_ER2_BAR := na
        PENDING_ES2_OFFSET := na, PENDING_ES2_LOW := na, PENDING_ES2_BAR := na, CANDIDATE_ER2_OFFSET := na, CANDIDATE_ER2_PIVOT_BAR := na
        CANDIDATE_ER2_LAST_HIT_BAR := na, CANDIDATE_ES2_OFFSET := na, CANDIDATE_ES2_PIVOT_BAR := na, CANDIDATE_ES2_LAST_HIT_BAR := na
        SELL_ARMED_ER2 := false, SELL_ARMED_ER2_BAR := na, BUY_ARMED_ES2 := false, BUY_ARMED_ES2_BAR := na, SELL_ER2_REF_PENDING := false
        SELL_ER2_REF_BAR := na, SELL_ER2_REF_LOW := na, SELL_ER2_REF_ZONE_PRICE := na, SELL_ER2_REF_SL_PRICE := na, BUY_ES2_REF_PENDING := false
        BUY_ES2_REF_BAR := na, BUY_ES2_REF_HIGH := na, BUY_ES2_REF_ZONE_PRICE := na, BUY_ES2_REF_SL_PRICE := na

        // Reset PENDING ER/ES tracking (prevents stale pending from old channel)
        PENDING_ER_OFFSET := na, PENDING_ER_HIGH := na, PENDING_ER_BAR := na, PENDING_ES_OFFSET := na, PENDING_ES_LOW := na, PENDING_ES_BAR := na

        BACKFILL_DONE := false
        INIT_BAR_INDEX := na

    LAST_EFFECTIVE_INIT_BAR_INDEX := EFFECTIVE_INIT_BAR_INDEX


// ───────────────────────── Plot MAs (NEW)
plot(ma9,  title='MA 9',  color=color.orange, linewidth=1)
plot(ma30, title='MA 30', color=color.purple, linewidth=1)


// ═══════════════════════════════════════════════════════════════════════════
// CHANNEL LOGIC CHANGES
// ═══════════════════════════════════════════════════════════════════════════
if time >= INIT_TS

    // Set INIT_BAR_INDEX only once on the actual init bar
    if isInitBar and na(INIT_BAR_INDEX)
        INIT_BAR_INDEX := bar_index

    // if we just shifted, only allow initial-pick AFTER we have a bound init bar
    if PENDING_REINIT
        // don't let any “normal” logic run until init is bound
        if na(INIT_BAR_INDEX)
            INIT_BAR_INDEX := PENDING_INIT_BAR_INDEX

        // once bound, allow init pick and then drop the latch
        if not na(INIT_BAR_INDEX)
            HAS_EVER_FROZEN := false
            // ── Mark channel changed for mid-trade SL fallback
            if strategy.position_size != 0
                STRAT_CH_CHANGED := true
            LT_FROZEN := false
            PENDING_REINIT := false

    if LT_FROZEN
        if not na(LT_LINE_MID)
            midNow := line.get_price(LT_LINE_MID, bar_index)
        if not na(LT_LINE_UP)
            upNow  := line.get_price(LT_LINE_UP,  bar_index)
        if not na(LT_LINE_LO)
            loNow  := line.get_price(LT_LINE_LO,  bar_index)

    // ─────────────────────────────────────────────────────────────────────────────
    // UTB/DTB and UTA/DTA Channel Logics
    // UTR/DTR resume on channel logic
    // ─────────────────────────────────────────────────────────────────────────────
    if LT_FROZEN and not LT_CHANGED_THIS_BAR
        float upP_now = na(upNow) ? line.get_price(LT_LINE_UP, bar_index) : upNow
        float loP_now = na(loNow) ? line.get_price(LT_LINE_LO, bar_index) : loNow
        // UTB/DTB zone thresholds: if ES1/ER1 are confirmed, use 1 ATR beyond ES1/ER1
        // (even if ES2/ER2 exist, we still anchor to ES1/ER1)
        float utb_zone_default = not na(LT_LINE_UTBZONE) ? line.get_price(LT_LINE_UTBZONE, bar_index) : na
        float dtb_zone_default = not na(LT_LINE_DTBZONE) ? line.get_price(LT_LINE_DTBZONE, bar_index) : na
        float es1_price = (LT_ES_CONFIRMED and not na(LT_LINE_ES)) ? line.get_price(LT_LINE_ES, bar_index) : na
        float er1_price = (LT_ER_CONFIRMED and not na(LT_LINE_ER)) ? line.get_price(LT_LINE_ER, bar_index) : na
        float utb_zone = not na(es1_price) ? (es1_price - 1.0 * atr) : utb_zone_default
        float dtb_zone = not na(er1_price) ? (er1_price + 1.0 * atr) : dtb_zone_default

        // Track whether trigger zone came from extended lines (so we can also gate
        // on the default band-anchored zone, matching the labelling-side logic)
        bool utbFromExtendedTrig = not na(es1_price)
        bool dtbFromExtendedTrig = not na(er1_price)

        bool isUptrend   = not na(LT_ANGLE_NORM_DEG) ? LT_ANGLE_NORM_DEG > 0 : (-LT_SLOPE) > 0
        bool isDowntrend = not na(LT_ANGLE_NORM_DEG) ? LT_ANGLE_NORM_DEG < 0 : (-LT_SLOPE) < 0

        // Breaks
        if isUptrend and not na(loP_now)
            // bool utb_raw = low < (loP_now - BREAK_ATR_X * atr)
            bool utb_raw = low <= utb_zone and (utbFromExtendedTrig ? (not na(utb_zone_default) and low <= utb_zone_default) : true)
            UTB_THIS_BAR := (not HAD_UTB) and utb_raw
            if UTB_THIS_BAR
                HAD_UTB := true, HAD_DTB := false
                AFTER_BREAK_DIR := +1
                FULL_OUTSIDE_COUNT := 0   // start counting full bars outside lower band
        if isDowntrend and not na(upP_now)
            // bool dtb_raw = high > (upP_now + BREAK_ATR_X * atr)
            bool dtb_raw = high >= dtb_zone and (dtbFromExtendedTrig ? (not na(dtb_zone_default) and high >= dtb_zone_default) : true)
            DTB_THIS_BAR := (not HAD_DTB) and dtb_raw
            if DTB_THIS_BAR
                HAD_DTB := true, HAD_UTB := false
                AFTER_BREAK_DIR := -1
                FULL_OUTSIDE_COUNT := 0   // start counting full bars outside upper band

        // ── Acceleration latch + resume (symmetric to UTR/DTR)
        var bool UTA_RESUME_THIS_BAR = false
        var bool DTA_RESUME_THIS_BAR = false

        // Triggers (same thresholds as before, but latched)
        if isUptrend and not na(upP_now)
            bool uta_raw = high >= dtb_zone and (dtbFromExtendedTrig ? (not na(dtb_zone_default) and high >= dtb_zone_default) : true)
            UTA_THIS_BAR := (not HAD_UTA) and uta_raw
            if UTA_THIS_BAR
                HAD_UTA := true
                HAD_DTA := false

                AFTER_BREAK_DIR := -1
                FULL_OUTSIDE_COUNT := 0

        if isDowntrend and not na(loP_now)
            bool dta_raw = low <= utb_zone and (utbFromExtendedTrig ? (not na(utb_zone_default) and low <= utb_zone_default) : true)
            DTA_THIS_BAR := (not HAD_DTA) and dta_raw
            if DTA_THIS_BAR
                HAD_DTA := true
                HAD_UTA := false

                AFTER_BREAK_DIR := +1
                FULL_OUTSIDE_COUNT := 0

        // “Resume” (re-arm) after price crosses back through the band by RESUME_ATR_X*ATR
        // After UTA (above upper), require cross UNDER (upper − resume_margin)
        if HAD_UTA and not na(upP_now)
            UTA_RESUME_THIS_BAR := ta.crossunder(close, upP_now - RESUME_ATR_X * atr)
            if UTA_RESUME_THIS_BAR
                HAD_UTA := false

        // After DTA (below lower), require cross OVER (lower + resume_margin)
        if HAD_DTA and not na(loP_now)
            DTA_RESUME_THIS_BAR := ta.crossover(close, loP_now + RESUME_ATR_X * atr)
            if DTA_RESUME_THIS_BAR
                HAD_DTA := false

        // Resumes
        if isUptrend and not na(loP_now)
            UTR_THIS_BAR := HAD_UTB and not UTB_THIS_BAR and ta.crossover(close, loP_now + RESUME_ATR_X * atr)
            if UTR_THIS_BAR
                HAD_UTB := false, HAD_UTA := false
                UTB_THIS_BAR := false, DTB_THIS_BAR := false, UTA_THIS_BAR := false
                AFTER_BREAK_DIR := 0
                FULL_OUTSIDE_COUNT := 0
        if isDowntrend and not na(upP_now)
            DTR_THIS_BAR := HAD_DTB and not DTB_THIS_BAR and ta.crossunder(close, upP_now - RESUME_ATR_X * atr)
            if DTR_THIS_BAR
                HAD_DTB := false, HAD_DTA := false
                UTB_THIS_BAR := false, DTB_THIS_BAR := false, DTA_THIS_BAR := false
                AFTER_BREAK_DIR := 0
                FULL_OUTSIDE_COUNT := 0

    // ── LATCH: set once on any UTB/DTB bar (DISABLED when legacyNoLatch = true)
    if UTB_THIS_BAR
        BREAK_LATCH := true
        BREAK_DIR   := +1
        BREAK_EVENT_COUNT := math.min(2, BREAK_EVENT_COUNT + 1)
        LAST_BREAK_BAR := bar_index
    if DTB_THIS_BAR
        BREAK_LATCH := true
        BREAK_DIR   := -1
        BREAK_EVENT_COUNT := math.min(2, BREAK_EVENT_COUNT + 1)
        LAST_BREAK_BAR := bar_index

    // UTA = acceleration above upper band → same side as DTB
    if UTA_THIS_BAR
        BREAK_LATCH := true
        BREAK_DIR   := -1
        BREAK_EVENT_COUNT := math.min(2, BREAK_EVENT_COUNT + 1)
        LAST_BREAK_BAR := bar_index

    // DTA = acceleration below lower band → same side as UTB
    if DTA_THIS_BAR
        BREAK_LATCH := true
        BREAK_DIR   := +1
        BREAK_EVENT_COUNT := math.min(2, BREAK_EVENT_COUNT + 1)
        LAST_BREAK_BAR := bar_index

    bool EVENT_THIS_BAR = UTB_THIS_BAR or DTB_THIS_BAR or UTA_THIS_BAR or DTA_THIS_BAR

    // ─────────────────────────────────────────────────────────────────────────────
    // CHANNEL EXPIRATIONS
    // Expires active channel if number of bars outside channel is met
    // ─────────────────────────────────────────────────────────────────────────────
    if LT_FROZEN and AFTER_BREAK_DIR != 0 and not EVENT_THIS_BAR
        float upP_cnt = line.get_price(LT_LINE_UP,  bar_index)
        float loP_cnt = line.get_price(LT_LINE_LO,  bar_index)
        bool fullBelow = not na(loP_cnt) and high < loP_cnt
        bool fullAbove = not na(upP_cnt) and low  > upP_cnt
        bool ok = (AFTER_BREAK_DIR == +1 and fullBelow) or (AFTER_BREAK_DIR == -1 and fullAbove)
        FULL_OUTSIDE_COUNT := ok ? (FULL_OUTSIDE_COUNT + 1) : 0

        float  scorePctNow   = LT_FROZEN and not na(LT_SCORE) ? LT_SCORE * 100.0 : na
        bool   STRONG_ACTIVE = (not na(scorePctNow) and scorePctNow >= strongScorePct) or STRONG_PROMOTED
        int    effFullBarsAfterBreak = STRONG_ACTIVE ? (fullBarsAfterBreak * 2) : fullBarsAfterBreak

        if FULL_OUTSIDE_COUNT >= effFullBarsAfterBreak
            // hard unfreeze
            UP_OUTSIDE_COUNT := 0
            DN_OUTSIDE_COUNT := 0

            // Snapshot previous channel values before archiving/deleting
            // Only overwrite PREV_CH if current channel lines exist (avoid blanking after expiration)
            [_su1, _sl1, _sm1, _st1] = snapshotPrevChannel()
            if not na(_sm1)
                PREV_CH_UPPER := _su1, PREV_CH_LOWER := _sl1, PREV_CH_MID := _sm1
                PREV_CH_TREND := _st1, PREV_CH_BAR := bar_index, PREV_CH_VALID := true

            // ── Age good channel archive; expire if too old
            if array.size(ARCH_MID) > 0
                ARCH_CHANNEL_AGE += 1
            if ARCH_CHANNEL_AGE >= ARCH_MAX_AGE and array.size(ARCH_MID) > 0
                utils.deleteAllLines(ARCH_MID), utils.deleteAllLines(ARCH_UP), utils.deleteAllLines(ARCH_LO)
                utils.deleteAllFills(ARCH_FILLU), utils.deleteAllFills(ARCH_FILLL)
                array.clear(ARCH_MID), array.clear(ARCH_UP), array.clear(ARCH_LO)
                array.clear(ARCH_FILLU), array.clear(ARCH_FILLL)
                ARCH_CHANNEL_AGE := 0

            bool _didArch1 = archiveCurrentChannelIfGood()
            if _didArch1
                ARCH_CHANNEL_AGE := 0

            // ── Mark channel changed for mid-trade SL fallback
            if strategy.position_size != 0
                STRAT_CH_CHANGED := true

            LT_FROZEN := false
            GOOD_ALERTED := false
            AFTER_BREAK_DIR := 0
            FULL_OUTSIDE_COUNT := 0

            LT_LINE_MID := utils.deleteLine(LT_LINE_MID), LT_LINE_UP := utils.deleteLine(LT_LINE_UP), LT_LINE_LO := utils.deleteLine(LT_LINE_LO)
            if not na(LT_FILL_U)
                linefill.delete(LT_FILL_U), linefill.delete(LT_FILL_L), LT_FILL_U := na, LT_FILL_L := na

            utils.deleteAllLines(longTermLines), utils.deleteAllFills(longTermFills)

            // Preserve cooldowns before reset (for backfill to inherit)
            PRESERVED_UPPER_BAR := LAST_UPPER_LABELBAR, PRESERVED_LOWER_BAR := LAST_LOWER_LABELBAR
            PRESERVED_MR_BAR    := LAST_MR_LABELBAR, PRESERVED_MS_BAR    := LAST_MS_LABELBAR

            LAST_UPPER_LABELBAR := na, LAST_LOWER_LABELBAR := na, LAST_MR_LABELBAR := na, LAST_MS_LABELBAR := na
            MR_ARMED := true, MS_ARMED := true, SRHITS_UP := 0, SRHITS_DN := 0, STRONG_PROMOTED := false

            array.clear(MR_HIT_BARS), array.clear(MS_HIT_BARS), MRHITS_CNT := 0, MSHITS_CNT := 0

            HAD_UTB := false, HAD_DTB := false, HAD_UTA := false, HAD_DTA := false
            PENDING_RETEST_SHORT := false, PENDING_RETEST_SHORT_BAR := na, PENDING_RETEST_SHORT_LVL := na, RETEST_TOUCHED_SHORT := false, PENDING_RETEST_LONG := false, PENDING_RETEST_LONG_BAR := na, PENDING_RETEST_LONG_LVL := na, RETEST_TOUCHED_LONG := false, PENDING_HOLD_COUNT := 0
            SELL_READY := true, BUY_READY := true, barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999
            LAST_EVT_BAR := na, LT_START_BAR := na, BREAK_LATCH := false, BREAK_DIR   := 0, BREAK_EVENT_COUNT := 0
            LAST_BREAK_BAR := na, LT_ANGLE_DEG := na, LT_ANGLE_NORM_DEG := na, BUY_ARMED := false, BUY_ARMED_BAR := na
            SELL_ARMED := false, SELL_ARMED_BAR := na, SKIP_NORMAL_SELL := false, SKIP_NORMAL_BUY := false
            BUY_REF_PENDING := false, BUY_REF_BAR := na, BUY_REF_HIGH := na
            BUY_REF_ZONE_PRICE := na, BUY_REF_SL_PRICE := na, SELL_REF_PENDING := false, SELL_REF_BAR := na, SELL_REF_LOW := na
            SELL_REF_ZONE_PRICE := na, SELL_REF_SL_PRICE := na, SELL_ARMED_ER := false, SELL_ARMED_ER_BAR := na, BUY_ARMED_ES := false
            BUY_ARMED_ES_BAR := na, SELL_ER_REF_PENDING := false, SELL_ER_REF_BAR := na, SELL_ER_REF_LOW := na, SELL_ER_REF_ZONE_PRICE := na
            SELL_ER_REF_SL_PRICE := na, BUY_ES_REF_PENDING := false, BUY_ES_REF_BAR := na, BUY_ES_REF_HIGH := na, BUY_ES_REF_ZONE_PRICE := na
            BUY_ES_REF_SL_PRICE := na, ER_HIT_COUNT := 0, ER_LAST_HIT_BAR := na, ES_HIT_COUNT := 0, ES_LAST_HIT_BAR := na,  ER2_HIT_COUNT := 0
            ER2_LAST_HIT_BAR := na, ES2_HIT_COUNT := 0, ES2_LAST_HIT_BAR := na, LT_ER2_CONFIRMED := false, LT_ES2_CONFIRMED := false
            SELL_ARMED_ER2 := false, SELL_ARMED_ER2_BAR := na, BUY_ARMED_ES2 := false, BUY_ARMED_ES2_BAR := na
            clearAllHitLabels()

            CANDIDATE_ER2_OFFSET := na, CANDIDATE_ER2_PIVOT_BAR := na, CANDIDATE_ER2_LAST_HIT_BAR := na
            CANDIDATE_ES2_OFFSET := na, CANDIDATE_ES2_PIVOT_BAR := na, CANDIDATE_ES2_LAST_HIT_BAR := na

            // Reset PENDING ER/ES tracking (prevents stale pending from old channel)
            PENDING_ER_OFFSET := na, PENDING_ER_HIGH := na, PENDING_ER_BAR := na, PENDING_ES_OFFSET := na, PENDING_ES_LOW := na, PENDING_ES_BAR := na

            string afterTxt = AFTER_BREAK_DIR == +1 ? "AFTER_UTB" : AFTER_BREAK_DIR == -1 ? "AFTER_DTB" : "UNKNOWN"

    // ─────────────────────────────────────────────────────────────────────────────
    // CHANNEL EXPIRATIONS
    // Breakout check - Determined by the number of bars outside the channel
    // and if price reaches the required breakout ATR distance
    // ─────────────────────────────────────────────────────────────────────────────
    if LT_FROZEN
        bool upOutside = not na(upNow) and low  > upNow
        bool dnOutside = not na(loNow) and high < loNow

        UP_OUTSIDE_COUNT := upOutside ? (UP_OUTSIDE_COUNT + 1) : 0
        DN_OUTSIDE_COUNT := dnOutside ? (DN_OUTSIDE_COUNT + 1) : 0

        float  scorePctNow2   = LT_FROZEN and not na(LT_SCORE) ? LT_SCORE * 100.0 : na
        bool   STRONG_ACTIVE2 = (not na(scorePctNow2) and scorePctNow2 >= strongScorePct) or STRONG_PROMOTED
        int    effMinBarsOutside = STRONG_ACTIVE2 ? (minBarsOutside * 2) : minBarsOutside
        float  effBreakoutX      = STRONG_ACTIVE2 ? (breakoutX * 2.0)   : breakoutX

        bool upAtrOK = not na(upNow) and low  > upNow + effBreakoutX * atr
        bool dnAtrOK = not na(loNow) and high < loNow - effBreakoutX * atr

        bool brokeUp = UP_OUTSIDE_COUNT >= effMinBarsOutside and upAtrOK
        bool brokeDn = DN_OUTSIDE_COUNT >= effMinBarsOutside and dnAtrOK

        bool latchActive = BREAK_LATCH and (BREAK_EVENT_COUNT < 2)

        if (brokeUp or brokeDn) and not EVENT_THIS_BAR and not latchActive and AFTER_BREAK_DIR == 0
            UP_OUTSIDE_COUNT := 0, DN_OUTSIDE_COUNT := 0

            // Snapshot previous channel values before archiving/deleting
            // Only overwrite PREV_CH if current channel lines exist (avoid blanking after expiration)
            [_su2, _sl2, _sm2, _st2] = snapshotPrevChannel()
            if not na(_sm2)
                PREV_CH_UPPER := _su2, PREV_CH_LOWER := _sl2, PREV_CH_MID := _sm2
                PREV_CH_TREND := _st2, PREV_CH_BAR := bar_index, PREV_CH_VALID := true

            // ── Age good channel archive; expire if too old
            if array.size(ARCH_MID) > 0
                ARCH_CHANNEL_AGE += 1
            if ARCH_CHANNEL_AGE >= ARCH_MAX_AGE and array.size(ARCH_MID) > 0
                utils.deleteAllLines(ARCH_MID), utils.deleteAllLines(ARCH_UP), utils.deleteAllLines(ARCH_LO)
                utils.deleteAllFills(ARCH_FILLU), utils.deleteAllFills(ARCH_FILLL)
                array.clear(ARCH_MID), array.clear(ARCH_UP), array.clear(ARCH_LO)
                array.clear(ARCH_FILLU), array.clear(ARCH_FILLL)
                ARCH_CHANNEL_AGE := 0

            bool _didArch2 = archiveCurrentChannelIfGood()
            if _didArch2
                ARCH_CHANNEL_AGE := 0

            // ── Mark channel changed for mid-trade SL fallback
            if strategy.position_size != 0
                STRAT_CH_CHANGED := true

            LT_FROZEN := false

            // Array clears (cannot be included in function return)
            array.clear(MR_HIT_BARS), array.clear(MS_HIT_BARS)

            LT_LINE_MID := utils.deleteLine(LT_LINE_MID), LT_LINE_UP := utils.deleteLine(LT_LINE_UP), LT_LINE_LO := utils.deleteLine(LT_LINE_LO)
            if not na(LT_FILL_U)
                linefill.delete(LT_FILL_U), linefill.delete(LT_FILL_L), LT_FILL_U := na, LT_FILL_L := na

            utils.deleteAllLines(longTermLines), utils.deleteAllFills(longTermFills)

            LT_LINE_BUYZONE := utils.deleteLine(LT_LINE_BUYZONE)
            LT_LINE_SELLZONE := utils.deleteLine(LT_LINE_SELLZONE)
            LT_LINE_UTBZONE := utils.deleteLine(LT_LINE_UTBZONE)
            LT_LINE_DTBZONE := utils.deleteLine(LT_LINE_DTBZONE)
            LT_LINE_BUYSL := utils.deleteLine(LT_LINE_BUYSL)
            LT_LINE_SELLSL := utils.deleteLine(LT_LINE_SELLSL)
            LT_LINE_ER_MINZONE := utils.deleteLine(LT_LINE_ER_MINZONE)
            LT_LINE_ES_MINZONE := utils.deleteLine(LT_LINE_ES_MINZONE)

            LT_LINE_ER := utils.deleteLine(LT_LINE_ER)
            LT_LINE_ES := utils.deleteLine(LT_LINE_ES)
            LT_LINE_ER_SELLZONE := utils.deleteLine(LT_LINE_ER_SELLZONE)
            LT_LINE_ER_DTBZONE := utils.deleteLine(LT_LINE_ER_DTBZONE)
            LT_LINE_ES_BUYZONE := utils.deleteLine(LT_LINE_ES_BUYZONE)
            LT_LINE_ES_UTBZONE := utils.deleteLine(LT_LINE_ES_UTBZONE)

            LT_LINE_ER2 := utils.deleteLine(LT_LINE_ER2)
            LT_LINE_ER2_SELLZONE := utils.deleteLine(LT_LINE_ER2_SELLZONE)
            LT_LINE_ER2_DTBZONE := utils.deleteLine(LT_LINE_ER2_DTBZONE)
            LT_LINE_ES2 := utils.deleteLine(LT_LINE_ES2)
            LT_LINE_ES2_BUYZONE := utils.deleteLine(LT_LINE_ES2_BUYZONE)
            LT_LINE_ES2_UTBZONE := utils.deleteLine(LT_LINE_ES2_UTBZONE)

            LT_ER_OFFSET := na, LT_ER_CONFIRMED := false, LT_ES_OFFSET := na, LT_ES_CONFIRMED := false, LT_ER_BAR := na, LT_ES_BAR := na
            LT_ER2_OFFSET := na, LT_ER2_CONFIRMED := false, LT_ES2_OFFSET := na, LT_ES2_CONFIRMED := false, LT_ER2_BAR := na, LT_ES2_BAR := na

            // Clear candidate tracking on channel change
            CANDIDATE_ER_OFFSET := na, CANDIDATE_ER_BAR := na, CANDIDATE_ER_HIT_COUNT := 0, CANDIDATE_ER_LAST_HIT_BAR := na,  
            CANDIDATE_ES_OFFSET := na, CANDIDATE_ES_BAR := na, CANDIDATE_ES_HIT_COUNT := 0, CANDIDATE_ES_LAST_HIT_BAR := na

            CANDIDATE_ER2_OFFSET := na, CANDIDATE_ER2_PIVOT_BAR := na, CANDIDATE_ER2_LAST_HIT_BAR := na
            CANDIDATE_ES2_OFFSET := na, CANDIDATE_ES2_PIVOT_BAR := na, CANDIDATE_ES2_LAST_HIT_BAR := na

            // Clear previous extended lines on channel change
            PREV_LT_LINE_ER := utils.deleteLine(PREV_LT_LINE_ER)
            PREV_LT_LINE_ES := utils.deleteLine(PREV_LT_LINE_ES)

            // Preserve cooldowns before reset (for backfill to inherit)
            PRESERVED_UPPER_BAR := LAST_UPPER_LABELBAR, PRESERVED_LOWER_BAR := LAST_LOWER_LABELBAR
            PRESERVED_MR_BAR    := LAST_MR_LABELBAR, PRESERVED_MS_BAR    := LAST_MS_LABELBAR

            LAST_UPPER_LABELBAR := na, LAST_LOWER_LABELBAR := na, LAST_MR_LABELBAR    := na, LAST_MS_LABELBAR    := na
            MR_ARMED := true, MS_ARMED := true
            // reset SR-promotion state
            SRHITS_UP := 0, SRHITS_DN := 0, STRONG_PROMOTED := false

            array.clear(MR_HIT_BARS), array.clear(MS_HIT_BARS)
            MRHITS_CNT := 0, MSHITS_CNT := 0

            LAST_EVT_BAR := na, LT_ANGLE_DEG := na, LT_ANGLE_NORM_DEG := na, LT_START_BAR := na, GOOD_ALERTED := false
            HAD_UTB := false, HAD_DTB := false, HAD_UTA := false, HAD_DTA := false, BUY_ARMED := false, BUY_ARMED_BAR := na
            PENDING_RETEST_SHORT := false, PENDING_RETEST_SHORT_BAR := na, PENDING_RETEST_SHORT_LVL := na, RETEST_TOUCHED_SHORT := false, PENDING_RETEST_LONG := false, PENDING_RETEST_LONG_BAR := na, PENDING_RETEST_LONG_LVL := na, RETEST_TOUCHED_LONG := false, PENDING_HOLD_COUNT := 0
            SELL_READY := true, BUY_READY := true, barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999
            SELL_ARMED := false, SELL_ARMED_BAR := na, SKIP_NORMAL_SELL := false, SKIP_NORMAL_BUY := false
            BUY_REF_PENDING := false, BUY_REF_BAR := na, BUY_REF_HIGH := na, BUY_REF_ZONE_PRICE := na
            BUY_REF_SL_PRICE := na, SELL_REF_PENDING := false, SELL_REF_BAR := na, SELL_REF_LOW := na, SELL_REF_ZONE_PRICE := na, SELL_REF_SL_PRICE := na
            SELL_ARMED_ER := false, SELL_ARMED_ER_BAR := na, BUY_ARMED_ES := false, BUY_ARMED_ES_BAR := na, SELL_ER_REF_PENDING := false, SELL_ER_REF_BAR := na
            SELL_ER_REF_LOW := na, SELL_ER_REF_ZONE_PRICE := na, SELL_ER_REF_SL_PRICE := na, BUY_ES_REF_PENDING := false, BUY_ES_REF_BAR := na, BUY_ES_REF_HIGH := na
            BUY_ES_REF_ZONE_PRICE := na, BUY_ES_REF_SL_PRICE := na, ER_HIT_COUNT := 0, ER_LAST_HIT_BAR := na, ES_HIT_COUNT := 0, ES_LAST_HIT_BAR := na, ER2_HIT_COUNT := 0
            ER2_LAST_HIT_BAR := na, ES2_HIT_COUNT := 0, ES2_LAST_HIT_BAR := na, LT_ER2_CONFIRMED := false, LT_ES2_CONFIRMED := false, SELL_ARMED_ER2 := false
            SELL_ARMED_ER2_BAR := na, BUY_ARMED_ES2 := false, BUY_ARMED_ES2_BAR := na

            // Reset PENDING ER/ES tracking (prevents stale pending from old channel)
            PENDING_ER_OFFSET := na, PENDING_ER_HIGH := na, PENDING_ER_BAR := na, PENDING_ES_OFFSET := na, PENDING_ES_LOW := na, PENDING_ES_BAR := na

            clearAllHitLabels()

            string dirTxt = brokeUp ? "UP" : brokeDn ? "DOWN" : "?"


    // ─────────────────────────────────────────────────────────────────────────────
    // CALCULATES THE BEST PERIOD AND DEVIATION
    // ─────────────────────────────────────────────────────────────────────────────

    var float[] devCands = array.new_float()
    if array.size(devCands) == 0
        float span = math.max(0.0, devMax - devMin)
        int steps = math.max(1, int(math.floor(span / math.max(0.0001, devStep))) + 1)
        for iDev = 0 to steps - 1
            float dv = devMin + iDev * devStep
            array.push(devCands, dv)

    // ── When autoDev is OFF, use a single-element candidate list (init once, update value)
    var float[] devSingle = array.new_float(1)

    float bestScore = na, int bestP = na, float bestSlope = na, float bestStd = na, float bestInt = na, float bestDev   = na

    if valuesNotEmpty

        for bix = 0 to array.size(ChannelPeriods) - 1
            float stdB = StdDevs.get(bix), float slpB = Slopes.get(bix)
            float intB = Intercepts.get(bix), float peaB = Pearsons.get(bix)

            if na(stdB) or na(slpB) or na(intB) or na(peaB)
                continue

            int p = ChannelPeriods.get(bix)
            [compS, devUse] = compositeBestForPeriod(p, intB, slpB, stdB, peaB, devCands, devSingle, atr)
            if na(bestScore) or compS > bestScore
                bestScore := compS, bestP := p, bestSlope := slpB, bestStd := stdB
                bestInt := intB, bestDev := devUse

    bool hasCandidate    = not na(bestScore)
    bool passesThreshold = hasCandidate and (bestScore * 100.0) >= minScorePct

    float candSTD = bestStd, float candSLOPE = bestSlope
    float candINTERCEPT = bestInt, int candPERIOD = bestP, float candDEVMULT = bestDev

    int curSign  = utils.signf(-LT_SLOPE), int candSign = utils.signf(-candSLOPE)

    // ─────────────────────────────────────────────────────────────────────────────
    // FORCE CHANNEL UPDATE
    // Check if it passes minimum threshold (45%) and if it has a UTB/DTB and didn't
    // price didn't return back inside the active channel
    // ─────────────────────────────────────────────────────────────────────────────
    bool pendingBreak   = LT_FROZEN and BREAK_LATCH and (BREAK_EVENT_COUNT < 2) and not (UTR_THIS_BAR or DTR_THIS_BAR) and not na(LAST_BREAK_BAR)
    float scorePctNow3 = LT_FROZEN and not na(LT_SCORE) ? LT_SCORE * 100.0 : na
    bool  STRONG_ACTIVE3 = (not na(scorePctNow3) and scorePctNow3 >= strongScorePct) or STRONG_PROMOTED
    int   effForceNoResumeBars = STRONG_ACTIVE3 ? (forceNoResumeBars * 2) : forceNoResumeBars

    bool timeExceeded   = pendingBreak and (bar_index - LAST_BREAK_BAR >= effForceNoResumeBars)

    bool stillNotResumed =
          timeExceeded and not na(upNow) and not na(loNow) and (
             (BREAK_DIR == +1 and close <= (loNow + RESUME_ATR_X * atr)) or
             (BREAK_DIR == -1 and close >= (upNow - RESUME_ATR_X * atr))
          )

    // No-SR force
    int lastSRPair1 = utils.maxi(LAST_UPPER_LABELBAR, LAST_LOWER_LABELBAR)
    int lastSRPair2 = utils.maxi(LAST_MR_LABELBAR,    LAST_MS_LABELBAR)
    int lastSRBar   = utils.maxi(lastSRPair1, lastSRPair2)
    int effForceNoSRBars = STRONG_ACTIVE3 ? (forceNoSRBars * 2) : forceNoSRBars
    bool noSRTooLong = STRONG_ACTIVE3 and LT_FROZEN and not na(lastSRBar) and (bar_index - lastSRBar >= effForceNoSRBars)

    // Fire force-update for either condition (only if candidate passes threshold)
    bool forceUpdateNow = (stillNotResumed and passesThreshold) or (noSRTooLong and passesThreshold and not EVENT_THIS_BAR)

    if forceUpdateNow
        float oldSlopeFU     = LT_SLOPE
        float oldSlopeDispFU = na(oldSlopeFU) ? na : -oldSlopeFU

