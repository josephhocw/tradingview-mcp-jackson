//@version=6
strategy("RHO Navigator V2.5 [Breakout]", 
         overlay = true, 
         max_bars_back = 5000,
         fill_orders_on_standard_ohlc = true,
         calc_on_every_tick = false,
         process_orders_on_close = true,
         pyramiding = 0,
         explicit_plot_zorder = true,
         currency = currency.USD,
         initial_capital = 10000,
         default_qty_type = strategy.percent_of_equity,
         default_qty_value = 100,
         margin_long = 0,
         margin_short = 0,
         slippage = 2)
         
import robinhosa/RHOUtils/25 as utils


// ═══════════════════════════════════════════════════════════════════════════
// USER INPUTS
// ═══════════════════════════════════════════════════════════════════════════

string groupFilters = 'Trade Filters'
bool useChannelWidthFilter = input.bool(true, "Filter Trades by Channel Width", group = groupFilters)
float wideChannelATR = input.float(10.0, "Wide Channel Threshold (x ATR)", minval = 1.0, maxval = 20.0, step = 0.5, group = groupFilters, display = display.none)
float narrowChannelATR = input.float(5.5, "Narrow Channel Threshold (x ATR)", minval = 0.5, maxval = 10.0, step = 0.5, group = groupFilters, display = display.none)
float slZonePctInput = input.float(0.35, "SL Zone Percentage", minval = 0.01, maxval = 1.0, step = 0.05, group = groupFilters, display = display.none)
float entryZonePctInput = input.float(0.50, "Entry Zone Percentage", minval = 0.01, maxval = 1.0, step = 0.05, group = groupFilters, display = display.none)
float boBdAtrDist = input.float(2.5, "BO/BD ATR Dist", minval = 0.1, maxval = 10.0, step = 0.1, group = groupFilters, display = display.none)

string groupStrategy = 'Strategy Settings'
bool enableMABasedFilter = input.bool(false, "Enable MA-based Filter (ie. Close must be below 9-MA to trigger Buy)", group = groupStrategy, display = display.none)
string tpExitMode          = input.string("Trigger Bar", "TP Exit Mode", options = ["Consecutive Closes", "Trigger Bar", "Disabled"], group = groupStrategy, display = display.none, tooltip = "Consecutive Closes: original N-bar closes beyond MA. Trigger Bar: TB sets when close crosses MA, exit on next bar if continuation confirmed. Disabled: no MA-based TP.")
int    tpConsecutiveCloses = input.int(5, "TP Consecutive Closes above/below MA", minval = 2, maxval = 20, group = groupStrategy, display = display.none, tooltip = "[Consecutive Closes mode] Number of consecutive closes above/below MA for TP while in profit")
int    maLengthTP          = input.int(9, "MA Length for TP", minval = 2, maxval = 50, group = groupStrategy, display = display.none, tooltip = "Moving average length used for take profit condition")
bool   tbRequireProfit     = input.bool(true, "TB: Only When in Profit", group = groupStrategy, display = display.none, tooltip = "[Trigger Bar mode] Only activate Trigger Bar TP when the position is in profit.")
bool   tbAlsoAsSL          = input.bool(false, "TB: Also Use as Stop Loss", group = groupStrategy, display = display.none, tooltip = "[Trigger Bar mode] When enabled, the Trigger Bar mechanism also acts as a stop loss (fires even when not in profit). Overrides the 'Only When in Profit' setting for SL direction.")
float  tbSlMinAtrDist      = input.float(0.5, "TB SL: Min ATR Distance from Entry", minval = 0.0, maxval = 10.0, step = 0.1, group = groupStrategy, display = display.none, tooltip = "[Trigger Bar SL] Minimum ATR distance price must have moved against your entry before TB-SL can trigger. Prevents TB-SL from firing on minor adverse moves near entry. 0 = no minimum distance required.")
float  slAtrBuffer         = input.float(1.0, "SL Min ATR Distance", minval = 0.0, maxval = 10.0, step = 0.1, group = groupStrategy, display = display.none, tooltip = "Minimum ATR distance beyond the fixed SL line. 0 = use exact upper/lower line as SL.")
float  angleThreshold      = input.float(20.0, "Trend Angle Threshold (°)", minval = 0.0, maxval = 89.0, step = 1.0, group = groupStrategy, display = display.none, tooltip = "Normalized angle threshold for entry signals. Uptrend > threshold, Downtrend < -threshold, otherwise Sideways. Only affects B/S/UTB/DTB labels and strategy entries.")
int    maCrossBarLimit     = input.int(10, "MA Cross Bar Limit (0 = disabled)", minval = 0, maxval = 50, group = groupStrategy, display = display.none, tooltip = "Only allow breakout entries within this many bars after MA9/MA30 cross. MA9 crossing under MA30 qualifies Short; MA9 crossing over MA30 qualifies Long. 0 = no limit.")
bool   requireMaAlignment = input.bool(false, "Require MA9/MA30 Alignment", group = groupStrategy, display = display.none, tooltip = "When enabled, Short entries require MA9 < MA30 and Long entries require MA9 > MA30 at the time of entry.")
float  maMinAtrDist       = input.float(0.0, "MA9/MA30 Min ATR Distance", minval = 0.0, maxval = 20.0, step = 0.5, group = groupStrategy, display = display.none, tooltip = "Minimum distance between MA9 and MA30 in ATR multiples for an entry to qualify. 0 = no minimum distance required.")
string entryConfirmMode    = input.string("Close Confirmation", "Entry Confirmation Mode", options = ["Immediate", "Close Confirmation", "Retest"], group = groupStrategy, display = display.none, tooltip = "Immediate: enter on the UTB/DTB bar (original behavior). Close Confirmation: require the breakout bar to CLOSE beyond the zone — filters wick traps, minimal delay. Retest: wait for a full pullback to the broken band and bounce confirmation — fewest trades but highest quality.")
int    retestMaxBars      = input.int(20, "Retest Max Wait (bars)", minval = 3, maxval = 60, group = groupStrategy, display = display.none, tooltip = "[Retest mode only] Maximum bars after UTB/DTB to wait for a retest of the broken level. If no retest occurs within this window, the signal is discarded.")
float  retestZonePct      = input.float(0.5, "Retest Zone (x ATR from band)", minval = 0.1, maxval = 3.0, step = 0.1, group = groupStrategy, display = display.none, tooltip = "[Retest mode only] How close price must return to the broken band to count as a retest. e.g. 0.5 = within 0.5 ATR of the band.")
int    holdBarsConfirm    = input.int(1, "Close Confirm Bars (hold beyond zone)", minval = 1, maxval = 10, group = groupStrategy, display = display.none, tooltip = "[Close Confirmation mode] How many consecutive bars must close beyond the breakout zone before entry fires. 1 = enter on the next bar that closes beyond the zone. 2 = require 2 consecutive closes.")
string groupBESL = 'Breakeven & Trailing Stop Loss'
bool   useBreakevenSL     = input.bool(false, "Enable Breakeven SL", group = groupBESL, tooltip = "When price moves in your favor by the Breakeven Activation distance (in ATR), the SL is moved to your entry price (breakeven). This protects against giving back open profits.")
float  beActivationATR    = input.float(1.5, "Breakeven Activation (x ATR)", minval = 0.5, maxval = 10.0, step = 0.5, group = groupBESL, display = display.none, tooltip = "How far price must move in your favor (in ATR multiples) before the SL moves to breakeven (entry price).")
bool   useTrailingSL      = input.bool(false, "Enable Trailing SL", group = groupBESL, tooltip = "When enabled, after price moves favorably by the Trail Activation distance, the SL trails price at the specified ATR distance. Locks in profits on extended moves. Requires Breakeven SL to be enabled (trailing starts after breakeven is activated).")
float  trailActivationATR = input.float(2.0, "Trail Activation (x ATR)", minval = 0.5, maxval = 10.0, step = 0.5, group = groupBESL, display = display.none, tooltip = "How far price must move in your favor (in ATR multiples) before the trailing SL activates. Must be >= Breakeven Activation. Once activated, the SL trails at the Trail Distance below/above the best price.")
float  trailATRMult       = input.float(2.5, "Trail Distance (x ATR)", minval = 0.5, maxval = 10.0, step = 0.5, group = groupBESL, display = display.none, tooltip = "ATR multiplier for the trailing stop distance. Once trailing is activated, the SL follows at this distance from the best price achieved.")

string groupUI = 'UI Panels (Show/Hide)'
bool showTrendAnalysisPanel = input.bool(true, 'Show Trend Analysis Panel (Top Panel)', group = groupUI)
bool showEstimatesPanel = input.bool(false, 'Show TP/SL Levels Panel (Bottom Panel)', group = groupUI)

string groupLabels = 'UI Labels (Show/Hide)'
bool showMSMR = input.bool(true, 'Show Middle Support (MS)/Middle Resistance (MR) Labels', group = groupLabels)

string groupChartLines = 'Chart Lines (Show/Hide)'
bool showBuySellLineZone = input.bool(false, 'Show Buy/Sell Line Zone [Normal Channel]', group = groupChartLines, display = display.none)
bool showBuySellLineZoneExt = input.bool(false, 'Show Buy/Sell Line Zone [Extended Channel]', group = groupChartLines, display = display.none)
bool showUtbDtbZoneLines = input.bool(false, 'Show UTB/DTB Zone Lines', group = groupChartLines, display = display.none)
bool showErEsMinZoneLines = input.bool(false, 'Show ER/ES Min ATR Zone Lines', group = groupChartLines, display = display.none)

string groupERESSettings = 'Extended Lines (ER/ES) Settings'
int pivotLookbackLeft = input.int(10, "Pivot Lookback Left", minval=1, maxval=50, group = groupERESSettings, display = display.none)
int pivotLookbackRight = input.int(6, "Pivot Lookback Right", minval=1, maxval=50, group = groupERESSettings, display = display.none)
float extLineMinAtrDist = input.float(1.0, "Min ATR Distance for ER/ES", minval=0.1, maxval=10.0, step=0.1, group = groupERESSettings, display = display.none, tooltip = "Extended line must be at least this many ATRs from the channel band to qualify.")

string groupPeriodSettings = 'Period Settings'
int periodMin = input.int(100, "Minimum Period", group = groupPeriodSettings, display = display.none)
int periodMax = input.int(650, "Maximum Period", group = groupPeriodSettings, display = display.none)
int periodStep = input.int(50, "Period Step", group = groupPeriodSettings, display = display.none)

string groupDeviationSettings = 'Deviation Settings'
float devMin = input.float(1.0, "Minimum Deviation", group = groupDeviationSettings, display = display.none)
float devMax = input.float(3.0, "Maximum Deviation", group = groupDeviationSettings, display = display.none)
float devStep = input.float(0.1, "Deviation Step", group = groupDeviationSettings, display = display.none)


// Constant variables for Channel Scoring, Channel Expiration
int goldenIters = 7, float idealWidthAtr = 3.0, float widthToleranceAtr = 2.0
float wUtil = 0.3, float wWidth = 0.3, float wHits = 0.4, int hitsTarget = 6 
float minScorePct = 45.0, float strongScorePct = 55.0

float breakoutX = 8.0, int minBarsOutside = 10, int forceNoResumeBars = 60
int forceNoSRBars = 200, int fullBarsAfterBreak = 60

bool useWebhookJSON = true


// ═══════════════════════════════════════════════════════════════════════════
// INDICATOR CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════

float atr = ta.atr(14)
float ma9  = ta.sma(close, 9)
float ma30 = ta.sma(close, 30)
float maTP = ta.sma(close, maLengthTP)  // MA for strategy TP condition


// ── MA Cross Bar Counters (for breakout entry freshness filter)
// ma9 crossing under ma30 = bearish momentum (qualifies Short entries)
// ma9 crossing over  ma30 = bullish momentum (qualifies Long entries)
var int barsSinceMaCrossunder = 999  // bars since ma9 crossed under ma30 (for Short)
var int barsSinceMaCrossover  = 999  // bars since ma9 crossed over  ma30 (for Long)
bool _maCrossUnder = ta.crossunder(ma9, ma30)
bool _maCrossOver  = ta.crossover(ma9, ma30)
if _maCrossUnder
    barsSinceMaCrossunder := 0
    barsSinceMaCrossover  := 999
else if _maCrossOver
    barsSinceMaCrossover  := 0
    barsSinceMaCrossunder := 999
else
    barsSinceMaCrossunder += 1
    barsSinceMaCrossover  += 1

// Price Calculators
float midNow = na
float upNow = na
float loNow = na

// ═══════════════════════════════════════════════════════════════════════════
// SLIDING WINDOW CALCULATION
// - Slides "Starting Datetime" (SD) every 2500 bars.
// - Depends on two modes: "Bars Behind" and "Datetime"
// ═══════════════════════════════════════════════════════════════════════════

// Mode selection: Datetime for popular timeframes with specific start dates, otherwise Bars Behind
// Popular timeframes and their starting datetimes:
// 30S  - 31 Jan '26 00:00
// 1m   - 24 Jan '26 00:00
// 5m   - 30 Dec '25 00:00
// 15m  - 01 Oct '25 09:00
// 1H   - 03 Apr '24 00:00
// 1D   - 02 Jan '18 00:00

bool is30SecTimeframe = timeframe.period == "30S"
bool is1MinTimeframe  = timeframe.period == "1"
bool is5MinTimeframe  = timeframe.period == "5"
bool is15MinTimeframe = timeframe.period == "15"
bool is1HourTimeframe = timeframe.period == "60"
bool is1DayTimeframe  = timeframe.period == "D" or timeframe.period == "1D"

bool isPopularTimeframe = is30SecTimeframe or is1MinTimeframe or is5MinTimeframe or is15MinTimeframe or is1HourTimeframe or is1DayTimeframe
string initModeOption = isPopularTimeframe ? "Datetime" : "Bars Behind"

// Timeframe-specific starting timestamps
int TS_30S = timestamp("31 Jan 2026 00:00 +0800")
int TS_1M  = timestamp("24 Jan 2026 00:00 +0800")
int TS_5M  = timestamp("01 Aug 2025 00:00 +0800")
int TS_15M = timestamp("01 Oct 2025 09:00 +0800")
int TS_1H  = timestamp("03 Apr 2024 00:00 +0800")
int TS_1D  = timestamp("02 Jan 2018 00:00 +0800")

// Select the appropriate timestamp based on current timeframe
int INIT_TS_INPUT = is30SecTimeframe ? TS_30S :
                     is1MinTimeframe  ? TS_1M  :
                     is5MinTimeframe  ? TS_5M  :
                     is15MinTimeframe ? TS_15M :
                     is1HourTimeframe ? TS_1H  :
                     is1DayTimeframe  ? TS_1D  :
                     timestamp("01 Oct 2025 09:00 +0800")  // fallback (won't be used due to Bars Behind mode)

int INIT_BARS_BEHIND = 1500

// ───────────────────────── SLIDING WINDOW CONFIGURATION
// Maximum bars allowed from init point before shifting forward
int MAX_BARS_FROM_INIT = 2500
// How many bars to shift forward when limit is reached
int SHIFT_BARS_FORWARD = 2500

const int MAX_INIT_LABEL_LOOKBACK = 5000

var bool PENDING_REINIT = false
var int  PENDING_INIT_BAR_INDEX = na

int totalBarsAvailable = last_bar_index + 1
int effectiveBarsBack = math.min(INIT_BARS_BEHIND, totalBarsAvailable - 1)

int targetBarIndex = last_bar_index - effectiveBarsBack

// Store the derived timestamp from the target bar (only set once when we reach that bar)
var int DERIVED_INIT_TS = na
if initModeOption == "Bars Behind" and bar_index == targetBarIndex and na(DERIVED_INIT_TS)
    DERIVED_INIT_TS := time

// Base INIT_TS before sliding window adjustment
int BASE_INIT_TS = initModeOption == "Datetime" ? INIT_TS_INPUT : nz(DERIVED_INIT_TS, time + 31536000000)

// Holds all INIT labels (base + previous windows + active)
var label[] INIT_LABELS = array.new_label()

var int BASE_INIT_BAR_INDEX = na
bool crossedBaseInit = time >= BASE_INIT_TS and (bar_index == 0 or time[1] < BASE_INIT_TS)
if crossedBaseInit and na(BASE_INIT_BAR_INDEX)
    BASE_INIT_BAR_INDEX := bar_index

int barsFromBaseToEnd = na(BASE_INIT_BAR_INDEX) ? na : last_bar_index - BASE_INIT_BAR_INDEX
int shiftsNeeded = 0
if not na(barsFromBaseToEnd) and barsFromBaseToEnd >= MAX_BARS_FROM_INIT
    int remainingBars = barsFromBaseToEnd
    while remainingBars >= MAX_BARS_FROM_INIT
        shiftsNeeded += 1
        remainingBars -= SHIFT_BARS_FORWARD

int EFFECTIVE_INIT_BAR_INDEX = na(BASE_INIT_BAR_INDEX) ? na : BASE_INIT_BAR_INDEX + (shiftsNeeded * SHIFT_BARS_FORWARD)

var int EFFECTIVE_INIT_TS = na
if not na(EFFECTIVE_INIT_BAR_INDEX)
    if bar_index >= EFFECTIVE_INIT_BAR_INDEX
        int lookbackOffset = bar_index - EFFECTIVE_INIT_BAR_INDEX
        if lookbackOffset >= 0 and lookbackOffset <= bar_index
            EFFECTIVE_INIT_TS := time[lookbackOffset]
    else
        EFFECTIVE_INIT_TS := time + 31536000000  // 1 year in future

int INIT_TS = nz(EFFECTIVE_INIT_TS, time + 31536000000)

var bool INIT_LABEL_PLACED = false

if barstate.islast and not na(BASE_INIT_BAR_INDEX)
    while array.size(INIT_LABELS) > 0
        label old = array.pop(INIT_LABELS)
        if not na(old)
            label.delete(old)

    int totalShifts = math.max(shiftsNeeded, 0)

    for i = 0 to totalShifts
        int initBarIndex = BASE_INIT_BAR_INDEX + i * SHIFT_BARS_FORWARD

        if initBarIndex >= 0 and initBarIndex <= last_bar_index
            int offset = bar_index - initBarIndex

            // ⚠️ Extra safety: don't index further back than our cap
            if offset >= 0 and offset <= bar_index and offset <= MAX_INIT_LABEL_LOOKBACK
                float y = na
                // small micro-safety: avoid low[0] vs low[offset] confusion
                y := offset == 0 ? high + (atr * 0.5) : high[offset] + (atr[offset] * 0.5)

                if not na(y)
                    bool  isActive = (i == totalShifts)
                    color col      = isActive ? color.new(color.purple, 0) : color.new(color.gray, 40)
                    string txt     = isActive ? "SD" : "SD (prev)"

                    label lbl = label.new(
                         initBarIndex, y,
                         text      = txt,
                         style     = label.style_label_down,
                         color     = col,
                         textcolor = color.white,
                         size      = size.tiny
                    )
                    array.push(INIT_LABELS, lbl)

    INIT_LABEL_PLACED := true


// ───────────────────────── SCRIPT ATTACHMENT LABEL (one-time only)
var bool ATTACHMENT_LABEL_PLACED = false

if barstate.islast and not ATTACHMENT_LABEL_PLACED
    label.new(bar_index, high + (atr * 1.25), text="",
                 style=label.style_triangledown, size=size.tiny,
                 color=color.new(color.blue, 35),
                 textcolor=color.new(color.white, 0))
    ATTACHMENT_LABEL_PLACED := true

// ═══════════════════════════════════════════════════════════════════════════
// PIVOT DETECTION
// - Records pivot highs and lows and saves them in an array.
// - Used by the 2nd Extended line feature
// ═══════════════════════════════════════════════════════════════════════════

float pivotLowPrice = ta.pivotlow(low, pivotLookbackLeft, pivotLookbackRight)
float pivotHighPrice = ta.pivothigh(high, pivotLookbackLeft, pivotLookbackRight)


// Store pivot values in arrays for backfill lookup
// When a pivot is detected, we record it at its ACTUAL bar (pivotLookbackRight bars ago)
var float[] PIVOT_LOW_PRICES = array.new_float(0)
var int[] PIVOT_LOW_BARS = array.new_int(0)
var float[] PIVOT_HIGH_PRICES = array.new_float(0)
var int[] PIVOT_HIGH_BARS = array.new_int(0)

// Function to record pivots - wrapping in function to reduce main body size
recordPivot(float pivotPrice, bool isLow, int lookbackRight) =>
    if not na(pivotPrice)
        int pivotBar = bar_index - lookbackRight
        if isLow
            array.push(PIVOT_LOW_PRICES, pivotPrice)
            array.push(PIVOT_LOW_BARS, pivotBar)
            if array.size(PIVOT_LOW_BARS) > 500
                array.shift(PIVOT_LOW_PRICES)
                array.shift(PIVOT_LOW_BARS)
        else
            array.push(PIVOT_HIGH_PRICES, pivotPrice)
            array.push(PIVOT_HIGH_BARS, pivotBar)
            if array.size(PIVOT_HIGH_BARS) > 500
                array.shift(PIVOT_HIGH_PRICES)
                array.shift(PIVOT_HIGH_BARS)
    true

// Record pivots when detected
bool _pivotLowRecorded = recordPivot(pivotLowPrice, true, pivotLookbackRight)
bool _pivotHighRecorded = recordPivot(pivotHighPrice, false, pivotLookbackRight)

var bool INIT_DONE = false
var int INIT_BAR_INDEX = na

bool isInitBar = time >= INIT_TS and (bar_index == 0 or time[1] < INIT_TS)


// ═══════════════════════════════════════════════════════════════════════════
// STATE VARIABLES
// ═══════════════════════════════════════════════════════════════════════════

// ───────────────────────── internals
var line[]     longTermLines = array.new_line()
var linefill[] longTermFills = array.new_linefill()

// Storage for archived sets
var line[]     ARCH_MID   = array.new_line()
var line[]     ARCH_UP    = array.new_line()
var line[]     ARCH_LO    = array.new_line()
var linefill[] ARCH_FILLU = array.new_linefill()
var linefill[] ARCH_FILLL = array.new_linefill()
// Gray styling for archived channels
color ARCH_MID_COL  = color.new(color.green, 85)
color ARCH_BAND_COL = color.new(color.green, 85)
color ARCH_FILL_COL = color.new(color.green, 90)

// Track how many new channels have been created since the good channel was archived
// Good channel survives for 3 channel changes, deleted on the 4th
var int ARCH_CHANNEL_AGE = 0
const int ARCH_MAX_AGE = 3

// Storage for channel change labels (keep only 3 most recent)
var label[] CHANNEL_CHANGE_LABELS = array.new_label()
int MAX_CHANNEL_CHANGE_LABELS = 3

// Freeze state
var bool  LT_FROZEN       = false
var bool  HAS_EVER_FROZEN = false
var int   LT_PERIOD       = na
var float LT_SLOPE        = na
var float LT_INTERCEPT    = na
var float LT_STD          = na
var float LT_SCORE        = na
var float LT_DEVMULT      = na
var line  LT_LINE_MID     = na
var line  LT_LINE_UP      = na
var line  LT_LINE_LO      = na
var linefill LT_FILL_U    = na
var linefill LT_FILL_L    = na
var int   LT_START_BAR    = na

// ── Channel Width Status (calculated once at channel creation)
var float LT_CHANNEL_WIDTH_ATR = na
var string LT_CHANNEL_WIDTH_TXT = "…"
var color LT_CHANNEL_WIDTH_COLOR = color.gray

// ── Buy/Sell zone guide lines
var line LT_LINE_BUYZONE  = na
var line LT_LINE_SELLZONE = na

// ── UTB/DTB zone guide lines
var line LT_LINE_UTBZONE  = na
var line LT_LINE_DTBZONE  = na

// ── ER/ES min ATR distance visualization lines (orange dotted)
var line LT_LINE_ER_MINZONE = na
var line LT_LINE_ES_MINZONE = na

// ── SL zone guide lines (50% - for stop-loss, shown on chart)
var line LT_LINE_BUYSL    = na
var line LT_LINE_SELLSL   = na

// ── Overshoot Resistance (OR) / Overshoot Support (OS) Lines
// These track the maximum price excursion outside the channel bands during backfill
var line  LT_LINE_ER       = na 
var line  LT_LINE_ES       = na
var line  LT_LINE_ER_SELLZONE = na 
var line  LT_LINE_ER_DTBZONE  = na 
var line  LT_LINE_ES_BUYZONE  = na
var line  LT_LINE_ES_UTBZONE  = na

// ── Overshoot tracking values
var float LT_ER_OFFSET     = na
var float LT_ES_OFFSET     = na
var int   LT_ER_BAR        = na
var int   LT_ES_BAR        = na
var bool  LT_ER_CONFIRMED  = false
var bool  LT_ES_CONFIRMED  = false

// ── PENDING spike tracking (before pivot confirmation)
var float PENDING_ER_OFFSET = na
var float PENDING_ER_HIGH   = na
var int   PENDING_ER_BAR    = na
var float PENDING_ES_OFFSET = na
var float PENDING_ES_LOW    = na
var int   PENDING_ES_BAR    = na

// ── CANDIDATE tracking for extended line updates (requires more hits than current line)
// When a higher pivot is detected, it becomes a "candidate" and must accumulate more hits
// than the current line before replacing it. The pivot itself counts as hit #1.
var float CANDIDATE_ER_OFFSET = na
var int   CANDIDATE_ER_BAR = na
var int   CANDIDATE_ER_HIT_COUNT = 0 
var int   CANDIDATE_ER_LAST_HIT_BAR = na

var float CANDIDATE_ES_OFFSET = na
var int   CANDIDATE_ES_BAR = na
var int   CANDIDATE_ES_HIT_COUNT = 0
var int   CANDIDATE_ES_LAST_HIT_BAR = na

// ── Previous extended lines (kept as dashed/transparent for reference)
var line PREV_LT_LINE_ER = na
var line PREV_LT_LINE_ES = na

// ── 2nd Extended Lines (ER2/ES2) - Must be 1 ATR beyond the 1st extended line
// These are secondary extended lines that form when a SECOND pivot occurs at least 1 ATR
// beyond the first extended line. First hit must be the pivot itself.
var line  LT_LINE_ER2       = na
var line  LT_LINE_ES2       = na
var line  LT_LINE_ER2_SELLZONE = na
var line  LT_LINE_ER2_DTBZONE  = na
var line  LT_LINE_ES2_BUYZONE  = na
var line  LT_LINE_ES2_UTBZONE  = na
var float LT_ER2_OFFSET     = na
var float LT_ES2_OFFSET     = na
var int   LT_ER2_BAR        = na
var int   LT_ES2_BAR        = na
var bool  LT_ER2_CONFIRMED  = false
var bool  LT_ES2_CONFIRMED  = false

// ── ER2/ES2 Hit Counters (pivot = hit #1, need 2+ to confirm)
var int   ER2_HIT_COUNT      = 0
var int   ER2_LAST_HIT_BAR   = na
var int   ES2_HIT_COUNT      = 0
var int   ES2_LAST_HIT_BAR   = na

// ── ER2/ES2 Hit Labels
var label[] ER2_HIT_LABELS   = array.new_label()
