    int dx = bar_index - LT_START_BAR
    if dx > 0
        float y0 = line.get_price(LT_LINE_MID, LT_START_BAR)
        float y1 = line.get_price(LT_LINE_MID, bar_index)
        float runSlope = (y1 - y0) / dx
        LT_ANGLE_DEG := math.atan(-LT_SLOPE) * 180 / math.pi

if LT_FROZEN and not na(LT_SLOPE) and na(LT_ANGLE_NORM_DEG) and not na(atr) and atr > 0
    float slope_per_bar      = -LT_SLOPE
    // Normalize: rise over 100 bars expressed in ATR units
