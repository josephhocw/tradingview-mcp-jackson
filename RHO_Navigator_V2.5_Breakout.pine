        LT_FROZEN := true, GOOD_ALERTED := false, BREAK_LATCH := false, BREAK_DIR := 0, BREAK_EVENT_COUNT := 0, LAST_BREAK_BAR := na
        AFTER_BREAK_DIR := 0, FULL_OUTSIDE_COUNT := 0, HAS_EVER_FROZEN := true, LT_ANGLE_DEG := na, LT_ANGLE_NORM_DEG := na
        HAD_UTB := false, HAD_DTB := false, HAD_UTA := false, HAD_DTA := false, BUY_ARMED := false, BUY_ARMED_BAR := na, SELL_ARMED := false, SELL_ARMED_BAR := na
        PENDING_RETEST_SHORT := false, PENDING_RETEST_SHORT_BAR := na, PENDING_RETEST_SHORT_LVL := na, RETEST_TOUCHED_SHORT := false, PENDING_RETEST_LONG := false, PENDING_RETEST_LONG_BAR := na, PENDING_RETEST_LONG_LVL := na, RETEST_TOUCHED_LONG := false, PENDING_HOLD_COUNT := 0
