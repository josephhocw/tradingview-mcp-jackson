    float rise_per_100bars   = slope_per_bar * 100.0
    float rise_in_ATR_units  = rise_per_100bars / atr
    LT_ANGLE_NORM_DEG := math.atan(rise_in_ATR_units) * 180.0 / math.pi

// ───────────────────────── Moving Averages (NEW)
string vs50Txt   = na(ma9)  ? "…" : close > ma9  ? "Above" : close < ma9  ? "Below" : "At", string vs200Txt  = na(ma30) ? "…" : close > ma30 ? "Above" : close < ma30 ? "Below" : "At"
color  vs50Color  = na(ma9)  ? color.gray : close > ma9  ? color.lime : close < ma9  ? color.red : color.orange
color  vs200Color = na(ma30) ? color.gray : close > ma30 ? color.lime : close < ma30 ? color.red : color.orange

// 50-MA angle over the last 50 bars (deg)
int   ma9AngleLen = 50, float MA9_ANGLE_DEG = na
if bar_index >= ma9AngleLen and not na(ma9) and not na(ma9[ma9AngleLen - 1])
    float dy_ma    = ma9 - ma9[ma9AngleLen - 1]
    float dx_ma    = ma9AngleLen - 1
    float slope_ma = dy_ma / dx_ma
    MA9_ANGLE_DEG := math.atan(slope_ma) * 180 / math.pi

// ── 50-MA Strength state (updates every 20 bars)
var string ma9StrengthTxt = "…", var color  ma9StrengthColor = color.gray, var int lastStrengthUpdateBar = na

// ── 50-MA Strength update (sample every 20 bars)
if na(lastStrengthUpdateBar) or (bar_index - lastStrengthUpdateBar >= 15)
    bool haveMA     = not na(ma9)
    bool haveAngle  = not na(MA9_ANGLE_DEG)
    float upThresh  = haveMA ? (ma9 + 2.0 * atr) : na
    float dnThresh  = haveMA ? (ma9 - 2.0 * atr) : na
    bool strongUp   = haveMA and haveAngle and (close >= upThresh) and (MA9_ANGLE_DEG >= 50)
    bool strongDown = haveMA and haveAngle and (close <= dnThresh) and (MA9_ANGLE_DEG <= -50)

    if strongUp
        ma9StrengthTxt   := "Strong"
        ma9StrengthColor := color.lime
    else if strongDown
        ma9StrengthTxt   := "Strong"
        ma9StrengthColor := color.red
    else
        ma9StrengthTxt   := "Weak"
        ma9StrengthColor := color.silver

    lastStrengthUpdateBar := bar_index

// ── Calculate channel width status ONCE on channel change
if LT_CHANGED_THIS_BAR and not na(LT_STD) and not na(LT_DEVMULT) and not na(atr) and atr > 0
    float chWidth = 2.0 * LT_DEVMULT * LT_STD  // Full channel width (upper - lower)
    LT_CHANNEL_WIDTH_ATR := chWidth / atr
    if LT_CHANNEL_WIDTH_ATR < narrowChannelATR
        LT_CHANNEL_WIDTH_TXT := "Narrow"
        LT_CHANNEL_WIDTH_COLOR := color.orange
    else if LT_CHANNEL_WIDTH_ATR >= wideChannelATR
        LT_CHANNEL_WIDTH_TXT := "Wide"
        LT_CHANNEL_WIDTH_COLOR := color.aqua
    else
        LT_CHANNEL_WIDTH_TXT := "Normal"
        LT_CHANNEL_WIDTH_COLOR := color.lime

// ───────────────────────── Status table (top-right) — PROD MINIMAL
var table statusTbl = na

// Theme-aware colors (calculated once, used for all tables)
bool isDarkMode = (color.r(chart.bg_color) + color.g(chart.bg_color) + color.b(chart.bg_color)) / 3 < 128

// Border and text colors based on theme
color tblBorderCol   = isDarkMode ? color.new(color.white, 60) : color.new(color.black, 60)
color tblFrameCol    = isDarkMode ? color.new(color.white, 40) : color.new(color.black, 40)  // Stronger for outer frame
color tblTextCol     = isDarkMode ? color.new(color.white, 0)  : color.new(color.black, 0)
color tblTextDimCol  = isDarkMode ? color.new(color.white, 40) : color.new(color.black, 0)
color tblBgCol       = color.new(color.white, 100)  // Fully transparent background

// First column accent colors (subtle background for labels)
color tblAccentBg    = isDarkMode ? color.new(#2d4a6f, 30) : color.new(#e3f2fd, 0)  // Subtle blue tint
color tblHeaderBg    = isDarkMode ? color.new(#1a365d, 10) : color.new(#bbdefb, 0)  // Slightly stronger for header

if na(statusTbl)
    // 2 columns × 8 rows (added 1 row for channel width status)
    statusTbl := table.new(position.top_right, 2, 10, frame_width = 1, frame_color = tblFrameCol, border_width = 1, border_color = tblBorderCol)

// Direction text (kept)
string trendDirTxt  = LT_FROZEN ? (LT_ANGLE_NORM_DEG > angleThreshold ? "Uptrend" : (LT_ANGLE_NORM_DEG < -angleThreshold ? "Downtrend" : "Sideways")) : "…"
color  trendDirColor = LT_FROZEN ? (trendDirTxt == "Uptrend" ? color.lime : trendDirTxt == "Downtrend" ? color.red : color.orange) : color.gray

// Fire test alerts
float upPTest  = line.get_price(LT_LINE_UP,  bar_index)
float loPTest  = line.get_price(LT_LINE_LO,  bar_index)
float midPTest = line.get_price(LT_LINE_MID, bar_index)
float buyZonePTest = line.get_price(LT_LINE_BUYZONE, bar_index)
float sellZonePTest = line.get_price(LT_LINE_SELLZONE, bar_index)

float buyZoneGapTest  = na(buyZonePTest)  or na(loPTest) ? na : (buyZonePTest - loPTest)
float sellZoneGapTest = na(sellZonePTest) or na(upPTest) ? na : (upPTest - sellZonePTest)

// New: Trend status = Developing / Good
float scorePct   = LT_FROZEN and not na(LT_SCORE) ? LT_SCORE * 100.0 : na
bool  isGood     = LT_FROZEN and ( (not na(scorePct) and scorePct >= strongScorePct) or STRONG_PROMOTED )
string trendStatTxt = LT_FROZEN ? (isGood ? "Good" : "Developing") : "…"
color  trendStatCol = LT_FROZEN ? (isGood ? color.lime : color.orange) : color.gray

// @function Populates the status table with trend analysis data
populateStatusTable(table _tbl, int _periodMin, int _periodMax, int _periodStep, int _ltPeriod,
     string _trendTxt, color _trendCol, bool _ltFrozen, float _angleDeg, bool _isDarkMode,
     color _textCol, color _dimCol, color _bgCol, color _accentBg, color _headerBg) =>
    table.cell(_tbl, 0, 0, "RHO Navigator", text_color = _textCol, bgcolor = _headerBg, text_size = size.normal)
    table.cell(_tbl, 0, 1, "Minimum Period",  text_color = _textCol, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 1, str.tostring(_periodMin),  text_color = _dimCol, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 0, 2, "Maximum Period", text_color = _textCol, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 2, str.tostring(_periodMax), text_color = _dimCol, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 0, 3, "Step", text_color = _textCol, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 3, str.tostring(_periodStep),  text_color = _dimCol, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 0, 4, "Best Period",  text_color = _textCol, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 4, str.tostring(_ltPeriod), text_color = _isDarkMode ? color.lime : color.green, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 0, 5, "Trend Direction", text_color = _textCol, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 5, _trendTxt, text_color = _trendCol, bgcolor = _bgCol, text_size = size.normal)
    string angleTxt = _ltFrozen and not na(_angleDeg) ? str.tostring(_angleDeg, "#.#") + "°" : "…"
    table.cell(_tbl, 0, 6, "Channel Angle", text_color = _textCol, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 6, angleTxt, text_color = _trendCol, bgcolor = _bgCol, text_size = size.normal)
    table.merge_cells(_tbl, 0, 0, 1, 0)

if showTrendAnalysisPanel
    populateStatusTable(statusTbl, periodMin, periodMax, periodStep, LT_PERIOD,
         trendDirTxt, trendDirColor, LT_FROZEN, LT_ANGLE_NORM_DEG, isDarkMode,
         tblTextCol, tblTextDimCol, tblBgCol, tblAccentBg, tblHeaderBg)

// ───────────────────────── TP/SL + Previous Channel Levels table (bottom-right)
// 4 columns: [Label | Value] current  +  [Label | Value] prev channel
var table estTbl = na
if na(estTbl)
    estTbl := table.new(position.bottom_right, 4, 4, frame_width = 1, frame_color = tblFrameCol, border_width = 1, border_color = tblBorderCol)

bool isUp = (-LT_SLOPE) > 0
bool isDn = (-LT_SLOPE) < 0
string sideTxt = isUp ? "BUY" : isDn ? "SELL" : "—"

// @function Calculates estimated TP/SL levels based on position relative to channel
computeEstimatedTPSL(bool _frozen, float _mid, float _up, float _lo, float _close, bool _isUp, bool _isDn) =>
    float _tp1 = na, float _tp2 = na, float _sl1 = na, float _sl2 = na
    if _frozen and not na(_mid) and not na(_up) and not na(_lo)
        bool outsideUp = _close >= _up, bool outsideDown = _close <= _lo
        if outsideUp or outsideDown
            if _isUp
                if _close < _mid
                    _tp1 := _lo, _tp2 := _mid
                else
                    _sl1 := _up, _sl2 := _mid
            else if _isDn
                if _close > _mid
                    _tp1 := _up, _tp2 := _mid
                else
                    _sl1 := _lo, _sl2 := _mid
        else
            if _isUp
                if _close >= _mid
                    _tp1 := _up, _sl1 := _mid, _sl2 := _lo
                else
                    _tp1 := _mid, _tp2 := _up, _sl2 := _lo
            else if _isDn
                if _close <= _mid
                    _tp1 := _lo, _sl1 := _mid, _sl2 := _up
                else
                    _tp1 := _mid, _tp2 := _lo, _sl2 := _up
    [_tp1, _tp2, _sl1, _sl2]

float midPrice = line.get_price(LT_LINE_MID,  bar_index)
float upPrice  = line.get_price(LT_LINE_UP,   bar_index)
float lowPrice = line.get_price(LT_LINE_LO,   bar_index)

[tp1, tp2, sl1, sl2] = computeEstimatedTPSL(LT_FROZEN, midPrice, upPrice, lowPrice, close, isUp, isDn)


// Previous channel accent colors (warm tint to distinguish from current)
color prevHeaderBg = isDarkMode ? color.new(#4a3d1a, 10) : color.new(#fff8e1, 0)
color prevAccentBg = isDarkMode ? color.new(#4a3d1a, 30) : color.new(#fff8e1, 10)

// @function Populates the estimates table with TP/SL and previous channel levels
populateEstimatesTable(table _tbl, string _side, float _tp1, float _tp2, float _sl1, float _sl2,
     bool _prevValid, float _prevUpper, float _prevMid, float _prevLower, bool _isDark,
     color _textCol, color _dimCol, color _bgCol, color _accentBg, color _headerBg,
     color _prevHdrBg, color _prevAccBg) =>
    color tp1C = na(_tp1) ? _dimCol : _textCol, color tp2C = na(_tp2) ? _dimCol : _textCol
    color sl1C = na(_sl1) ? _dimCol : _textCol, color sl2C = na(_sl2) ? _dimCol : _textCol
    table.cell(_tbl, 0, 0, "Estimated TP/SL Levels", text_color = _textCol, bgcolor = _headerBg, text_size = size.normal)
    table.merge_cells(_tbl, 0, 0, 1, 0)
    table.cell(_tbl, 2, 0, "Prev Channel Levels", text_color = _textCol, bgcolor = _prevHdrBg, text_size = size.normal)
    table.merge_cells(_tbl, 2, 0, 3, 0)
    table.cell(_tbl, 0, 1, str.format("{0} TP1", _side), text_color = tp1C, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 1, fmt(_tp1), text_color = na(_tp1) ? _dimCol : _isDark ? color.lime : color.green, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 2, 1, "Resistance (R)", text_color = _textCol, bgcolor = _prevAccBg, text_size = size.normal)
    table.cell(_tbl, 3, 1, _prevValid ? fmt(_prevUpper) : "—", text_color = _prevValid ? (_isDark ? color.new(color.red, 20) : color.red) : _dimCol, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 0, 2, str.format("{0} TP2", _side), text_color = tp2C, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 2, fmt(_tp2), text_color = na(_tp2) ? _dimCol : _isDark ? color.lime : color.green, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 2, 2, "Middle (M)", text_color = _textCol, bgcolor = _prevAccBg, text_size = size.normal)
    table.cell(_tbl, 3, 2, _prevValid ? fmt(_prevMid) : "—", text_color = _prevValid ? _textCol : _dimCol, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 0, 3, str.format("{0} SL1", _side), text_color = sl1C, bgcolor = _accentBg, text_size = size.normal)
    table.cell(_tbl, 1, 3, fmt(_sl1), text_color = na(_sl1) ? _dimCol : color.red, bgcolor = _bgCol, text_size = size.normal)
    table.cell(_tbl, 2, 3, "Support (S)", text_color = _textCol, bgcolor = _prevAccBg, text_size = size.normal)
    table.cell(_tbl, 3, 3, _prevValid ? fmt(_prevLower) : "—", text_color = _prevValid ? (_isDark ? color.new(color.green, 20) : color.green) : _dimCol, bgcolor = _bgCol, text_size = size.normal)

if showEstimatesPanel
    populateEstimatesTable(estTbl, sideTxt, tp1, tp2, sl1, sl2,
         PREV_CH_VALID, PREV_CH_UPPER, PREV_CH_MID, PREV_CH_LOWER, isDarkMode,
         tblTextCol, tblTextDimCol, tblBgCol, tblAccentBg, tblHeaderBg, prevHeaderBg, prevAccentBg)

// ═══════════════════════════════════════════════════════════════════════════
// LABEL HITS AND SIGNALS
// ═══════════════════════════════════════════════════════════════════════════

// ───────────────────────── Event labels + ALERTS (added sendAlert calls)
float upP  = line.get_price(LT_LINE_UP,  bar_index)
float upPrev = line.get_price(LT_LINE_UP, bar_index - 1)
float loP  = line.get_price(LT_LINE_LO,  bar_index)
float loPrev = line.get_price(LT_LINE_LO, bar_index - 1)
float midP = line.get_price(LT_LINE_MID, bar_index)
float midPrev = line.get_price(LT_LINE_MID, bar_index - 1)
bool haveMid = not na(midP)

// R hit: current bar touches upper line AND previous bar wasn't touching
// Case 1: Coming from below - high crosses up through the line (high >= upP and high[1] < upPrev)
// Case 2: Coming from above - low drops down to touch the line (low <= upP and low[1] > upPrev)
bool rHitFromBelow = (high >= upP) and (high[1] < upPrev)
bool rHitFromAbove = (low <= upP) and (low[1] > upPrev)
bool priceCrossoverUpper = not na(upP) and not na(upPrev) and (rHitFromBelow or rHitFromAbove)

// S hit: current bar touches lower line AND previous bar wasn't touching
// Case 1: Coming from above - low crosses down through the line (low <= loP and low[1] > loPrev)
// Case 2: Coming from below - high rises up to touch the line (high >= loP and high[1] < loPrev)
bool sHitFromAbove = (low <= loP) and (low[1] > loPrev)
bool sHitFromBelow = (high >= loP) and (high[1] < loPrev)
bool priceCrossunderLower = not na(loP) and not na(loPrev) and (sHitFromAbove or sHitFromBelow)


bool midResTouchRaw = haveMid and not na(midPrev) and (high[1] < midPrev) and (high >= midP)
bool midSupTouchRaw = haveMid and not na(midPrev) and (low[1]  > midPrev) and (low <= midP)

// Back-inside check (strict: whole bar inside the channel)
// Back-inside check (strict: whole bar inside the outermost confirmed lines)
[insideUpper, insideLower] = getInsideBounds(upP, loP,
     LT_ER_CONFIRMED, LT_LINE_ER,
     LT_ES_CONFIRMED, LT_LINE_ES)
bool backInside = not na(insideUpper) and not na(insideLower) and low >= insideLower and high <= insideUpper
var int insideStreak = 0
insideStreak := backInside ? insideStreak + 1 : 0

// Re-arm when we've been back inside long enough
if insideStreak >= 5
    SELL_READY := true, BUY_READY  := true
    HAD_UTB := false, HAD_DTB := false
    PENDING_RETEST_SHORT := false, PENDING_RETEST_SHORT_BAR := na, PENDING_RETEST_SHORT_LVL := na, RETEST_TOUCHED_SHORT := false, PENDING_RETEST_LONG := false, PENDING_RETEST_LONG_BAR := na, PENDING_RETEST_LONG_LVL := na, RETEST_TOUCHED_LONG := false, PENDING_HOLD_COUNT := 0

bool allowEventLabels = LT_FROZEN and not na(LT_LINE_UP) and not na(LT_LINE_LO)

// ═══════════════════════════════════════════════════════════════════════════
// LIVE EXTENDED LINES TRACKING - Track pending spikes, confirm with 10-bar pivot, then create lines
// Lines are ONLY created/updated when spike is CONFIRMED (10-bar pivot detected)
// A pivot high requires 10 bars on the left AND 10 bars on the right to have lower highs
// ═══════════════════════════════════════════════════════════════════════════
if LT_FROZEN and not na(upP) and not na(loP)
    // Calculate channel width cap (distance between upper and lower bands)
    float channelWidthCap = LT_DEVMULT * LT_STD * 2.0
    
    // ═══ ER (Extended Resistance) TRACKING ═══
    // Step 1: Check if current bar creates a new potential ER spike (above upper band)
    if high > upP
        float currentER = math.min(high - upP, channelWidthCap)
        // If this is higher than the pending spike, update the pending spike
        if na(PENDING_ER_OFFSET) or currentER > PENDING_ER_OFFSET
            PENDING_ER_OFFSET := currentER, PENDING_ER_HIGH := high, PENDING_ER_BAR := bar_index
        
        // ═══ CHECK IF NEW HIGH IS A 2ND HIT OR A NEW HIGHER PIVOT FOR CANDIDATE_ER2 ═══
        // If we have a candidate ER2, check if this new high:
        // A) Touches the candidate level (within 1 ATR tolerance) → Count as 2nd hit, draw ER2
        // B) Significantly exceeds the candidate (by more than 1 ATR) → Update candidate to new level
        if not na(CANDIDATE_ER2_OFFSET) and not na(CANDIDATE_ER2_PIVOT_BAR) and not na(LT_LINE_UP)
            // Calculate the candidate ER2 price level
            float candidateER2Price = line.get_price(LT_LINE_UP, bar_index) + CANDIDATE_ER2_OFFSET
            float atrTolerance = atr * 0.5  // Use half ATR as tolerance for "touching" vs "new pivot"
            
            // Check that 2nd hit is AFTER the pivot bar (not same bar)
            bool gapOK = bar_index > CANDIDATE_ER2_PIVOT_BAR
            
            // If high touches the candidate level (within tolerance) and gap is satisfied → This is Hit #2!
            if high >= candidateER2Price and gapOK

                LT_ER2_OFFSET := CANDIDATE_ER2_OFFSET, LT_ER2_BAR := CANDIDATE_ER2_PIVOT_BAR, ER2_HIT_COUNT := 2, ER2_LAST_HIT_BAR := bar_index
                LT_ER2_CONFIRMED := true, SELL_ARMED_ER2 := true, SELL_ARMED_ER2_BAR := bar_index

                [newER2Line, newER2SellZone, newER2DtbZone, _, _] = 
                         utils.createExtendedLine(LT_ER2_OFFSET, true, LT_LINE_UP, LT_LINE_MID, LT_LINE_ER2, LT_LINE_ER2_SELLZONE, LT_LINE_ER2_DTBZONE,
                                                 showBuySellLineZoneExt, ER2_LINE_COL, SELL_ZONE_COL, BUY_ZONE_COL)
                LT_LINE_ER2 := newER2Line, LT_LINE_ER2_SELLZONE := newER2SellZone, LT_LINE_ER2_DTBZONE := newER2DtbZone
                
                if not na(LT_LINE_ER)
                    line.delete(LT_LINE_ER), LT_LINE_ER := na
                if not na(LT_LINE_ER_SELLZONE)
                    line.delete(LT_LINE_ER_SELLZONE), LT_LINE_ER_SELLZONE := na
                if not na(LT_LINE_ER_DTBZONE)
                    line.delete(LT_LINE_ER_DTBZONE), LT_LINE_ER_DTBZONE := na

                utils.deleteAllLabels(ER_HIT_LABELS)

                LT_ER_OFFSET := na, LT_ER_BAR := na, LT_ER_CONFIRMED := false, ER_HIT_COUNT := 0, ER_LAST_HIT_BAR := na, SELL_ARMED_ER := false, SELL_ARMED_ER_BAR := na
                SELL_ER_REF_PENDING := false, SELL_ER_REF_BAR := na, SELL_ER_REF_LOW := na, SELL_ER_REF_ZONE_PRICE := na, SELL_ER_REF_SL_PRICE := na
                
                // Label at pivot bar (hit #1)
                int pivotOff = bar_index - CANDIDATE_ER2_PIVOT_BAR
                if pivotOff >= 0 and pivotOff <= bar_index
                    label er2PivotLbl = label.new(CANDIDATE_ER2_PIVOT_BAR, line.get_price(LT_LINE_ER2, CANDIDATE_ER2_PIVOT_BAR), text="ER2", style=label.style_label_down, size=size.tiny, color=LBL_ER2_COL, textcolor=LBL_TEXT_COL)
                    array.push(ER2_HIT_LABELS, er2PivotLbl)
                // Label at current bar (hit #2)
                label er2Lbl = label.new(bar_index, line.get_price(LT_LINE_ER2, bar_index), text="ER2", style=label.style_label_down, size=size.tiny, color=LBL_ER2_COL, textcolor=LBL_TEXT_COL)
                array.push(ER2_HIT_LABELS, er2Lbl)
                sendAlert("Extended Resistance 2 Hit", candidateER2Price, trendDirTxt)
                
                // Clear candidate
                CANDIDATE_ER2_OFFSET := na, CANDIDATE_ER2_PIVOT_BAR := na, CANDIDATE_ER2_LAST_HIT_BAR := na
    
    // Step 2: If we have a pending spike and pivotLookbackRight bars have passed, check if it's a valid pivot
    if not na(PENDING_ER_OFFSET) and not na(PENDING_ER_HIGH) and not na(PENDING_ER_BAR)
        int barsElapsed = bar_index - PENDING_ER_BAR
        
        // Only check for confirmation after pivotLookbackRight bars have passed (V2.5: faster confirmation)
        if barsElapsed >= pivotLookbackRight
            // Get the high value at the pending bar
            int pendingOff = bar_index - PENDING_ER_BAR
            float pendingHighVal = na
            if pendingOff >= 0 and pendingOff <= bar_index
                pendingHighVal := high[pendingOff]
            
            if not na(pendingHighVal)
                // Check if all pivotLookbackRight bars on the right have lower highs
                bool rightSideValid = true
                for i = 1 to pivotLookbackRight
                    int rightBar = PENDING_ER_BAR + i
                    if rightBar <= bar_index
                        int rightOff = bar_index - rightBar
                        if rightOff >= 0 and rightOff <= bar_index
                            float rightHigh = high[rightOff]
                            if not na(rightHigh) and rightHigh > pendingHighVal
                                rightSideValid := false
                                break
                
                // Check pivotLookbackLeft bars on the left
                bool leftSideValid = true
                int startBar = nz(LT_START_BAR, 0)
                for i = 1 to pivotLookbackLeft
                    int leftBar = PENDING_ER_BAR - i
                    if leftBar >= startBar and leftBar >= 0
                        int leftOff = bar_index - leftBar
                        if leftOff >= 0 and leftOff <= bar_index
                            float leftHigh = high[leftOff]
                            if not na(leftHigh) and leftHigh > pendingHighVal
                                leftSideValid := false
                                break
                    else
                        leftSideValid := false
                        break
                
                bool isPivot = rightSideValid and leftSideValid
                log.info("isPivotER: right={0} left={1}", rightSideValid, leftSideValid)

                if isPivot
                    // Valid pivot - check if we should create/update OR line
                    bool isBiggerSpike = na(LT_ER_OFFSET) or PENDING_ER_OFFSET > LT_ER_OFFSET
                    bool notAtCap = na(LT_ER_OFFSET) or LT_ER_OFFSET < channelWidthCap

                    float erLineMinDistance = line.get_price(LT_LINE_ER_MINZONE, bar_index)    

                    bool isBeyondMinAtr = pendingHighVal > erLineMinDistance
                    log.info("ER GATES: bar={0} off={1} high={2} bigger={3} notCap={4} beyondMin={5} minAtrDist={6} existER={7} existER2={8}", PENDING_ER_BAR, PENDING_ER_OFFSET, pendingHighVal, isBiggerSpike, notAtCap, isBeyondMinAtr, erLineMinDistance, LT_ER_OFFSET, LT_ER2_OFFSET)

                    if isBiggerSpike and notAtCap and isBeyondMinAtr
                        // Check if this is the FIRST OR line (no existing line)
                        if na(LT_ER_OFFSET) and na(LT_ER2_OFFSET)

                            LT_ER_OFFSET := PENDING_ER_OFFSET, LT_ER_BAR := PENDING_ER_BAR, LT_ER_CONFIRMED := true
                            ER_HIT_COUNT := 1, ER_LAST_HIT_BAR := PENDING_ER_BAR, SELL_ARMED_ER := false, SELL_ARMED_ER_BAR := na
                            utils.deleteAllLabels(ER_HIT_LABELS)
                            
                            [newOR, newOS, newORSellZone, newORDtbZone, newOSBuyZone, newOSUtbZone] = 
                                 utils.createOvershootLines(LT_ER_OFFSET, LT_ES_OFFSET, LT_LINE_UP, LT_LINE_LO, LT_LINE_MID,
                                                             LT_LINE_ER, LT_LINE_ES, LT_LINE_ER_SELLZONE, LT_LINE_ER_DTBZONE,
                                                             LT_LINE_ES_BUYZONE, LT_LINE_ES_UTBZONE,
                                                             showBuySellLineZoneExt, OR_LINE_COL, OS_LINE_COL, SELL_ZONE_COL, BUY_ZONE_COL)

                                                                
                            LT_LINE_ER := newOR, LT_LINE_ES := newOS, LT_LINE_ER_SELLZONE := newORSellZone, LT_LINE_ER_DTBZONE := newORDtbZone, 
                            LT_LINE_ES_BUYZONE := newOSBuyZone, LT_LINE_ES_UTBZONE := newOSUtbZone
                            
                            // Create ER label at the pivot bar for hit #1
                            int pivotOffset = bar_index - PENDING_ER_BAR
                            if pivotOffset >= 0 and pivotOffset <= bar_index
                                // float erLabelPrice = high[pivotOffset]
                                float erLabelPrice = line.get_price(LT_LINE_ER, PENDING_ER_BAR)
                                label erHitLabel = label.new(PENDING_ER_BAR, erLabelPrice, text="ER", 
                                     style=label.style_label_down, size=size.tiny,
                                     color=LBL_ER_COL, textcolor=LBL_TEXT_COL)
                                array.push(ER_HIT_LABELS, erHitLabel)
                        else
                            // Existing OR line - check if new pivot qualifies for ER2
                            float atrNow = atr
                            float er1Level = upP + LT_ER_OFFSET
                            float er2MinLevel = er1Level + atrNow
                            float pendingLevel = upP + PENDING_ER_OFFSET
                            bool qualifiesForER2 = not na(atrNow) and pendingLevel >= er2MinLevel

                            if qualifiesForER2
                                bool isHigherThanCandidate = na(CANDIDATE_ER2_OFFSET) or PENDING_ER_OFFSET > CANDIDATE_ER2_OFFSET

                                if isHigherThanCandidate

                                    CANDIDATE_ER2_OFFSET := PENDING_ER_OFFSET
                                    CANDIDATE_ER2_PIVOT_BAR := PENDING_ER_BAR
                                    CANDIDATE_ER2_LAST_HIT_BAR := PENDING_ER_BAR

                    
                    // Clear pending after confirmation check (regardless of whether we updated)
                    PENDING_ER_OFFSET := na, PENDING_ER_HIGH := na, PENDING_ER_BAR := na
                    
                else if not rightSideValid
                    float newPendingOffset = na
                    float newPendingHigh = na
                    int newPendingBar = na
                    
                    for i = 0 to pivotLookbackRight
                        int checkBar = bar_index - i
                        if checkBar >= nz(LT_START_BAR, 0)
                            float checkHigh = high[i]
                            float upAtCheck = line.get_price(LT_LINE_UP, checkBar)
                            if not na(checkHigh) and not na(upAtCheck) and checkHigh > upAtCheck
                                float checkOvershoot = math.min(checkHigh - upAtCheck, channelWidthCap)
                                if na(newPendingOffset) or checkOvershoot > newPendingOffset
                                    newPendingOffset := checkOvershoot
                                    newPendingHigh := checkHigh
                                    newPendingBar := checkBar
                    
                    PENDING_ER_OFFSET := newPendingOffset, PENDING_ER_HIGH := newPendingHigh, PENDING_ER_BAR := newPendingBar
    
    // ═══ ES (Extended Support) TRACKING ═══
    // Step 1: Check if current bar creates a new potential ES spike (below lower band)
    if low < loP
        float currentES = math.min(loP - low, channelWidthCap)
        if na(PENDING_ES_OFFSET) or currentES > PENDING_ES_OFFSET
            PENDING_ES_OFFSET := currentES
            PENDING_ES_LOW := low
            PENDING_ES_BAR := bar_index
        
        // ═══ CHECK IF NEW LOW IS A 2ND HIT FOR CANDIDATE_ES2 ═══
        // If we have a candidate ES2, check if this new low touches the candidate level
        if not na(CANDIDATE_ES2_OFFSET) and not na(CANDIDATE_ES2_PIVOT_BAR) and not na(LT_LINE_LO)
            // Calculate the candidate ES2 price level
            float candidateES2Price = line.get_price(LT_LINE_LO, bar_index) - CANDIDATE_ES2_OFFSET
            
            // Check that 2nd hit is AFTER the pivot bar (not same bar)
            bool gapOK = bar_index > CANDIDATE_ES2_PIVOT_BAR
            
            // If low touches the candidate level (at or below) and gap is satisfied → This is Hit #2!
            if low <= candidateES2Price and gapOK
                LT_ES2_OFFSET := CANDIDATE_ES2_OFFSET
                LT_ES2_BAR := CANDIDATE_ES2_PIVOT_BAR
                ES2_HIT_COUNT := 2
                ES2_LAST_HIT_BAR := bar_index
                LT_ES2_CONFIRMED := true
                BUY_ARMED_ES2 := true
                BUY_ARMED_ES2_BAR := bar_index
                [newES2Line, _, _, newES2BuyZone, newES2UtbZone] = 
                         utils.createExtendedLine(LT_ES2_OFFSET, false, LT_LINE_LO, LT_LINE_MID, LT_LINE_ES2, LT_LINE_ES2_BUYZONE, LT_LINE_ES2_UTBZONE,
                                                 showBuySellLineZoneExt, ES2_LINE_COL, BUY_ZONE_COL, SELL_ZONE_COL)
                LT_LINE_ES2 := newES2Line, LT_LINE_ES2_BUYZONE := newES2BuyZone, LT_LINE_ES2_UTBZONE := newES2UtbZone

                if not na(LT_LINE_ES)
                    line.delete(LT_LINE_ES), LT_LINE_ES := na
                if not na(LT_LINE_ES_BUYZONE)
                    line.delete(LT_LINE_ES_BUYZONE), LT_LINE_ES_BUYZONE := na
                if not na(LT_LINE_ES_UTBZONE)
                    line.delete(LT_LINE_ES_UTBZONE), LT_LINE_ES_UTBZONE := na

                utils.deleteAllLabels(ES_HIT_LABELS)
                LT_ES_OFFSET := na, LT_ES_BAR := na, LT_ES_CONFIRMED := false, ES_HIT_COUNT := 0, ES_LAST_HIT_BAR := na, BUY_ARMED_ES := false
                BUY_ARMED_ES_BAR := na, BUY_ES_REF_PENDING := false, BUY_ES_REF_BAR := na, BUY_ES_REF_HIGH := na, BUY_ES_REF_ZONE_PRICE := na, BUY_ES_REF_SL_PRICE := na
                
                // Label at pivot bar (hit #1)
                int pivotOffES = bar_index - CANDIDATE_ES2_PIVOT_BAR
                if pivotOffES >= 0 and pivotOffES <= bar_index
                    label es2PivotLbl = label.new(CANDIDATE_ES2_PIVOT_BAR, line.get_price(LT_LINE_ES2, CANDIDATE_ES2_PIVOT_BAR), text="ES2", style=label.style_label_up, size=size.tiny, color=LBL_ES2_COL, textcolor=LBL_TEXT_COL)
                    array.push(ES2_HIT_LABELS, es2PivotLbl)
                // Label at current bar (hit #2)
                label es2Lbl = label.new(bar_index, line.get_price(LT_LINE_ES2, bar_index), text="ES2", style=label.style_label_up, size=size.tiny, color=LBL_ES2_COL, textcolor=LBL_TEXT_COL)
                array.push(ES2_HIT_LABELS, es2Lbl)
                sendAlert("Extended Support 2 Hit", candidateES2Price, trendDirTxt)
                
                // Clear candidate
                CANDIDATE_ES2_OFFSET := na, CANDIDATE_ES2_PIVOT_BAR := na, CANDIDATE_ES2_LAST_HIT_BAR := na
    
    // Step 2: If we have a pending spike and pivotLookbackRight bars have passed, check if it's a valid pivot
    if not na(PENDING_ES_OFFSET) and not na(PENDING_ES_LOW) and not na(PENDING_ES_BAR)
        int barsElapsed = bar_index - PENDING_ES_BAR
        
        // Only check for confirmation after pivotLookbackRight bars have passed (V2.5: faster confirmation)
        if barsElapsed >= pivotLookbackRight
            // Get the low value at the pending bar
            int pendingOff = bar_index - PENDING_ES_BAR
            float pendingLowVal = na
            if pendingOff >= 0 and pendingOff <= bar_index
                pendingLowVal := low[pendingOff]
            
            if not na(pendingLowVal)
                // Check if all pivotLookbackRight bars on the right have higher lows
                bool rightSideValid = true
                for i = 1 to pivotLookbackRight
                    int rightBar = PENDING_ES_BAR + i
                    if rightBar <= bar_index
                        int rightOff = bar_index - rightBar
                        if rightOff >= 0 and rightOff <= bar_index
                            float rightLow = low[rightOff]
                            if not na(rightLow) and rightLow < pendingLowVal
                                rightSideValid := false
                                break
                
                // Check pivotLookbackLeft bars on the left
                bool leftSideValid = true
                int startBar = nz(LT_START_BAR, 0)
                for i = 1 to pivotLookbackLeft
                    int leftBar = PENDING_ES_BAR - i
                    if leftBar >= startBar and leftBar >= 0
                        int leftOff = bar_index - leftBar
                        if leftOff >= 0 and leftOff <= bar_index
                            float leftLow = low[leftOff]
                            if not na(leftLow) and leftLow < pendingLowVal
                                leftSideValid := false
                                break
                    else
                        leftSideValid := false
                        break
                
                bool isPivot = rightSideValid and leftSideValid
                
                if isPivot
                    // Valid pivot - check if we should create/update OS line
                    bool isBiggerSpike = na(LT_ES_OFFSET) or PENDING_ES_OFFSET > LT_ES_OFFSET
                    bool notAtCap = na(LT_ES_OFFSET) or LT_ES_OFFSET < channelWidthCap

                    float extLineMinDistance = line.get_price(LT_LINE_ES_MINZONE, bar_index)    

                    bool isBeyondMinAtr = pendingLowVal < extLineMinDistance
                    log.info("ES GATES: bar={0} off={1} low={2} bigger={3} notCap={4} beyondMin={5} minAtrDist={6} existES={7} existES2={8}", PENDING_ES_BAR, PENDING_ES_OFFSET, pendingLowVal, isBiggerSpike, notAtCap, isBeyondMinAtr, extLineMinDistance, LT_ES_OFFSET, LT_ES2_OFFSET)
                    
                    if isBiggerSpike and notAtCap and isBeyondMinAtr
                        // Check if this is the FIRST OS line (no existing line)
                        if na(LT_ES_OFFSET) and na(LT_ES2_OFFSET)

                            LT_ES_OFFSET := PENDING_ES_OFFSET
                            LT_ES_BAR := PENDING_ES_BAR
                            LT_ES_CONFIRMED := true
                            ES_HIT_COUNT := 1
                            ES_LAST_HIT_BAR := PENDING_ES_BAR
                            BUY_ARMED_ES := false
                            BUY_ARMED_ES_BAR := na

                            utils.deleteAllLabels(ES_HIT_LABELS)
                            
                            [newOR2, newOS2, newORSellZone2, newORDtbZone2, newOSBuyZone2, newOSUtbZone2] = 
                                     utils.createOvershootLines(LT_ER_OFFSET, LT_ES_OFFSET, LT_LINE_UP, LT_LINE_LO, LT_LINE_MID,
                                     LT_LINE_ER, LT_LINE_ES, LT_LINE_ER_SELLZONE, LT_LINE_ER_DTBZONE,
                                     LT_LINE_ES_BUYZONE, LT_LINE_ES_UTBZONE,
                                     showBuySellLineZoneExt, OR_LINE_COL, OS_LINE_COL, SELL_ZONE_COL, BUY_ZONE_COL)

                    
                            LT_LINE_ER := newOR2, LT_LINE_ES := newOS2, LT_LINE_ER_SELLZONE := newORSellZone2
                            LT_LINE_ER_DTBZONE := newORDtbZone2, LT_LINE_ES_BUYZONE := newOSBuyZone2, LT_LINE_ES_UTBZONE := newOSUtbZone2
                            
                            // Create ES label at the pivot bar for hit #1
                            int pivotOffsetOS = bar_index - PENDING_ES_BAR
                            if pivotOffsetOS >= 0 and pivotOffsetOS <= bar_index
                                // float esLabelPrice = low[pivotOffsetOS]
                                float esLabelPrice = line.get_price(LT_LINE_ES, PENDING_ES_BAR)
                                label esHitLabel = label.new(PENDING_ES_BAR, esLabelPrice, text="ES", 
                                     style=label.style_label_up, size=size.tiny,
                                     color=LBL_ES_COL, textcolor=LBL_TEXT_COL)
                                array.push(ES_HIT_LABELS, esHitLabel)
                        else
                            float atrNow = atr
                            float es1Level = loP - LT_ES_OFFSET
                            float es2MaxLevel = es1Level - atrNow
                            float pendingLevel = loP - PENDING_ES_OFFSET
                            bool qualifiesForES2 = not na(atrNow) and pendingLevel <= es2MaxLevel

                            if qualifiesForES2
                                bool isLowerThanCandidate = na(CANDIDATE_ES2_OFFSET) or PENDING_ES_OFFSET < CANDIDATE_ES2_OFFSET

                                if isLowerThanCandidate
                                    CANDIDATE_ES2_OFFSET := PENDING_ES_OFFSET
                                    CANDIDATE_ES2_PIVOT_BAR := PENDING_ES_BAR
                                    CANDIDATE_ES2_LAST_HIT_BAR := PENDING_ES_BAR
                    
                    // Clear pending after confirmation check (regardless of whether we updated)
                    PENDING_ES_OFFSET := na, PENDING_ES_LOW := na, PENDING_ES_BAR := na
                    
                else if not rightSideValid
                    float newPendingOffset = na
                    float newPendingLow = na
                    int newPendingBar = na
                    
                    for i = 0 to pivotLookbackRight
                        int checkBar = bar_index - i
                        if checkBar >= nz(LT_START_BAR, 0)
                            float checkLow = low[i]
                            float loAtCheck = line.get_price(LT_LINE_LO, checkBar)
                            if not na(checkLow) and not na(loAtCheck) and checkLow < loAtCheck
                                float checkOvershoot = math.min(loAtCheck - checkLow, channelWidthCap)
                                if na(newPendingOffset) or checkOvershoot > newPendingOffset
                                    newPendingOffset := checkOvershoot
                                    newPendingLow := checkLow
                                    newPendingBar := checkBar
                    
                    PENDING_ES_OFFSET := newPendingOffset, PENDING_ES_LOW := newPendingLow, PENDING_ES_BAR := newPendingBar

// ═══════════════════════════════════════════════════════════════════════════
// ER/ES TOUCH DETECTION AND TRADE ARMING
// When price touches ER line → arm for SELL (like R touch) - requires 2 hits from below
// When price touches ES line → arm for BUY (like S touch) - requires 2 hits from above
// NOTE: Lines only exist after spike is CONFIRMED (pivot detected during line creation)
// NOTE: Hits must have at least 60 bars gap to count. Counter resets on line update/channel change.
// ═══════════════════════════════════════════════════════════════════════════
if LT_FROZEN and not LT_CHANGED_THIS_BAR
    // Get current upper and lower band prices for candidate level calculations
    float upP_touch = not na(LT_LINE_UP) ? line.get_price(LT_LINE_UP, bar_index) : na
    float loP_touch = not na(LT_LINE_LO) ? line.get_price(LT_LINE_LO, bar_index) : na
    
    // ═══ CANDIDATE ER TOUCH DETECTION AND PROMOTION ═══
    // Check if price touches the candidate ER level (if one exists)
    if not na(CANDIDATE_ER_OFFSET) and not na(upP_touch)
        float candidateERPrice = upP_touch + CANDIDATE_ER_OFFSET
        float candidateERPricePrev = na
        if not na(LT_LINE_UP)
            float upP_prev = line.get_price(LT_LINE_UP, bar_index - 1)
            candidateERPricePrev := upP_prev + CANDIDATE_ER_OFFSET
        
        // Detect touch from below (price coming up to hit candidate ER level)
        bool candidateERHit = not na(candidateERPrice) and not na(candidateERPricePrev) and (high >= candidateERPrice) and (high[1] < candidateERPricePrev)
        
        if candidateERHit
            // Check gap requirement
            bool validCandidateERHit = na(CANDIDATE_ER_LAST_HIT_BAR) or (bar_index - CANDIDATE_ER_LAST_HIT_BAR >= ER_HIT_GAP_BARS)
            if validCandidateERHit
                CANDIDATE_ER_HIT_COUNT := CANDIDATE_ER_HIT_COUNT + 1
                CANDIDATE_ER_LAST_HIT_BAR := bar_index

                // Check if candidate now has MORE hits than current ER line
                if CANDIDATE_ER_HIT_COUNT > ER_HIT_COUNT

                    // Convert current ER line to previous (dashed, transparent)
                    if not na(LT_LINE_ER)
                        if not na(PREV_LT_LINE_ER)
                            line.delete(PREV_LT_LINE_ER)
                        
                    // Update to new ER level
                    LT_ER_OFFSET := CANDIDATE_ER_OFFSET, LT_ER_BAR := CANDIDATE_ER_BAR, LT_ER_CONFIRMED := true
                    ER_HIT_COUNT := CANDIDATE_ER_HIT_COUNT, ER_LAST_HIT_BAR := CANDIDATE_ER_LAST_HIT_BAR
                    
                    // Clear candidate state
                    CANDIDATE_ER_OFFSET := na, CANDIDATE_ER_BAR := na, CANDIDATE_ER_HIT_COUNT := 0, CANDIDATE_ER_LAST_HIT_BAR := na

                    utils.deleteAllLabels(ER_HIT_LABELS)
                    SELL_ARMED_ER := false, SELL_ARMED_ER_BAR := na
                    
                    // Redraw OR line at new level
                    [newOR, newOS, newORSellZone, newORDtbZone, newOSBuyZone, newOSUtbZone] = 
                                     utils.createOvershootLines(LT_ER_OFFSET, LT_ES_OFFSET, LT_LINE_UP, LT_LINE_LO, LT_LINE_MID,
                                     LT_LINE_ER, LT_LINE_ES, LT_LINE_ER_SELLZONE, LT_LINE_ER_DTBZONE,
                                     LT_LINE_ES_BUYZONE, LT_LINE_ES_UTBZONE,
                                     showBuySellLineZoneExt, OR_LINE_COL, OS_LINE_COL, SELL_ZONE_COL, BUY_ZONE_COL)

                    LT_LINE_ER := newOR, LT_LINE_ES := newOS, LT_LINE_ER_SELLZONE := newORSellZone, LT_LINE_ER_DTBZONE := newORDtbZone
                    LT_LINE_ES_BUYZONE := newOSBuyZone, LT_LINE_ES_UTBZONE := newOSUtbZone
                    
                    // Create ER label at the original pivot bar (hit #1)
                    int promotedPivotOffset = bar_index - LT_ER_BAR
                    if promotedPivotOffset >= 0 and promotedPivotOffset <= bar_index and not na(newOR)
                        float erLabelPrice = line.get_price(newOR, LT_ER_BAR)
                        if not na(erLabelPrice)
                            label erHitLabel = label.new(LT_ER_BAR, erLabelPrice, text="ER", 
                                 style=label.style_label_down, size=size.tiny,
                                 color=LBL_ER_COL, textcolor=LBL_TEXT_COL)
                            array.push(ER_HIT_LABELS, erHitLabel)

    // ═══ CANDIDATE ES TOUCH DETECTION AND PROMOTION ═══
    // Check if price touches the candidate ES level (if one exists)
    if not na(CANDIDATE_ES_OFFSET) and not na(loP_touch)
        float candidateESPrice = loP_touch - CANDIDATE_ES_OFFSET
        float candidateESPricePrev = na
        if not na(LT_LINE_LO)
            float loP_prev = line.get_price(LT_LINE_LO, bar_index - 1)
            candidateESPricePrev := loP_prev - CANDIDATE_ES_OFFSET
        
        // Detect touch from above (price coming down to hit candidate ES level)
        bool candidateESHit = not na(candidateESPrice) and not na(candidateESPricePrev) and (low <= candidateESPrice) and (low[1] > candidateESPricePrev)
        
        if candidateESHit
            // Check gap requirement
            bool validCandidateESHit = na(CANDIDATE_ES_LAST_HIT_BAR) or (bar_index - CANDIDATE_ES_LAST_HIT_BAR >= ES_HIT_GAP_BARS)
            if validCandidateESHit
                CANDIDATE_ES_HIT_COUNT := CANDIDATE_ES_HIT_COUNT + 1
                CANDIDATE_ES_LAST_HIT_BAR := bar_index

                // Check if candidate now has MORE hits than current ES line
                if CANDIDATE_ES_HIT_COUNT > ES_HIT_COUNT

                    // Convert current ES line to previous (dashed, transparent)
                    if not na(LT_LINE_ES)
                        if not na(PREV_LT_LINE_ES)
                            line.delete(PREV_LT_LINE_ES)

                    LT_ES_OFFSET := CANDIDATE_ES_OFFSET, LT_ES_BAR := CANDIDATE_ES_BAR, LT_ES_CONFIRMED := true
                    ES_HIT_COUNT := CANDIDATE_ES_HIT_COUNT, ES_LAST_HIT_BAR := CANDIDATE_ES_LAST_HIT_BAR

                    CANDIDATE_ES_OFFSET := na, CANDIDATE_ES_BAR := na, CANDIDATE_ES_HIT_COUNT := 0, CANDIDATE_ES_LAST_HIT_BAR := na
                    utils.deleteAllLabels(ES_HIT_LABELS)
                    BUY_ARMED_ES := false, BUY_ARMED_ES_BAR := na
                    
                    [newOR2, newOS2, newORSellZone2, newORDtbZone2, newOSBuyZone2, newOSUtbZone2] = 
                                     utils.createOvershootLines(LT_ER_OFFSET, LT_ES_OFFSET, LT_LINE_UP, LT_LINE_LO, LT_LINE_MID,
                                     LT_LINE_ER, LT_LINE_ES, LT_LINE_ER_SELLZONE, LT_LINE_ER_DTBZONE,
                                     LT_LINE_ES_BUYZONE, LT_LINE_ES_UTBZONE,
                                     showBuySellLineZoneExt, OR_LINE_COL, OS_LINE_COL, SELL_ZONE_COL, BUY_ZONE_COL)
                
                    LT_LINE_ER := newOR2, LT_LINE_ES := newOS2, LT_LINE_ER_SELLZONE := newORSellZone2
                    LT_LINE_ER_DTBZONE := newORDtbZone2, LT_LINE_ES_BUYZONE := newOSBuyZone2, LT_LINE_ES_UTBZONE := newOSUtbZone2
                    
                    // Create ES label at the original pivot bar (hit #1)
                    int promotedPivotOffsetOS = bar_index - LT_ES_BAR
                    if promotedPivotOffsetOS >= 0 and promotedPivotOffsetOS <= bar_index and not na(newOS2)
                        float esLabelPrice = line.get_price(newOS2, LT_ES_BAR)
                        if not na(esLabelPrice)
                            label esHitLabel = label.new(LT_ES_BAR, esLabelPrice, text="ES", 
                                 style=label.style_label_up, size=size.tiny,
                                 color=LBL_ES_COL, textcolor=LBL_TEXT_COL)
                            array.push(ES_HIT_LABELS, esHitLabel)
                    
    // Get ER line price at current bar
    float erPrice = not na(LT_LINE_ER) ? line.get_price(LT_LINE_ER, bar_index) : na
    float erPricePrev = not na(LT_LINE_ER) ? line.get_price(LT_LINE_ER, bar_index - 1) : na
    
    // Get ES line price at current bar
    float esPrice = not na(LT_LINE_ES) ? line.get_price(LT_LINE_ES, bar_index) : na
    float esPricePrev = not na(LT_LINE_ES) ? line.get_price(LT_LINE_ES, bar_index - 1) : na
    
    // ═══ TOUCH DETECTION ═══
    // ER touch detection - only count hits from BELOW (price coming up to hit ER)
    bool erHitFromBelow = not na(erPrice) and not na(erPricePrev) and (high >= erPrice) and (high[1] < erPricePrev)
    bool ER_TOUCH_THIS_BAR = LT_ER_CONFIRMED and erHitFromBelow
    
    // ES touch detection - only count hits from ABOVE (price coming down to hit ES)
    bool esHitFromAbove = not na(esPrice) and not na(esPricePrev) and (low <= esPrice) and (low[1] > esPricePrev)
    bool ES_TOUCH_THIS_BAR = LT_ES_CONFIRMED and esHitFromAbove
    
    // ═══ ER HIT COUNTING (2-hit requirement with variable gap) ═══
    // Gap requirement: 15 bars between 1st and 2nd hit, 25 bars for 3rd+ hits (same as R/S gap)
    if ER_TOUCH_THIS_BAR
        // Determine the required gap based on current hit count
        int requiredERGap = ER_HIT_COUNT >= 2 ? ER_HIT_GAP_BARS_AFTER_2ND : ER_HIT_GAP_BARS
        bool validERHit = na(ER_LAST_HIT_BAR) or (bar_index - ER_LAST_HIT_BAR >= requiredERGap)
        if validERHit
            ER_HIT_COUNT := ER_HIT_COUNT + 1
            ER_LAST_HIT_BAR := bar_index

            // Create hit count label at OR line
            label erHitLabel = label.new(bar_index, erPrice, text="ER", 
                 style=label.style_label_down, size=size.tiny,
                 color=LBL_ER_COL, textcolor=LBL_TEXT_COL)
            array.push(ER_HIT_LABELS, erHitLabel)
            
            // ARM for SELL after 2nd+ valid hit (with cooldown check)
            if ER_HIT_COUNT >= 2 and utils.shouldPlace(SELL_ARMED_ER_BAR, MIN_LABEL_GAP_BARS, bar_index)
                SELL_ARMED_ER := true
                SELL_ARMED_ER_BAR := bar_index
                sendAlert("Extended Resistance Hit", erPrice, trendDirTxt)
    
    // ═══ ES HIT COUNTING (2-hit requirement with variable gap) ═══
    // Gap requirement: 15 bars between 1st and 2nd hit, 25 bars for 3rd+ hits (same as R/S gap)
    if ES_TOUCH_THIS_BAR
        // Determine the required gap based on current hit count
        int requiredESGap = ES_HIT_COUNT >= 2 ? ES_HIT_GAP_BARS_AFTER_2ND : ES_HIT_GAP_BARS
        bool validESHit = na(ES_LAST_HIT_BAR) or (bar_index - ES_LAST_HIT_BAR >= requiredESGap)
        if validESHit
            ES_HIT_COUNT := ES_HIT_COUNT + 1
            ES_LAST_HIT_BAR := bar_index

            // Create hit count label at OS line
            label esHitLabel = label.new(bar_index, esPrice, text="ES", 
                 style=label.style_label_up, size=size.tiny,
                 color=LBL_ES_COL, textcolor=LBL_TEXT_COL)
            array.push(ES_HIT_LABELS, esHitLabel)
            
            // ARM for BUY after 2nd+ valid hit (with cooldown check)
            if ES_HIT_COUNT >= 2 and utils.shouldPlace(BUY_ARMED_ES_BAR, MIN_LABEL_GAP_BARS, bar_index)
                BUY_ARMED_ES := true
                BUY_ARMED_ES_BAR := bar_index
                // log.info("OS Hit #" + str.tostring(ES_HIT_COUNT) + " - BUY Armed at bar " + str.tostring(bar_index))
                sendAlert("Extended Support Hit", esPrice, trendDirTxt)
    
    // Timeout the OR arm after ER_ARM_TIMEOUT bars
    if SELL_ARMED_ER and not na(SELL_ARMED_ER_BAR) and bar_index - SELL_ARMED_ER_BAR >= ER_ARM_TIMEOUT
        SELL_ARMED_ER := false
        SELL_ARMED_ER_BAR := na
    
    // Timeout the OS arm after ES_ARM_TIMEOUT bars
    if BUY_ARMED_ES and not na(BUY_ARMED_ES_BAR) and bar_index - BUY_ARMED_ES_BAR >= ES_ARM_TIMEOUT
        BUY_ARMED_ES := false
        BUY_ARMED_ES_BAR := na

    // ═══ ER2/ES2 (2nd Extended Lines) TOUCH DETECTION AND ARMING ═══
    float er2Price = not na(LT_LINE_ER2) ? line.get_price(LT_LINE_ER2, bar_index) : na
    float er2PricePrev = not na(LT_LINE_ER2) ? line.get_price(LT_LINE_ER2, bar_index - 1) : na
    float es2Price = not na(LT_LINE_ES2) ? line.get_price(LT_LINE_ES2, bar_index) : na
    float es2PricePrev = not na(LT_LINE_ES2) ? line.get_price(LT_LINE_ES2, bar_index - 1) : na
    
    // ═══ CANDIDATE ER2/ES2 PROMOTION (2nd hit creates line) ═══
    if not na(CANDIDATE_ER2_OFFSET) and na(LT_ER2_OFFSET) and not na(LT_LINE_UP)
        float cER2Price = line.get_price(LT_LINE_UP, bar_index) + CANDIDATE_ER2_OFFSET
        float cER2PricePrev = line.get_price(LT_LINE_UP, bar_index - 1) + CANDIDATE_ER2_OFFSET
        bool cER2Hit = (high >= cER2Price) and (high[1] < cER2PricePrev)

        if cER2Hit and (bar_index > CANDIDATE_ER2_PIVOT_BAR)

            // 2nd hit - create line now
            LT_ER2_OFFSET := CANDIDATE_ER2_OFFSET
            LT_ER2_BAR := CANDIDATE_ER2_PIVOT_BAR
            ER2_HIT_COUNT := 2
            ER2_LAST_HIT_BAR := bar_index
            LT_ER2_CONFIRMED := true
            SELL_ARMED_ER2 := true
            SELL_ARMED_ER2_BAR := bar_index
            [newER2Line2, newER2SellZone2, newER2DtbZone2, _, _] = 
                         utils.createExtendedLine(LT_ER2_OFFSET, true, LT_LINE_UP, LT_LINE_MID, LT_LINE_ER2, LT_LINE_ER2_SELLZONE,
                                                 LT_LINE_ER2_DTBZONE, showBuySellLineZoneExt, ER2_LINE_COL, SELL_ZONE_COL, BUY_ZONE_COL)

            LT_LINE_ER2 := newER2Line2, LT_LINE_ER2_SELLZONE := newER2SellZone2, LT_LINE_ER2_DTBZONE := newER2DtbZone2
            
            // ═══ REMOVE ORIGINAL ER (OR) LINE AND MAKE ER2 THE ACTIVE EXTENDED RESISTANCE ═══
            // Delete the original OR line and its associated zones
            if not na(LT_LINE_ER)
                line.delete(LT_LINE_ER), LT_LINE_ER := na
            if not na(LT_LINE_ER_SELLZONE)
                line.delete(LT_LINE_ER_SELLZONE), LT_LINE_ER_SELLZONE := na
            if not na(LT_LINE_ER_DTBZONE)
                line.delete(LT_LINE_ER_DTBZONE), LT_LINE_ER_DTBZONE := na

            utils.deleteAllLabels(ER_HIT_LABELS)

            LT_ER_OFFSET := na, LT_ER_BAR := na, LT_ER_CONFIRMED := false, ER_HIT_COUNT := 0
            ER_LAST_HIT_BAR := na, SELL_ARMED_ER := false, SELL_ARMED_ER_BAR := na
            SELL_ER_REF_PENDING := false, SELL_ER_REF_BAR := na, SELL_ER_REF_LOW := na
            SELL_ER_REF_ZONE_PRICE := na, SELL_ER_REF_SL_PRICE := na
            
            // Label at pivot bar (hit #1)
            int pivotOff = bar_index - CANDIDATE_ER2_PIVOT_BAR
            if pivotOff >= 0 and pivotOff <= bar_index
                label er2PivotLbl = label.new(CANDIDATE_ER2_PIVOT_BAR, high[pivotOff], text="ER2", style=label.style_label_down, size=size.tiny, color=LBL_ER2_COL, textcolor=LBL_TEXT_COL)
                array.push(ER2_HIT_LABELS, er2PivotLbl)
            // Label at current bar (hit #2)
            label er2Lbl = label.new(bar_index, cER2Price, text="ER2", style=label.style_label_down, size=size.tiny, color=LBL_ER2_COL, textcolor=LBL_TEXT_COL)
            array.push(ER2_HIT_LABELS, er2Lbl)
            sendAlert("Extended Resistance 2 Hit", cER2Price, trendDirTxt)

            CANDIDATE_ER2_OFFSET := na, CANDIDATE_ER2_PIVOT_BAR := na, CANDIDATE_ER2_LAST_HIT_BAR := na
    
    if not na(CANDIDATE_ES2_OFFSET) and na(LT_ES2_OFFSET) and not na(LT_LINE_LO)
        float cES2Price = line.get_price(LT_LINE_LO, bar_index) - CANDIDATE_ES2_OFFSET
        float cES2PricePrev = line.get_price(LT_LINE_LO, bar_index - 1) - CANDIDATE_ES2_OFFSET
        bool cES2Hit = (low <= cES2Price) and (low[1] > cES2PricePrev)

        if cES2Hit and (bar_index > CANDIDATE_ES2_PIVOT_BAR)

            // 2nd hit - create line now
            LT_ES2_OFFSET := CANDIDATE_ES2_OFFSET
            LT_ES2_BAR := CANDIDATE_ES2_PIVOT_BAR
            ES2_HIT_COUNT := 2
            ES2_LAST_HIT_BAR := bar_index
            LT_ES2_CONFIRMED := true
            BUY_ARMED_ES2 := true
            BUY_ARMED_ES2_BAR := bar_index
            [newES2Line2, _, _, newES2BuyZone2, newES2UtbZone2] = 
                         utils.createExtendedLine(LT_ES2_OFFSET, false, LT_LINE_LO, LT_LINE_MID, LT_LINE_ES2, LT_LINE_ES2_BUYZONE, LT_LINE_ES2_UTBZONE,
                                                 showBuySellLineZoneExt,  ES2_LINE_COL, BUY_ZONE_COL, SELL_ZONE_COL)

            LT_LINE_ES2 := newES2Line2, LT_LINE_ES2_BUYZONE := newES2BuyZone2, LT_LINE_ES2_UTBZONE := newES2UtbZone2
            
            // ═══ REMOVE ORIGINAL ES (ES) LINE AND MAKE ES2 THE ACTIVE EXTENDED SUPPORT ═══
            // Delete the original ES line and its associated zones
            if not na(LT_LINE_ES)
                line.delete(LT_LINE_ES), LT_LINE_ES := na
            if not na(LT_LINE_ES_BUYZONE)
                line.delete(LT_LINE_ES_BUYZONE), LT_LINE_ES_BUYZONE := na
            if not na(LT_LINE_ES_UTBZONE)
                line.delete(LT_LINE_ES_UTBZONE), LT_LINE_ES_UTBZONE := na

            utils.deleteAllLabels(ES_HIT_LABELS)

            LT_ES_OFFSET := na, LT_ES_BAR := na, LT_ES_CONFIRMED := false, ES_HIT_COUNT := 0, ES_LAST_HIT_BAR := na, 
            BUY_ARMED_ES := false, BUY_ARMED_ES_BAR := na, BUY_ES_REF_PENDING := false, BUY_ES_REF_BAR := na
            BUY_ES_REF_HIGH := na, BUY_ES_REF_ZONE_PRICE := na, BUY_ES_REF_SL_PRICE := na
            
            // Label at pivot bar (hit #1)
            int pivotOffES = bar_index - CANDIDATE_ES2_PIVOT_BAR
            if pivotOffES >= 0 and pivotOffES <= bar_index
                label es2PivotLbl = label.new(CANDIDATE_ES2_PIVOT_BAR, low[pivotOffES], text="ES2", style=label.style_label_up, size=size.tiny, color=LBL_ES2_COL, textcolor=LBL_TEXT_COL)
                array.push(ES2_HIT_LABELS, es2PivotLbl)
            // Label at current bar (hit #2)
            label es2Lbl = label.new(bar_index, cES2Price, text="ES2", style=label.style_label_up, size=size.tiny, color=LBL_ES2_COL, textcolor=LBL_TEXT_COL)
            array.push(ES2_HIT_LABELS, es2Lbl)
            sendAlert("Extended Support 2 Hit", cES2Price, trendDirTxt)

            CANDIDATE_ES2_OFFSET := na, CANDIDATE_ES2_PIVOT_BAR := na, CANDIDATE_ES2_LAST_HIT_BAR := na

    // ER2 touch detection - only count hits from BELOW (price coming up to hit ER2)
    bool er2HitFromBelow = not na(er2Price) and not na(er2PricePrev) and (high >= er2Price) and (high[1] < er2PricePrev)
    bool ER2_TOUCH_THIS_BAR = not na(LT_ER2_OFFSET) and er2HitFromBelow
    
    // ES2 touch detection - only count hits from ABOVE (price coming down to hit ES2)
    bool es2HitFromAbove = not na(es2Price) and not na(es2PricePrev) and (low <= es2Price) and (low[1] > es2PricePrev)
    bool ES2_TOUCH_THIS_BAR = not na(LT_ES2_OFFSET) and es2HitFromAbove
    
    [newER2HitCount, newER2LastHitBar, er2NowConfirmed, er2ShouldArm, er2NewArmedBar, er2ShouldLabel, er2LabelPrice] = 
         utils.processExtendedHitCount(ER2_TOUCH_THIS_BAR, ER2_HIT_COUNT, ER2_LAST_HIT_BAR, ER_HIT_GAP_BARS, 
                                     ER_HIT_GAP_BARS_AFTER_2ND, SELL_ARMED_ER2_BAR, MIN_LABEL_GAP_BARS, 
                                     er2Price, bar_index)

    ER2_HIT_COUNT := newER2HitCount
    ER2_LAST_HIT_BAR := newER2LastHitBar
    if er2NowConfirmed
        LT_ER2_CONFIRMED := true
    if er2ShouldArm
        SELL_ARMED_ER2 := true
        SELL_ARMED_ER2_BAR := er2NewArmedBar
        sendAlert("Extended Resistance 2 Hit", er2Price, trendDirTxt)
    if er2ShouldLabel
        label er2HitLabel = label.new(bar_index, er2LabelPrice, text="ER2", style=label.style_label_down, size=size.tiny, color=LBL_ER2_COL, textcolor=LBL_TEXT_COL)
        array.push(ER2_HIT_LABELS, er2HitLabel)

    [newES2HitCount, newES2LastHitBar, es2NowConfirmed, es2ShouldArm, es2NewArmedBar, es2ShouldLabel, es2LabelPrice] = 
         utils.processExtendedHitCount(ES2_TOUCH_THIS_BAR, ES2_HIT_COUNT, ES2_LAST_HIT_BAR, ES_HIT_GAP_BARS, 
                                     ES_HIT_GAP_BARS_AFTER_2ND, BUY_ARMED_ES2_BAR, MIN_LABEL_GAP_BARS, 
                                     es2Price, bar_index)

    ES2_HIT_COUNT := newES2HitCount
    ES2_LAST_HIT_BAR := newES2LastHitBar
    if es2NowConfirmed
        LT_ES2_CONFIRMED := true
    if es2ShouldArm
        BUY_ARMED_ES2 := true
        BUY_ARMED_ES2_BAR := es2NewArmedBar
        sendAlert("Extended Support 2 Hit", es2Price, trendDirTxt)
    if es2ShouldLabel
        label es2HitLabel = label.new(bar_index, es2LabelPrice, text="ES2", style=label.style_label_up, size=size.tiny, color=LBL_ES2_COL, textcolor=LBL_TEXT_COL)
        array.push(ES2_HIT_LABELS, es2HitLabel)
    
    // Timeout the ER2/ES2 arm via function
    [newSellArmedER2Timeout, newSellArmedER2BarTimeout] = utils.checkArmTimeout(SELL_ARMED_ER2, SELL_ARMED_ER2_BAR, ER_ARM_TIMEOUT, bar_index)
    SELL_ARMED_ER2 := newSellArmedER2Timeout, SELL_ARMED_ER2_BAR := newSellArmedER2BarTimeout
    
    [newBuyArmedES2Timeout, newBuyArmedES2BarTimeout] = utils.checkArmTimeout(BUY_ARMED_ES2, BUY_ARMED_ES2_BAR, ES_ARM_TIMEOUT, bar_index)
    BUY_ARMED_ES2 := newBuyArmedES2Timeout, BUY_ARMED_ES2_BAR := newBuyArmedES2BarTimeout

// ═══════════════════════════════════════════════════════════════════════════
// CHANNEL WIDTH & TREND DIRECTION DETECTION
// ═══════════════════════════════════════════════════════════════════════════
// Channel width classification uses STORED values from channel creation (LT_CHANNEL_WIDTH_ATR)
// This ensures consistent classification throughout the channel's lifetime
bool isNarrowChannel = not na(LT_CHANNEL_WIDTH_ATR) and LT_CHANNEL_WIDTH_ATR < narrowChannelATR
bool isWideChannel = not na(LT_CHANNEL_WIDTH_ATR) and LT_CHANNEL_WIDTH_ATR >= wideChannelATR
bool isNormalChannel = na(LT_CHANNEL_WIDTH_ATR) or (LT_CHANNEL_WIDTH_ATR >= narrowChannelATR and LT_CHANNEL_WIDTH_ATR < wideChannelATR)

// Trend direction from normalized angle (user-configurable threshold)
// LT_ANGLE_NORM_DEG > threshold = Uptrend, < -threshold = Downtrend, otherwise Sideways
bool isUptrend = LT_FROZEN and not na(LT_ANGLE_NORM_DEG) and LT_ANGLE_NORM_DEG > angleThreshold
bool isDowntrend = LT_FROZEN and not na(LT_ANGLE_NORM_DEG) and LT_ANGLE_NORM_DEG < -angleThreshold
bool isSideways = LT_FROZEN and not na(LT_ANGLE_NORM_DEG) and math.abs(LT_ANGLE_NORM_DEG) <= angleThreshold

// Update table with channel width status (row 5, below Best Period) - uses STORED values from channel creation
if showTrendAnalysisPanel
    string widthDetail = na(LT_CHANNEL_WIDTH_ATR) ? "" : " (" + str.tostring(LT_CHANNEL_WIDTH_ATR, "#.#") + "x)"
    table.cell(statusTbl, 0, 7, "Channel Width", text_color = tblTextCol, bgcolor = tblAccentBg, text_size = size.normal)
    table.cell(statusTbl, 1, 7, LT_CHANNEL_WIDTH_TXT + widthDetail, text_color = LT_CHANNEL_WIDTH_COLOR, bgcolor = tblBgCol, text_size = size.normal)

    // TB-SL status row
    string tbSlStatusTxt = "Off"
    color  tbSlStatusCol = tblTextDimCol
    if tbAlsoAsSL
        bool _inLong  = strategy.position_size > 0
        bool _inShort = strategy.position_size < 0
        bool _tbArmedNow = (_inLong and TB_ARMED_LONG) or (_inShort and TB_ARMED_SHORT)
        if _tbArmedNow and not na(STRAT_ENTRY_PRICE) and not na(atr)
            float _adverseDist = _inLong ? (STRAT_ENTRY_PRICE - close) : (close - STRAT_ENTRY_PRICE)
            bool _atrMet = _adverseDist >= tbSlMinAtrDist * atr
            if _atrMet
                tbSlStatusTxt := "Armed"
                tbSlStatusCol := color.red
            else
                tbSlStatusTxt := "Pending (" + str.tostring(_adverseDist / atr, "#.#") + "/" + str.tostring(tbSlMinAtrDist, "#.#") + " ATR)"
                tbSlStatusCol := color.orange
        else if _inLong or _inShort
            tbSlStatusTxt := "Watching"
            tbSlStatusCol := isDarkMode ? color.new(color.white, 40) : color.gray
        else
            tbSlStatusTxt := "No Position"
            tbSlStatusCol := tblTextDimCol
    table.cell(statusTbl, 0, 8, "TB-SL", text_color = tblTextCol, bgcolor = tblAccentBg, text_size = size.normal)
    table.cell(statusTbl, 1, 8, tbSlStatusTxt, text_color = tbSlStatusCol, bgcolor = tblBgCol, text_size = size.normal)

// NEW: detect S/R hit intent on this bar (used to suppress opposite/duplicate zone triggers)
bool R_HIT_THIS_BAR = not LT_CHANGED_THIS_BAR and not na(upP) and priceCrossoverUpper and utils.shouldPlace(LAST_UPPER_LABELBAR, MIN_LABEL_GAP_BARS, bar_index)
bool S_HIT_THIS_BAR = not LT_CHANGED_THIS_BAR and not na(loP) and priceCrossunderLower and utils.shouldPlace(LAST_LOWER_LABELBAR, MIN_LABEL_GAP_BARS, bar_index)


if allowEventLabels and ((time >= INIT_TS) or barstate.isrealtime)
    // 35% buy-zone line at this bar (derived from lines or fallback to mid/low)
    float buyZoneNow = line.get_price(LT_LINE_BUYZONE, bar_index)
    float buySLZoneNow = line.get_price(LT_LINE_BUYSL, bar_index)

    // Process direct buy trigger
    [updatedBuyArmed, updatedBuyArmedBar, buyTriggered, buyTrigPrice, buySlPrice] = 
             utils.processDirectBuyTrigger(BUY_ARMED, BUY_ARMED_BAR, buyZoneNow, buySLZoneNow, midP, 
                                         high, high, S_HIT_THIS_BAR, bar_index)

    BUY_ARMED := updatedBuyArmed, BUY_ARMED_BAR := updatedBuyArmedBar

    if buyTriggered
        if SKIP_NORMAL_BUY
            SKIP_NORMAL_BUY := false
        else
            label lbBuy = label.new(bar_index, buyTrigPrice, text="B", style=label.style_label_right, size=size.tiny, color=LBL_BUY_COL, textcolor=LBL_TEXT_COL)
            array.push(BUY_SIG_LABELS, lbBuy)
            // log.info("'Entered Buy Zone' Alert Sent!")
            sendSignalAlert('Channel Buy Signal', buyTrigPrice, midP, upP, buySlPrice)

    // 35% sell-zone line at this bar (derived from lines or fallback to mid/up)
    float sellZoneNow = line.get_price(LT_LINE_SELLZONE, bar_index)
    float sellSLZoneNow = line.get_price(LT_LINE_SELLSL, bar_index)

    // Process direct sell trigger
    [updatedSellArmed, updatedSellArmedBar, sellTriggered, sellTrigPrice, sellSlPrice] = 
                 utils.processDirectSellTrigger(SELL_ARMED, SELL_ARMED_BAR, sellZoneNow, sellSLZoneNow, midP, 
                                         low, low, R_HIT_THIS_BAR, bar_index)

    SELL_ARMED := updatedSellArmed
    SELL_ARMED_BAR := updatedSellArmedBar

    if sellTriggered
        if SKIP_NORMAL_SELL
            SKIP_NORMAL_SELL := false
        else
            label lbSell = label.new(bar_index, sellTrigPrice, text="S", style=label.style_label_right, size=size.tiny, color=LBL_SELL_COL, textcolor=LBL_TEXT_COL)
            array.push(SELL_SIG_LABELS, lbSell)
            sendSignalAlert('Channel Sell Signal', sellTrigPrice, midP, loP, sellSlPrice)

    // LOGIC FOR UTB ZONE (SELL)
    // Use ES1 - 1 ATR when ES1 is confirmed (even if ES2 exists), otherwise default UTB zone
    float utbZoneDefault = line.get_price(LT_LINE_UTBZONE, bar_index)
    
    float es1PriceUTB = (LT_ES_CONFIRMED and not na(LT_LINE_ES)) ? line.get_price(LT_LINE_ES, bar_index) : na
    float utbZoneNow = not na(es1PriceUTB) ? (es1PriceUTB - 1.0 * atr) : utbZoneDefault

    // Track whether UTB/DTB was triggered from extended lines (for SL reference)
    bool utbFromExtended = not na(es1PriceUTB)
    bool dtbFromExtended = false  // set below

    // UTB trigger requires: zone exists, UTB event detected, sell ready, price touches UTB zone, AND angle confirms uptrend
    bool utbPriceTouched = not na(utbZoneNow) and (low <= utbZoneNow)
    bool SELL_TRIG_UTB = not na(utbZoneNow) and UTB_THIS_BAR and SELL_READY and utbPriceTouched and isUptrend

    if SELL_TRIG_UTB and (utbFromExtended ? low <= utbZoneDefault : true)
        label lbU = label.new(bar_index, utbZoneNow, text = "▼\nUTB",
                     style = label.style_label_up, textcolor = LBL_TEXT_COL, size = size.tiny, color = LBL_UTB_COL)
        float sl = buyZoneNow
        sendSignalAlert('Uptrend Breakdown (SELL ZONE)', utbZoneNow, na, na, sl, true)
        array.push(SELL_SIG_LABELS, lbU)
        SELL_READY := false

    // LOGIC FOR DTB ZONE (BUY)
    // Use ER1 + 1 ATR when ER1 is confirmed (even if ER2 exists), otherwise default DTB zone
    float dtbZoneDefault = line.get_price(LT_LINE_DTBZONE, bar_index)

    float er1PriceDTB = (LT_ER_CONFIRMED and not na(LT_LINE_ER)) ? line.get_price(LT_LINE_ER, bar_index) : na
    float dtbZoneNow = not na(er1PriceDTB) ? (er1PriceDTB + 1.0 * atr) : dtbZoneDefault
    dtbFromExtended := not na(er1PriceDTB)

    // DTB trigger requires: zone exists, DTB event detected, buy ready, price touches DTB zone, AND angle confirms downtrend
    bool dtbPriceTouched = not na(dtbZoneNow) and (high >= dtbZoneNow)
    bool BUY_TRIG_DTB = not na(dtbZoneNow) and DTB_THIS_BAR and BUY_READY and dtbPriceTouched and isDowntrend

    if BUY_TRIG_DTB and (dtbFromExtended ? high >= dtbZoneDefault : true)
        label lbD = label.new(bar_index, dtbZoneNow, text = "▲\nDTB",
                     style = label.style_label_down, textcolor = LBL_TEXT_COL, size = size.tiny, color = LBL_DTB_COL)

        float sl = sellZoneNow
        sendSignalAlert('Downtrend Breakout (BUY ZONE)', dtbZoneNow, na, na, sl, true)
        array.push(BUY_SIG_LABELS, lbD)
        BUY_READY := false

    // ── STRATEGY: 3-Mode Entry Confirmation (Immediate / Close Confirmation / Retest)
    bool _maFilterShort = enableMABasedFilter ? (close < maTP) : true
    bool _maFilterLong  = enableMABasedFilter ? (close > maTP) : true
    bool _maCrossOkShort = (maCrossBarLimit == 0) or (barsSinceMaCrossunder <= maCrossBarLimit)
    bool _maAlignOkShort = not requireMaAlignment or (ma9 < ma30)
    bool _maDistOkShort  = (maMinAtrDist == 0.0) or (not na(atr) and not na(ma9) and not na(ma30) and math.abs(ma9 - ma30) >= maMinAtrDist * atr)
    bool _maCrossOkLong  = (maCrossBarLimit == 0) or (barsSinceMaCrossover <= maCrossBarLimit)
    bool _maAlignOkLong  = not requireMaAlignment or (ma9 > ma30)
    bool _maDistOkLong   = _maDistOkShort  // same distance check applies to both directions

    [pShort, pShortBar, pShortLvl, rtShort, pLong, pLongBar, pLongLvl, rtLong, holdCnt, retestAction] = 
         processEntryConfirmation(
         PENDING_RETEST_SHORT, PENDING_RETEST_SHORT_BAR, PENDING_RETEST_SHORT_LVL, RETEST_TOUCHED_SHORT,
         PENDING_RETEST_LONG, PENDING_RETEST_LONG_BAR, PENDING_RETEST_LONG_LVL, RETEST_TOUCHED_LONG,
         PENDING_HOLD_COUNT,
         SELL_TRIG_UTB, BUY_TRIG_DTB,
         loP, upP,
         utbZoneNow, dtbZoneNow,
         entryConfirmMode, retestMaxBars, retestZonePct, holdBarsConfirm,
         _maCrossOkShort and _maFilterShort, _maAlignOkShort and _maDistOkShort,
         _maCrossOkLong and _maFilterLong, _maAlignOkLong and _maDistOkLong,
         strategy.position_size, atr, high, low, close, open)

    // Apply state updates from entry confirmation function
    PENDING_RETEST_SHORT := pShort, PENDING_RETEST_SHORT_BAR := pShortBar
    PENDING_RETEST_SHORT_LVL := pShortLvl, RETEST_TOUCHED_SHORT := rtShort
    PENDING_RETEST_LONG := pLong, PENDING_RETEST_LONG_BAR := pLongBar
    PENDING_RETEST_LONG_LVL := pLongLvl, RETEST_TOUCHED_LONG := rtLong
    PENDING_HOLD_COUNT := holdCnt

    if retestAction == +1  // Short entry
        strategy.entry("Short", strategy.short)
        STRAT_ENTRY_UPPER := line.get_price(LT_LINE_UP, bar_index), STRAT_ENTRY_LOWER := line.get_price(LT_LINE_LO, bar_index)
        STRAT_ENTRY_MID := line.get_price(LT_LINE_MID, bar_index), STRAT_ENTRY_DIR := +1, STRAT_ENTRY_PRICE := close
        [_sl1, _fe1, _er1] = computeBreakoutSL(+1, utbFromExtended, es1PriceUTB, STRAT_ENTRY_LOWER, slAtrBuffer, atr)
        STRAT_FIXED_SL := _sl1, STRAT_SL_FROM_EXT := _fe1, STRAT_EXT_SL_REF := _er1
        STRAT_CH_CHANGED := false, STRAT_CONSEC_ABOVE_MA := 0, STRAT_CONSEC_BELOW_MA := 0
        STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false

    if retestAction == -1  // Long entry
        strategy.entry("Long", strategy.long)
        STRAT_ENTRY_UPPER := line.get_price(LT_LINE_UP, bar_index), STRAT_ENTRY_LOWER := line.get_price(LT_LINE_LO, bar_index)
        STRAT_ENTRY_MID := line.get_price(LT_LINE_MID, bar_index), STRAT_ENTRY_DIR := -1, STRAT_ENTRY_PRICE := close
        [_sl2, _fe2, _er2] = computeBreakoutSL(-1, dtbFromExtended, er1PriceDTB, STRAT_ENTRY_UPPER, slAtrBuffer, atr)
        STRAT_FIXED_SL := _sl2, STRAT_SL_FROM_EXT := _fe2, STRAT_EXT_SL_REF := _er2
        STRAT_CH_CHANGED := false, STRAT_CONSEC_ABOVE_MA := 0, STRAT_CONSEC_BELOW_MA := 0
        STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false

    // ═══════════════════════════════════════════════════════════════════════════
    // ER SELL ZONE TRIGGER - Process via function (same as ER2)
    // ═══════════════════════════════════════════════════════════════════════════

    // Get current prices
    float erSellZoneNow = not na(LT_LINE_ER_SELLZONE) ? line.get_price(LT_LINE_ER_SELLZONE, bar_index) : na
    float erDtbZoneNow = not na(LT_LINE_ER_DTBZONE) ? line.get_price(LT_LINE_ER_DTBZONE, bar_index) : na
    float erLineNow = not na(LT_LINE_ER) ? line.get_price(LT_LINE_ER, bar_index) : na

    [newSellArmedOR, newSellArmedORBar, newSellORRefPending, newSellORRefBar, newSellORRefLow, newSellORRefZonePrice, newSellORRefSlPrice, erSignalTriggered, orTriggerPrice, orSlPrice] = 
         utils.processER2SellTrigger(SELL_ARMED_ER, SELL_ARMED_ER_BAR, SELL_ER_REF_PENDING, SELL_ER_REF_BAR, SELL_ER_REF_LOW, SELL_ER_REF_ZONE_PRICE, SELL_ER_REF_SL_PRICE,
                             erLineNow, erSellZoneNow, erDtbZoneNow, low, close, LT_CHANGED_THIS_BAR, SELL_ER_REF_TIMEOUT, bar_index)

    SELL_ARMED_ER := newSellArmedOR, SELL_ARMED_ER_BAR := newSellArmedORBar, SELL_ER_REF_PENDING := newSellORRefPending, SELL_ER_REF_BAR := newSellORRefBar
    SELL_ER_REF_LOW := newSellORRefLow, SELL_ER_REF_ZONE_PRICE := newSellORRefZonePrice, SELL_ER_REF_SL_PRICE := newSellORRefSlPrice
    
    if erSignalTriggered
        label lbORSell = label.new(bar_index, orTriggerPrice, text="ES", style=label.style_label_right, size=size.tiny, color=LBL_SELL_COL, textcolor=LBL_TEXT_COL)
        array.push(SELL_SIG_LABELS, lbORSell)
        sendSignalAlert('Extended Channel Sell Signal', orTriggerPrice, upP, midP, orSlPrice)
        SKIP_NORMAL_SELL := true

    // ═══════════════════════════════════════════════════════════════════════════
    // ES BUY ZONE TRIGGER - Process via function (same as ES2)
    // ═══════════════════════════════════════════════════════════════════════════
    // Get current prices
    float esBuyZoneNow = not na(LT_LINE_ES_BUYZONE) ? line.get_price(LT_LINE_ES_BUYZONE, bar_index) : na
    float esUtbZoneNow = not na(LT_LINE_ES_UTBZONE) ? line.get_price(LT_LINE_ES_UTBZONE, bar_index) : na
    float esLineNow = not na(LT_LINE_ES) ? line.get_price(LT_LINE_ES, bar_index) : na

    [newBuyArmedOS, newBuyArmedOSBar, newBuyOSRefPending, newBuyOSRefBar, newBuyOSRefHigh, newBuyOSRefZonePrice, newBuyOSRefSlPrice, esSignalTriggered, osTriggerPrice, osSlPrice] = 
         utils.processES2BuyTrigger(BUY_ARMED_ES, BUY_ARMED_ES_BAR, BUY_ES_REF_PENDING, BUY_ES_REF_BAR, BUY_ES_REF_HIGH, BUY_ES_REF_ZONE_PRICE, BUY_ES_REF_SL_PRICE,
                              esLineNow, esBuyZoneNow, esUtbZoneNow, high, close, LT_CHANGED_THIS_BAR, BUY_ES_REF_TIMEOUT, bar_index)
    
    BUY_ARMED_ES := newBuyArmedOS, BUY_ARMED_ES_BAR := newBuyArmedOSBar, BUY_ES_REF_PENDING := newBuyOSRefPending, BUY_ES_REF_BAR := newBuyOSRefBar
    BUY_ES_REF_HIGH := newBuyOSRefHigh, BUY_ES_REF_ZONE_PRICE := newBuyOSRefZonePrice, BUY_ES_REF_SL_PRICE := newBuyOSRefSlPrice
    
    if esSignalTriggered
        label lbOSBuy = label.new(bar_index, osTriggerPrice, text="EB", style=label.style_label_right, size=size.tiny, color=LBL_BUY_COL, textcolor=LBL_TEXT_COL)
        array.push(BUY_SIG_LABELS, lbOSBuy)
        sendSignalAlert('Extended Channel Buy Signal', osTriggerPrice, loP, midP, osSlPrice)
        SKIP_NORMAL_BUY := true

    // ═══════════════════════════════════════════════════════════════════════════
    // ER2 SELL ZONE TRIGGER - Process via function
    // ═══════════════════════════════════════════════════════════════════════════
    // Get current prices
    float er2SellZoneNow = not na(LT_LINE_ER2_SELLZONE) ? line.get_price(LT_LINE_ER2_SELLZONE, bar_index) : na
    float er2DtbZoneNow = not na(LT_LINE_ER2_DTBZONE) ? line.get_price(LT_LINE_ER2_DTBZONE, bar_index) : na
    float er2LineNow = not na(LT_LINE_ER2) ? line.get_price(LT_LINE_ER2, bar_index) : na

    [newSellArmedER2, newSellArmedER2Bar, newSellER2RefPending, newSellER2RefBar, newSellER2RefLow, newSellER2RefZonePrice, newSellER2RefSlPrice, er2SignalTriggered, er2TriggerPrice, er2SlPrice] = 
         utils.processER2SellTrigger(SELL_ARMED_ER2, SELL_ARMED_ER2_BAR, SELL_ER2_REF_PENDING, SELL_ER2_REF_BAR, SELL_ER2_REF_LOW, SELL_ER2_REF_ZONE_PRICE, SELL_ER2_REF_SL_PRICE,
                             er2LineNow, er2SellZoneNow, er2DtbZoneNow, low, close, LT_CHANGED_THIS_BAR, SELL_ER2_REF_TIMEOUT, bar_index)


    SELL_ARMED_ER2 := newSellArmedER2, SELL_ARMED_ER2_BAR := newSellArmedER2Bar, SELL_ER2_REF_PENDING := newSellER2RefPending, SELL_ER2_REF_BAR := newSellER2RefBar
    SELL_ER2_REF_LOW := newSellER2RefLow, SELL_ER2_REF_ZONE_PRICE := newSellER2RefZonePrice, SELL_ER2_REF_SL_PRICE := newSellER2RefSlPrice
    
    if er2SignalTriggered
        label lbER2Sell = label.new(bar_index, er2TriggerPrice, text="ES2", style=label.style_label_right, size=size.tiny, color=LBL_SELL_COL, textcolor=LBL_TEXT_COL)
        array.push(SELL_SIG_LABELS, lbER2Sell)
        sendSignalAlert('Extended Channel 2 Sell Signal', er2TriggerPrice, upP, midP, er2SlPrice)

    // ═══════════════════════════════════════════════════════════════════════════
    // ES2 BUY ZONE TRIGGER - Process via function
    // ═══════════════════════════════════════════════════════════════════════════
    // Get current prices
    float es2BuyZoneNow = not na(LT_LINE_ES2_BUYZONE) ? line.get_price(LT_LINE_ES2_BUYZONE, bar_index) : na
    float es2UtbZoneNow = not na(LT_LINE_ES2_UTBZONE) ? line.get_price(LT_LINE_ES2_UTBZONE, bar_index) : na
    float es2LineNow = not na(LT_LINE_ES2) ? line.get_price(LT_LINE_ES2, bar_index) : na

    [newBuyArmedES2, newBuyArmedES2Bar, newBuyES2RefPending, newBuyES2RefBar, newBuyES2RefHigh, newBuyES2RefZonePrice, newBuyES2RefSlPrice, es2SignalTriggered, es2TriggerPrice, es2SlPrice] = 
         utils.processES2BuyTrigger(BUY_ARMED_ES2, BUY_ARMED_ES2_BAR, BUY_ES2_REF_PENDING, BUY_ES2_REF_BAR, BUY_ES2_REF_HIGH, BUY_ES2_REF_ZONE_PRICE, BUY_ES2_REF_SL_PRICE,
                              es2LineNow, es2BuyZoneNow, es2UtbZoneNow, high, close, LT_CHANGED_THIS_BAR, BUY_ES2_REF_TIMEOUT, bar_index)

    BUY_ARMED_ES2 := newBuyArmedES2, BUY_ARMED_ES2_BAR := newBuyArmedES2Bar, BUY_ES2_REF_PENDING := newBuyES2RefPending, BUY_ES2_REF_BAR := newBuyES2RefBar
    BUY_ES2_REF_HIGH := newBuyES2RefHigh, BUY_ES2_REF_ZONE_PRICE := newBuyES2RefZonePrice, BUY_ES2_REF_SL_PRICE := newBuyES2RefSlPrice
    
    if es2SignalTriggered
        label lbES2Buy = label.new(bar_index, es2TriggerPrice, text="EB2", style=label.style_label_right, size=size.tiny, color=LBL_BUY_COL, textcolor=LBL_TEXT_COL)
        array.push(BUY_SIG_LABELS, lbES2Buy)
        sendSignalAlert('Extended Channel 2 Buy Signal', es2TriggerPrice, loP, midP, es2SlPrice)

    // ── NEW: Reset S/R windows if price pushes ≥ 3×ATR beyond the band
    if not na(upP) and high > (upP + BREAK_ATR_X * atr)
        array.clear(UP_HIT_BARS)
        SRHITS_UP := 0
    if not na(loP) and low < (loP - BREAK_ATR_X * atr)
        array.clear(DN_HIT_BARS)
        SRHITS_DN := 0

    if not LT_CHANGED_THIS_BAR
        bool upperTouch = not na(upP) and priceCrossoverUpper
        if upperTouch and utils.shouldPlace(LAST_UPPER_LABELBAR, MIN_LABEL_GAP_BARS, bar_index)
            label lbR = label.new(bar_index, upP, text='R', textcolor=LBL_TEXT_COL,
                                  style=label.style_label_down, size=size.tiny, color=LBL_R_COL)
            SELL_ARMED := true
            SELL_ARMED_BAR := bar_index

            if not na(lbR)
                array.push(SR_LABELS, lbR)
                LAST_UPPER_LABELBAR := bar_index
                sendAlert('Resistance Hit', upP, trendDirTxt)

            // ── NEW: windowed counting (100-bar window)
            array.push(UP_HIT_BARS, bar_index)
            SRHITS_UP := array.size(UP_HIT_BARS)
            if LT_FROZEN and not STRONG_PROMOTED
                float spNow = na(LT_SCORE) ? 0.0 : LT_SCORE * 100.0
                if spNow < strongScorePct and SRHITS_UP >= PROMOTE_MIN_HITS
                    STRONG_PROMOTED := true

        bool lowerTouch = not na(loP) and priceCrossunderLower
        if lowerTouch and utils.shouldPlace(LAST_LOWER_LABELBAR, MIN_LABEL_GAP_BARS, bar_index)
            label lbS = label.new(bar_index, loP, text='S', textcolor=LBL_TEXT_COL,
                                  style=label.style_label_up, size=size.tiny, color=LBL_S_COL)
            BUY_ARMED     := true
            BUY_ARMED_BAR := bar_index

            if not na(lbS)
                array.push(SR_LABELS, lbS)
                LAST_LOWER_LABELBAR := bar_index
                sendAlert('Support Hit', loP, trendDirTxt)

            // ── NEW: windowed counting (100-bar window)
            array.push(DN_HIT_BARS, bar_index)
            SRHITS_DN := array.size(DN_HIT_BARS)
            // promotion check uses windowed count
            if LT_FROZEN and not STRONG_PROMOTED
                float spNow2 = na(LT_SCORE) ? 0.0 : LT_SCORE * 100.0
                if spNow2 < strongScorePct and SRHITS_DN >= PROMOTE_MIN_HITS
                    STRONG_PROMOTED := true

        // bool widthOK = not na(upP) and not na(loP) and ((upP - loP) >= MIN_MIDLABEL_WIDTH_ATR_X * atr)

        if haveMid
            float distFromMid = math.max(math.abs(high - midP), math.abs(low - midP))
            if distFromMid >= MIDDLE_RESET_ATR_X * atr
                MR_ARMED := true
                MS_ARMED := true

        // Shared MR/MS cooldown: no new MS/MR within 20 bars of the last MS or MR
        int  sharedLastMid = utils.maxi(LAST_MR_LABELBAR, LAST_MS_LABELBAR)
        bool midCooldownOK = na(sharedLastMid) or (bar_index - sharedLastMid >= 20)

        bool midResTouch    = MR_ARMED and midCooldownOK and midResTouchRaw
        if midResTouch and utils.shouldPlace(LAST_MR_LABELBAR, MIN_LABEL_GAP_BARS, bar_index)
            label lbMR = label.new(bar_index, midP, text="⬤", textcolor = showMSMR ? LBL_MR_COL : color.new(LBL_MR_COL, 100),
                                 style=label.style_label_center, size=size.normal, color=color.new(LBL_MR_COL, 100))
            
            if not na(lbMR)
                array.push(SR_LABELS, lbMR)
                LAST_MR_LABELBAR := bar_index
                MR_ARMED := false

            // ── NEW: windowed middle-resistance counting + promotion
            array.push(MR_HIT_BARS, bar_index)
            MRHITS_CNT := array.size(MR_HIT_BARS)
            if LT_FROZEN and not STRONG_PROMOTED
                float spNowMid = na(LT_SCORE) ? 0.0 : LT_SCORE * 100.0
                if spNowMid < strongScorePct and (MRHITS_CNT >= PROMOTE_MID_MIN_HITS) and (MSHITS_CNT >= PROMOTE_MID_MIN_HITS)
                    STRONG_PROMOTED := true

        bool midSupTouch    = MS_ARMED and midCooldownOK and midSupTouchRaw
        if midSupTouch and utils.shouldPlace(LAST_MS_LABELBAR, MIN_LABEL_GAP_BARS, bar_index)
            label lbMS = label.new(bar_index, midP, text="⬤", textcolor = showMSMR ? LBL_MS_COL : color.new(LBL_MS_COL, 100),
                                 style=label.style_label_center, size=size.normal, color=color.new(LBL_MS_COL, 100))

            if not na(lbMS)
                array.push(SR_LABELS, lbMS)
                LAST_MS_LABELBAR := bar_index
                MS_ARMED := false

            // ── NEW: windowed middle-support counting + promotion
            array.push(MS_HIT_BARS, bar_index)
            MSHITS_CNT := array.size(MS_HIT_BARS)
            if LT_FROZEN and not STRONG_PROMOTED
                float spNowMid2 = na(LT_SCORE) ? 0.0 : LT_SCORE * 100.0
                if spNowMid2 < strongScorePct and (MRHITS_CNT >= PROMOTE_MID_MIN_HITS) and (MSHITS_CNT >= PROMOTE_MID_MIN_HITS)
                    STRONG_PROMOTED := true

        if UTA_THIS_BAR and utils.shouldPlace(LAST_EVT_BAR, MIN_EVT_GAP_BARS, bar_index)
            label lbUTA = label.new(bar_index, math.max(high, upP) + 0.15 * atr, text = "UTA",
                                     style = label.style_label_down, textcolor = LBL_TEXT_COL, size = size.tiny, color = LBL_UTA_COL)
            
            if not na(lbUTA)
                array.push(EVT_LABELS, lbUTA)
                LAST_EVT_BAR := bar_index
                sendAlert('Uptrend Accelerates', close, trendDirTxt)

        if DTA_THIS_BAR and utils.shouldPlace(LAST_EVT_BAR, MIN_EVT_GAP_BARS, bar_index)
            label lbDTA = label.new(bar_index, math.min(low, loP) - 0.15 * atr, text = "DTA",
                                     style = label.style_label_up, textcolor = LBL_TEXT_COL, size = size.tiny, color = LBL_DTA_COL)
            
            if not na(lbDTA)
                array.push(EVT_LABELS, lbDTA)
                LAST_EVT_BAR := bar_index
                sendAlert('Downtrend Accelerates', close, trendDirTxt)

    bool revPlaceOK = na(LAST_REV_LABELBAR) or (bar_index - LAST_REV_LABELBAR >= MIN_EVT_GAP_BARS)
    if TRU_THIS_BAR and haveMid and revPlaceOK
        label lbTRU = label.new(bar_index, midP - 0.10 * atr, text = "TRU",
                                 style = label.style_label_up, textcolor = LBL_TEXT_COL,
                                 size = size.tiny, color = LBL_TRU_COL)

        if not na(lbTRU)
            array.push(REV_LABELS, lbTRU)
            LAST_REV_LABELBAR := bar_index
            sendAlert('Trend Reversal to Uptrend', close, trendDirTxt)

    if TRD_THIS_BAR and haveMid and revPlaceOK
        label lbTRD = label.new(bar_index, midP + 0.10 * atr, text = "TRD",
                                 style = label.style_label_down, textcolor = LBL_TEXT_COL,
                                 size = size.tiny, color = LBL_TRD_COL)

        if not na(lbTRD)
            array.push(REV_LABELS, lbTRD)
            LAST_REV_LABELBAR := bar_index
            sendAlert('Trend Reveresal to Downtrend', close, trendDirTxt)

    while array.size(EVT_LABELS) > MAX_EVT_LABELS
        label oldEv = array.shift(EVT_LABELS)
        if not na(oldEv)
            label.delete(oldEv)

    while array.size(REV_LABELS) > MAX_REV_LABELS
        label oldRev = array.shift(REV_LABELS)
        if not na(oldRev)
            label.delete(oldRev)

// ═══════════════════════════════════════════════════════════════════════════
// HISTORICAL BACKFILL
// Put labels on bars before the NC label. Returns final state to get 
// most updated global variables for live continuation
// ═══════════════════════════════════════════════════════════════════════════

backfillEvents(int startBar, int endBar) =>
    // wipe previous backfill so edits don't duplicate
    utils.deleteAllLabels(BACKFILLED_LABELS)

    // Track separate cooldowns for R vs S (mirrors live LAST_UPPER_LABELBAR / LAST_LOWER_LABELBAR)
    // CRITICAL FIX: Only inherit PRESERVED values if they fall BEFORE the current channel's start bar
    // If PRESERVED values are within or after the channel range, they're from a different channel context
    // and should not block backfill detections in this channel
    int lastUpperBar = (not na(PRESERVED_UPPER_BAR) and PRESERVED_UPPER_BAR < startBar) ? PRESERVED_UPPER_BAR : na
    int lastLowerBar = (not na(PRESERVED_LOWER_BAR) and PRESERVED_LOWER_BAR < startBar) ? PRESERVED_LOWER_BAR : na
    int lastMRBar    = (not na(PRESERVED_MR_BAR) and PRESERVED_MR_BAR < startBar) ? PRESERVED_MR_BAR : na
    int lastMSBar    = (not na(PRESERVED_MS_BAR) and PRESERVED_MS_BAR < startBar) ? PRESERVED_MS_BAR : na

    // Armed states that will transfer to live detection
    bool buyArmedLocal  = false
    bool sellArmedLocal = false
    int  buyArmedBar    = na
    int  sellArmedBar   = na
    
    // Reference bar states for buy/sell confirmation (backfill local)
    bool  buyRefPending    = false
    int   buyRefBar        = na
    float buyRefHigh       = na
    float buyRefZonePrice  = na
    bool  sellRefPending   = false
    int   sellRefBar       = na
    float sellRefLow       = na
    float sellRefZonePrice = na
    
    // MR/MS armed states (mirrors live MR_ARMED / MS_ARMED)
    // Start armed at channel creation, disarm on hit, re-arm when price moves ≥2×ATR from mid
    bool mrArmedLocal = true
    bool msArmedLocal = true

    // FIX: Walk from the channel start bar (left edge of regression line) to endBar (where "New Channel" label appears)
    // This ensures we only backfill the historical portion of the channel, NOT bars after the channel was created
    int oldestBx = startBar
    int newestBx = endBar  // include the bar where "New Channel" was placed (live detection starts AFTER this bar)
    
    for bx = oldestBx to newestBx
        // safety: skip if bx is invalid
        if bx < 0 or bx >= bar_index
            continue

        int off  = bar_index - bx
        int offP = off + 1
        if offP > bar_index or offP < 0
            continue

        // line prices at bx and previous bar
        float up    = line.get_price(LT_LINE_UP,  bx)
        float lo    = line.get_price(LT_LINE_LO,  bx)
        float mid   = line.get_price(LT_LINE_MID, bx)
        float up_p  = line.get_price(LT_LINE_UP,  bx - 1)
        float lo_p  = line.get_price(LT_LINE_LO,  bx - 1)
        float mid_p = line.get_price(LT_LINE_MID, bx - 1)
        if na(up) or na(lo) or na(mid) or na(up_p) or na(lo_p) or na(mid_p)
            continue

        // bar data at that historical bar
        float hi   = high[off]
        float lw   = low[off]
        float hi_p = high[offP]
        float lw_p = low[offP]
        
        // Get ATR at this bar for width check (use current ATR as approximation)
        float atrAtBx = atr[off]

        // FIX: Channel width check for MS/MR (mirrors live widthOK logic)
        // MS/MR labels should only appear if channel width >= MIN_MIDLABEL_WIDTH_ATR_X * ATR
        // bool widthOK = (up - lo) >= MIN_MIDLABEL_WIDTH_ATR_X * atrAtBx

        // R/S hits - fresh touch from any direction
        // R: from below (hi >= up and hi_p < up_p) OR from above (lw <= up and lw_p > up_p)
        // S: from above (lw <= lo and lw_p > lo_p) OR from below (hi >= lo and hi_p < lo_p)
        bool hitRFromBelow = (hi >= up) and (hi_p < up_p)
        bool hitRFromAbove = (lw <= up) and (lw_p > up_p)
        bool hitR = not na(hi) and not na(lw) and (hitRFromBelow or hitRFromAbove)
        
        bool hitSFromAbove = (lw <= lo) and (lw_p > lo_p)
        bool hitSFromBelow = (hi >= lo) and (hi_p < lo_p)
        bool hitS = not na(hi) and not na(lw) and (hitSFromAbove or hitSFromBelow)
        
        bool hitMR = not na(hi) and (hi >= mid) and (hi_p < mid_p)
        bool hitMS = not na(lw) and (lw <= mid) and (lw_p > mid_p)

        // Separate cooldown gating for R vs S (mirrors live logic)
        bool okR = hitR and (na(lastUpperBar) or (bx - lastUpperBar >= MIN_LABEL_GAP_BARS))
        bool okS = hitS and (na(lastLowerBar) or (bx - lastLowerBar >= MIN_LABEL_GAP_BARS))
        
        // Shared MR/MS cooldown (mirrors live: 20-bar shared cooldown)
        int  sharedLastMid = utils.maxi(lastMRBar, lastMSBar)
        bool midCooldownOK = na(sharedLastMid) or (bx - sharedLastMid >= 20)
        
        // FIX: MR/MS must also pass widthOK and be armed (mirrors live logic)
        bool okMR = hitMR and mrArmedLocal and midCooldownOK and (na(lastMRBar) or (bx - lastMRBar >= MIN_LABEL_GAP_BARS))
        bool okMS = hitMS and msArmedLocal and midCooldownOK and (na(lastMSBar) or (bx - lastMSBar >= MIN_LABEL_GAP_BARS))

        // FIX: Re-arm MR/MS when price moves ≥ MIDDLE_RESET_ATR_X * ATR from mid (mirrors live logic)
        float distFromMid = math.max(math.abs(hi - mid), math.abs(lw - mid))
        if distFromMid >= MIDDLE_RESET_ATR_X * atrAtBx
            mrArmedLocal := true
            msArmedLocal := true

        // place R label and arm SELL
        if okR
            makeBackfillLbl(label.style_label_down, "R", up, LBL_R_COL, bx)
            lastUpperBar := bx
            // ARM for SELL (mirrors live arming on upper touch)
            sellArmedLocal := true, sellArmedBar := bx

        // place S label and arm BUY
        if okS
            makeBackfillLbl(label.style_label_up, "S", lo, LBL_S_COL, bx)
            lastLowerBar := bx
            // ARM for BUY (mirrors live arming on lower touch)
            buyArmedLocal := true, buyArmedBar := bx

        // place MR label (now gated by widthOK and mrArmedLocal)
        if okMR and showMSMR
            // makeBackfillLbl(label.style_label_down, "MR", mid, color.new(color.red, 0), bx)
            label lbMR = label.new(bx, mid, text = "⬤", style = label.style_label_center, textcolor = LBL_MR_COL, size = size.normal, color = color.new(LBL_MR_COL, 100))
            array.push(BACKFILLED_LABELS, lbMR)
            
            // makeBackfillLbl(label.style_label_down, "MR", mid, color.new(color.red, 0), bx)
            lastMRBar := bx
            mrArmedLocal := false  // disarm after hit

        // place MS label (now gated by widthOK and msArmedLocal)
        if okMS and showMSMR
            // makeBackfillLbl(label.style_label_up, "MS", mid, color.new(color.blue, 0), bx)
            label lbMR = label.new(bx, mid, text = "⬤", style = label.style_label_center, textcolor = LBL_MS_COL, size = size.normal, color = color.new(LBL_MS_COL, 100))
            array.push(BACKFILLED_LABELS, lbMR)
            lastMSBar := bx
            msArmedLocal := false  // disarm after hit

        // ───────── Buy/Sell triggers using 35% zones + timeouts + REFERENCE BAR CONFIRMATION
        float buyZ_atBx  = line.get_price(LT_LINE_BUYZONE,  bx)
        float sellZ_atBx = line.get_price(LT_LINE_SELLZONE, bx)
        float cl = close[off]  // close price at this bar

        // timeout logic mirrors live (BUY_ARM_TIMEOUT / SELL_ARM_TIMEOUT)
        if buyArmedLocal and not na(buyArmedBar) and bx - buyArmedBar >= BUY_ARM_TIMEOUT
            buyArmedLocal := false, buyArmedBar := na
        if sellArmedLocal and not na(sellArmedBar) and bx - sellArmedBar >= SELL_ARM_TIMEOUT
            sellArmedLocal := false, sellArmedBar := na

        // ═══ BUY REFERENCE BAR CONFIRMATION (backfill) ═══
        // Reference bar timeout - also disarm to require new Support hit
        if buyRefPending and not na(buyRefBar) and bx - buyRefBar >= BUY_REF_TIMEOUT
            buyRefPending := false, buyRefBar := na, buyRefHigh := na, buyRefZonePrice := na
            buyArmedLocal := false, buyArmedBar := na

        // Check if buy zone touched - set reference bar
        bool buyZoneTouched = buyArmedLocal and bx > buyArmedBar and not na(hi) and not na(buyZ_atBx) and hi >= buyZ_atBx and not buyRefPending
        if buyZoneTouched
            buyRefPending := true
            buyRefBar := bx
            buyRefHigh := hi
            buyRefZonePrice := buyZ_atBx

        // Check for confirmation (subsequent bar closes above reference bar's high)
        // Additional condition: whole bar must be below middle line for buy signals
        float midAtBx = line.get_price(LT_LINE_MID, bx)
        bool bfBarBelowMid = not na(midAtBx) and (hi < midAtBx)
        bool buyConfirmed = buyRefPending and bx > buyRefBar and cl > buyRefHigh and bfBarBelowMid
        if buyConfirmed
            // Place ▲ label at CONFIRMATION bar (current bx)
            label lbBuy = label.new(bx, cl, text="B",
                 style=label.style_label_right, size=size.tiny,
                 color=LBL_BUY_COL, textcolor=LBL_TEXT_COL)
            array.push(BACKFILLED_LABELS, lbBuy)

            // reset armed and reference bar states
            buyArmedLocal := false, buyArmedBar := na
            buyRefPending := false, buyRefBar := na, buyRefHigh := na, buyRefZonePrice := na

        // ═══ SELL REFERENCE BAR CONFIRMATION (backfill) ═══
        // Reference bar timeout - also disarm to require new Resistance hit
        if sellRefPending and not na(sellRefBar) and bx - sellRefBar >= SELL_REF_TIMEOUT
            sellRefPending := false, sellRefBar := na, sellRefLow := na, sellRefZonePrice := na
            sellArmedLocal := false, sellArmedBar := na

        // Check if sell zone touched - set reference bar
        bool sellZoneTouched = sellArmedLocal and bx > sellArmedBar and not na(lw) and not na(sellZ_atBx) and lw <= sellZ_atBx and not sellRefPending
        if sellZoneTouched
            sellRefPending := true
            sellRefBar := bx
            sellRefLow := lw
            sellRefZonePrice := sellZ_atBx

        // Check for confirmation (subsequent bar closes below reference bar's low)
        // Additional condition: whole bar must be above middle line for sell signals
        float midAtBxSell = line.get_price(LT_LINE_MID, bx)
        bool bfBarAboveMid = not na(midAtBxSell) and (lw > midAtBxSell)
        bool sellConfirmed = sellRefPending and bx > sellRefBar and cl < sellRefLow and bfBarAboveMid
        if sellConfirmed
            // Place ▼ label at CONFIRMATION bar (current bx)
            label lbSell = label.new(bx, cl, text="S",
                 style=label.style_label_right, size=size.tiny,
                 color=LBL_SELL_COL, textcolor=LBL_TEXT_COL)
            array.push(BACKFILLED_LABELS, lbSell)

            // reset armed and reference bar states
            sellArmedLocal := false, sellArmedBar := na
            sellRefPending := false, sellRefBar := na, sellRefLow := na, sellRefZonePrice := na

    // Return final state for transfer to global variables
    // Format: [lastUpperBar, lastLowerBar, lastMRBar, lastMSBar, buyArmed, buyArmedBar, sellArmed, sellArmedBar, mrArmed, msArmed]
    [lastUpperBar, lastLowerBar, lastMRBar, lastMSBar, buyArmedLocal, buyArmedBar, sellArmedLocal, sellArmedBar, mrArmedLocal, msArmedLocal]


// ── Run backfill ONCE right after a New Channel is created
// This makes cooldown carry over immediately (not only on barstate.islast).
if not BACKFILL_DONE and LT_FROZEN and not na(LT_START_BAR) and not na(LAST_CHG_BAR) and bar_index >= LAST_CHG_BAR
    int scanEnd = LAST_CHG_BAR  // include the New Channel bar in the scan
    [bfLastUpper, bfLastLower, bfLastMR, bfLastMS,
     bfBuyArmed, bfBuyArmedBar, bfSellArmed, bfSellArmedBar,
     bfMrArmed, bfMsArmed] = backfillEvents(LT_START_BAR, scanEnd)

    if not na(bfLastUpper)
        LAST_UPPER_LABELBAR := bfLastUpper
    if not na(bfLastLower)
        LAST_LOWER_LABELBAR := bfLastLower
    if not na(bfLastMR)
        LAST_MR_LABELBAR := bfLastMR
    if not na(bfLastMS)
        LAST_MS_LABELBAR := bfLastMS

    BUY_ARMED := bfBuyArmed
    BUY_ARMED_BAR := bfBuyArmedBar
    SELL_ARMED := bfSellArmed
    SELL_ARMED_BAR := bfSellArmedBar

    MR_ARMED := bfMrArmed
    MS_ARMED := bfMsArmed

    // ── Calculate and create Overshoot Resistance (OR) / Overshoot Support (OS) lines
    // Uses simulateOvershootLevels: replays the live ER/ES detection logic over historical bars
    // (replaces calcOvershootLevels which used a different pivot detection mechanism)
    [orOffset, osOffset, orBar, osBar] = utils.simulateOvershootLevels(
     LT_START_BAR, scanEnd, bar_index, LT_DEVMULT, LT_STD,
     LT_LINE_UP, LT_LINE_LO,
     pivotLookbackLeft, pivotLookbackRight, extLineMinAtrDist, atr)

    LT_ER_OFFSET := orOffset
    LT_ES_OFFSET := osOffset
    LT_ER_BAR := orBar
    LT_ES_BAR := osBar
    
    // Create the OR/OS lines with their zones
    [newOR, newOS, newORSellZone, newORDtbZone, newOSBuyZone, newOSUtbZone] = 
         utils.createOvershootLines(LT_ER_OFFSET, LT_ES_OFFSET, LT_LINE_UP, LT_LINE_LO, LT_LINE_MID,
                                     LT_LINE_ER, LT_LINE_ES, LT_LINE_ER_SELLZONE, LT_LINE_ER_DTBZONE,
                                     LT_LINE_ES_BUYZONE, LT_LINE_ES_UTBZONE,
                                     showBuySellLineZoneExt, OR_LINE_COL, OS_LINE_COL, SELL_ZONE_COL, BUY_ZONE_COL)

    LT_LINE_ER := newOR, LT_LINE_ES := newOS, LT_LINE_ER_SELLZONE := newORSellZone, LT_LINE_ER_DTBZONE := newORDtbZone
    LT_LINE_ES_BUYZONE := newOSBuyZone, LT_LINE_ES_UTBZONE := newOSUtbZone
    
    // Set confirmed flags if OR/OS lines were created (backfill acts as confirmation)
    LT_ER_CONFIRMED := not na(orOffset) and not na(newOR)
    LT_ES_CONFIRMED := not na(osOffset) and not na(newOS)

    // ── Count OR/OS hits that occurred during backfill period
    // The spike bar that created OR/OS counts as Hit #1, plus any additional hits
    if LT_ER_CONFIRMED or LT_ES_CONFIRMED

        [bferHitCount, bferLastHitBar, erFirstBar, erFirstPrice, bfesHitCount, bfesLastHitBar, esFirstBar, esFirstPrice] = utils.countOvershootHitsBackfill(
             orBar, osBar, scanEnd, newOR, newOS,
             ER_HIT_GAP_BARS, ES_HIT_GAP_BARS, bar_index, highHistory, lowHistory)

        if not na(erFirstPrice)
            label erHitLabel = label.new(erFirstBar, erFirstPrice, text="ER", 
                     style=label.style_label_down, size=size.tiny,
                     color=LBL_ER_COL, textcolor=LBL_TEXT_COL)
            array.push(ER_HIT_LABELS, erHitLabel)

        if not na(esFirstPrice)
            label esHitLabel = label.new(esFirstBar, esFirstPrice, text="ES", 
                     style=label.style_label_up, size=size.tiny,
                     color=LBL_ES_COL, textcolor=LBL_TEXT_COL)
            array.push(ES_HIT_LABELS, esHitLabel)

        // Transfer hit counts to global state
        ER_HIT_COUNT := bferHitCount
        ER_LAST_HIT_BAR := bferLastHitBar
        ES_HIT_COUNT := bfesHitCount
        ES_LAST_HIT_BAR := bfesLastHitBar
        
        // If 2+ hits already occurred during backfill, arm the entry
        if ER_HIT_COUNT >= 2
            SELL_ARMED_ER := true
            SELL_ARMED_ER_BAR := bferLastHitBar

        if ES_HIT_COUNT >= 2
            BUY_ARMED_ES := true
            BUY_ARMED_ES_BAR := bfesLastHitBar

    BACKFILL_DONE := true

// ═══════════════════════════════════════════════════════════════════════════
// LINE PLOTS AND DYNAMIC COLOR RE-APPLICATION FOR STRONG CHANNEL
// ═══════════════════════════════════════════════════════════════════════════

// ───────────────────────── Series readout (status line)
plot(LT_FROZEN ? line.get_price(LT_LINE_MID, bar_index) : na, title='Middle Line', color=color.red,  linewidth=1, display = display.status_line)
plot(LT_FROZEN ? line.get_price(LT_LINE_UP,  bar_index) : na, title='Upper Line',  color=color.blue, linewidth=1, display = display.status_line)
plot(LT_FROZEN ? line.get_price(LT_LINE_LO,  bar_index) : na, title='Lower Line',  color=color.blue, linewidth=1, display = display.status_line)

// ───────────────────────── DYNAMIC COLOR RE-APPLY FOR STRONG CHANNEL
// Ensures an accepted channel that later crosses 55% OR is promoted turns green without redrawing
if LT_FROZEN and not na(LT_LINE_MID) and not na(LT_SCORE)
    float sp = LT_SCORE * 100.0
    bool strongActive = (sp >= strongScorePct) or STRONG_PROMOTED

    if strongActive and not GOOD_ALERTED
        // log.info("'Trend Reveresal to Downtrend' Alert Sent!")
        sendAlert('Good Channel Established', close, trendDirTxt)
        GOOD_ALERTED := true

    color midDyn  = color.new(strongActive ? color.green : color.red, 30)
    color bandDyn = color.new(strongActive ? color.green : color.blue, 50)
    color fillDyn = color.new(strongActive ? color.green : color.blue, 95)
    line.set_color(LT_LINE_MID, midDyn)
    line.set_color(LT_LINE_UP,  bandDyn)
    line.set_color(LT_LINE_LO,  bandDyn)
    if not na(LT_FILL_U)
        linefill.set_color(LT_FILL_U, fillDyn)
    if not na(LT_FILL_L)
        linefill.set_color(LT_FILL_L, fillDyn)


// ═══════════════════════════════════════════════════════════════════════════
// ██ STRATEGY LOGIC — STOP LOSS & TAKE PROFIT
// (Entries are injected directly into the UTB/DTB trigger blocks above)
// ═══════════════════════════════════════════════════════════════════════════

// ── BREAKEVEN + TRAILING SL (pure function — runs BEFORE SL check) ──
// @function Computes breakeven activation, trailing SL, and best price tracking.
//           - Breakeven: once price moves beATR * ATR in your favor, SL → entry price
//           - Trailing: once price moves trailActATR * ATR in your favor AND BE is active, 
//             SL trails at trailMult * ATR from best price
// @returns  [newBestPrice, newFixedSL, newBEActivated, newTrailActivated]
computeBreakevenTrailSL(float _posSize, float _bestPrice, float _fixedSL, float _entryPrice, 
     bool _beActivated, bool _trailActivated,
     bool _useBE, bool _useTrail,
     float _beATR, float _trailActATR, float _trailMult, 
     float _atr, float _high, float _low) =>
    float bestP = _bestPrice
    float sl = _fixedSL
    bool beAct = _beActivated
    bool trAct = _trailActivated
    if _posSize > 0
        bestP := na(bestP) ? _high : math.max(bestP, _high)
        if _useBE and not na(_entryPrice) and not na(bestP)
            float fav = bestP - _entryPrice
            // Breakeven activation
            if not beAct and fav >= _beATR * _atr
                sl := math.max(nz(sl, _entryPrice), _entryPrice)
                beAct := true
            // Trailing activation (requires BE active first)
            if _useTrail and beAct and not na(bestP)
                if not trAct and fav >= _trailActATR * _atr
                    trAct := true
                if trAct
                    float tsl = bestP - _trailMult * _atr
                    sl := math.max(nz(sl, tsl), tsl)
    else if _posSize < 0
        bestP := na(bestP) ? _low : math.min(bestP, _low)
        if _useBE and not na(_entryPrice) and not na(bestP)
            float fav = _entryPrice - bestP
            // Breakeven activation
            if not beAct and fav >= _beATR * _atr
                sl := math.min(nz(sl, _entryPrice), _entryPrice)
                beAct := true
            // Trailing activation (requires BE active first)
            if _useTrail and beAct and not na(bestP)
                if not trAct and fav >= _trailActATR * _atr
                    trAct := true
                if trAct
                    float tsl = bestP + _trailMult * _atr
                    sl := math.min(nz(sl, tsl), tsl)
    else
        bestP := na
        beAct := false
        trAct := false
    [bestP, sl, beAct, trAct]

// ── Run breakeven/trailing SL update (must run BEFORE SL check so SL is updated on this bar) ──
[newBestPrice, newFixedSL, newBEActivated, newTrailActivated] = computeBreakevenTrailSL(
     strategy.position_size, STRAT_BEST_PRICE, STRAT_FIXED_SL, STRAT_ENTRY_PRICE, 
     STRAT_BE_ACTIVATED, STRAT_TRAIL_ACTIVATED,
     useBreakevenSL, useTrailingSL,
     beActivationATR, trailActivationATR, trailATRMult, atr, high, low)
STRAT_BEST_PRICE := newBestPrice, STRAT_FIXED_SL := newFixedSL
STRAT_BE_ACTIVATED := newBEActivated, STRAT_TRAIL_ACTIVATED := newTrailActivated

// @function Determines SL reference price considering fixed SL, channel changes, and extended line SL.
// @returns  SL reference price (or na if none available)
computeSLRef(float _fixedSL, bool _chChanged, bool _prevValid, float _posSize,
     bool _slFromExt, float _extSLRef, float _prevUpper, float _prevLower,
     float _slAtrBuf, float _atr) =>
    float sl = _fixedSL
    if na(sl) and _chChanged and _prevValid
        if _posSize > 0
            sl := _slFromExt and not na(_extSLRef) ? _extSLRef - _slAtrBuf * _atr : _prevUpper - _slAtrBuf * _atr
        else if _posSize < 0
            sl := _slFromExt and not na(_extSLRef) ? _extSLRef + _slAtrBuf * _atr : _prevLower + _slAtrBuf * _atr
    sl

// @function Evaluates TP exit conditions for one side (long or short).
//           Returns action code and updated state without calling strategy.close().
// @param    _side +1 for long, -1 for short
// @returns  [action, consecBelow, consecAbove, tbArmed, tbHigh, tbLow]
//           action: 0=none, 1=consec TP, 2=TB-TP, 3=TB-SL, -1=disarm only
evaluateTPExit(int _side, float _entryPrice, string _tpMode, float _maTP,
     int _tpConsecCloses, bool _tbReqProfit, bool _tbAlsoSL, float _tbSlMinAtrDist, float _atr,
     int _consecBelow, int _consecAbove,
     bool _tbArmed, float _tbHigh, float _tbLow,
     float _posSize, float _close, float _high, float _low, float _openProfit) =>
    int action = 0
    int cBelow = _consecBelow, int cAbove = _consecAbove
    bool armed = _tbArmed, float tH = _tbHigh, float tL = _tbLow
    
    if _side == +1 and _posSize > 0
        bool inProfit = _openProfit > 0
        if _tpMode == "Consecutive Closes"
            cBelow := inProfit and (_close < _maTP) ? cBelow + 1 : 0
            action := cBelow >= _tpConsecCloses ? 1 : 0
        else if _tpMode == "Trigger Bar"
            bool tbTP = _tbReqProfit ? inProfit : true
            if armed
                if tbTP and (_close < tL)
                    action := 2
                else if _tbAlsoSL and (not inProfit) and (_close < tL) and (not na(_entryPrice)) and ((_entryPrice - _close) >= _tbSlMinAtrDist * _atr)
                    action := 3
                else
                    action := -1  // disarm
                    armed := false, tH := na, tL := na
            if action <= 0 and _posSize > 0 and (_close < _maTP)
                armed := true, tH := _high, tL := _low
            else if action <= 0
                armed := false, tH := na, tL := na

    else if _side == -1 and _posSize < 0
        bool inProfit = _openProfit > 0
        if _tpMode == "Consecutive Closes"
            cAbove := inProfit and (_close > _maTP) ? cAbove + 1 : 0
            action := cAbove >= _tpConsecCloses ? 1 : 0
        else if _tpMode == "Trigger Bar"
            bool tbTP = _tbReqProfit ? inProfit : true
            if armed
                if tbTP and (_close > tH)
                    action := 2
                else if _tbAlsoSL and (not inProfit) and (_close > tH) and (not na(_entryPrice)) and ((_close - _entryPrice) >= _tbSlMinAtrDist * _atr)
                    action := 3
                else
                    action := -1  // disarm
                    armed := false, tH := na, tL := na
            if action <= 0 and _posSize < 0 and (_close > _maTP)
                armed := true, tH := _high, tL := _low
            else if action <= 0
                armed := false, tH := na, tL := na

    [action, cBelow, cAbove, armed, tH, tL]

// ── Determine SL reference price ──
float slRef = computeSLRef(STRAT_FIXED_SL, STRAT_CH_CHANGED, PREV_CH_VALID, strategy.position_size,
     STRAT_SL_FROM_EXT, STRAT_EXT_SL_REF, PREV_CH_UPPER, PREV_CH_LOWER, slAtrBuffer, atr)

// ── STOP LOSS ──
if (strategy.position_size > 0) and not na(slRef) and (close < slRef)
    string _slTag = STRAT_TRAIL_ACTIVATED ? " [Trail]" : STRAT_BE_ACTIVATED ? " [BE]" : " [Fixed]"
    strategy.close("Long", "Long SL" + _slTag)
    STRAT_CH_CHANGED := false, STRAT_CONSEC_BELOW_MA := 0, STRAT_FIXED_SL := na, STRAT_SL_FROM_EXT := false, STRAT_EXT_SL_REF := na, STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
    TB_ARMED_LONG := false, TB_HIGH_LONG := na, TB_LOW_LONG := na
    barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999

if (strategy.position_size < 0) and not na(slRef) and (close > slRef)
    string _slTag = STRAT_TRAIL_ACTIVATED ? " [Trail]" : STRAT_BE_ACTIVATED ? " [BE]" : " [Fixed]"
    strategy.close("Short", "Short SL" + _slTag)
    STRAT_CH_CHANGED := false, STRAT_CONSEC_ABOVE_MA := 0, STRAT_FIXED_SL := na, STRAT_SL_FROM_EXT := false, STRAT_EXT_SL_REF := na, STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
    TB_ARMED_SHORT := false, TB_HIGH_SHORT := na, TB_LOW_SHORT := na
    barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999

// ── TAKE PROFIT / EXIT (mode-aware via function) ──
if strategy.position_size > 0
    [longAct, cBelowL, cAboveL, tbArmL, tbHL, tbLL] = evaluateTPExit(
         +1, STRAT_ENTRY_PRICE, tpExitMode, maTP, tpConsecutiveCloses, tbRequireProfit, tbAlsoAsSL, tbSlMinAtrDist, atr,
         STRAT_CONSEC_BELOW_MA, STRAT_CONSEC_ABOVE_MA, TB_ARMED_LONG, TB_HIGH_LONG, TB_LOW_LONG,
         strategy.position_size, close, high, low, strategy.openprofit)
    STRAT_CONSEC_BELOW_MA := cBelowL, STRAT_CONSEC_ABOVE_MA := cAboveL
    TB_ARMED_LONG := tbArmL, TB_HIGH_LONG := tbHL, TB_LOW_LONG := tbLL
    if longAct == 1
        strategy.close("Long", "Long TP")
        STRAT_CH_CHANGED := false, STRAT_CONSEC_BELOW_MA := 0, STRAT_CONSEC_ABOVE_MA := 0, STRAT_FIXED_SL := na, STRAT_SL_FROM_EXT := false, STRAT_EXT_SL_REF := na, STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
        TB_ARMED_LONG := false, TB_HIGH_LONG := na, TB_LOW_LONG := na, TB_ARMED_SHORT := false, TB_HIGH_SHORT := na, TB_LOW_SHORT := na
        barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999
    else if longAct == 2
        strategy.close("Long", "Long TB-TP")
        STRAT_CH_CHANGED := false, STRAT_CONSEC_BELOW_MA := 0, STRAT_CONSEC_ABOVE_MA := 0, STRAT_FIXED_SL := na, STRAT_SL_FROM_EXT := false, STRAT_EXT_SL_REF := na, STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
        TB_ARMED_LONG := false, TB_HIGH_LONG := na, TB_LOW_LONG := na, TB_ARMED_SHORT := false, TB_HIGH_SHORT := na, TB_LOW_SHORT := na
        barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999
    else if longAct == 3
        strategy.close("Long", "Long TB-SL")
        STRAT_CH_CHANGED := false, STRAT_CONSEC_BELOW_MA := 0, STRAT_CONSEC_ABOVE_MA := 0, STRAT_FIXED_SL := na, STRAT_SL_FROM_EXT := false, STRAT_EXT_SL_REF := na, STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
        TB_ARMED_LONG := false, TB_HIGH_LONG := na, TB_LOW_LONG := na, TB_ARMED_SHORT := false, TB_HIGH_SHORT := na, TB_LOW_SHORT := na
        barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999

else if strategy.position_size < 0
    [shortAct, cBelowS, cAboveS, tbArmS, tbHS, tbLS] = evaluateTPExit(
         -1, STRAT_ENTRY_PRICE, tpExitMode, maTP, tpConsecutiveCloses, tbRequireProfit, tbAlsoAsSL, tbSlMinAtrDist, atr,
         STRAT_CONSEC_BELOW_MA, STRAT_CONSEC_ABOVE_MA, TB_ARMED_SHORT, TB_HIGH_SHORT, TB_LOW_SHORT,
         strategy.position_size, close, high, low, strategy.openprofit)
    STRAT_CONSEC_BELOW_MA := cBelowS, STRAT_CONSEC_ABOVE_MA := cAboveS
    TB_ARMED_SHORT := tbArmS, TB_HIGH_SHORT := tbHS, TB_LOW_SHORT := tbLS
    if shortAct == 1
        strategy.close("Short", "Short TP")
        STRAT_CH_CHANGED := false, STRAT_CONSEC_BELOW_MA := 0, STRAT_CONSEC_ABOVE_MA := 0, STRAT_FIXED_SL := na, STRAT_SL_FROM_EXT := false, STRAT_EXT_SL_REF := na, STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
        TB_ARMED_LONG := false, TB_HIGH_LONG := na, TB_LOW_LONG := na, TB_ARMED_SHORT := false, TB_HIGH_SHORT := na, TB_LOW_SHORT := na
        barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999
    else if shortAct == 2
        strategy.close("Short", "Short TB-TP")
        STRAT_CH_CHANGED := false, STRAT_CONSEC_BELOW_MA := 0, STRAT_CONSEC_ABOVE_MA := 0, STRAT_FIXED_SL := na, STRAT_SL_FROM_EXT := false, STRAT_EXT_SL_REF := na, STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
        TB_ARMED_LONG := false, TB_HIGH_LONG := na, TB_LOW_LONG := na, TB_ARMED_SHORT := false, TB_HIGH_SHORT := na, TB_LOW_SHORT := na
        barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999
    else if shortAct == 3
        strategy.close("Short", "Short TB-SL")
        STRAT_CH_CHANGED := false, STRAT_CONSEC_BELOW_MA := 0, STRAT_CONSEC_ABOVE_MA := 0, STRAT_FIXED_SL := na, STRAT_SL_FROM_EXT := false, STRAT_EXT_SL_REF := na, STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
        TB_ARMED_LONG := false, TB_HIGH_LONG := na, TB_LOW_LONG := na, TB_ARMED_SHORT := false, TB_HIGH_SHORT := na, TB_LOW_SHORT := na
        barsSinceMaCrossunder := 999, barsSinceMaCrossover := 999

else
    // No position — reset all counters
    STRAT_CONSEC_BELOW_MA := 0, STRAT_CONSEC_ABOVE_MA := 0
    STRAT_BEST_PRICE := na, STRAT_BE_ACTIVATED := false, STRAT_TRAIL_ACTIVATED := false
    TB_ARMED_LONG := false, TB_HIGH_LONG := na, TB_LOW_LONG := na
    TB_ARMED_SHORT := false, TB_HIGH_SHORT := na, TB_LOW_SHORT := na