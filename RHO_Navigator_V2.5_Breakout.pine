        SELL_ER_REF_ZONE_PRICE := na, SELL_ER_REF_SL_PRICE := na, BUY_ES_REF_PENDING := false, BUY_ES_REF_BAR := na, BUY_ES_REF_HIGH := na, BUY_ES_REF_ZONE_PRICE := na, BUY_ES_REF_SL_PRICE := na
        ER_HIT_COUNT := 0, ER_LAST_HIT_BAR := na, ES_HIT_COUNT := 0, ES_LAST_HIT_BAR := na, ER2_HIT_COUNT := 0, ER2_LAST_HIT_BAR := na, ES2_HIT_COUNT := 0
        ES2_LAST_HIT_BAR := na, LT_ER2_CONFIRMED := false, LT_ES2_CONFIRMED := false, SELL_ARMED_ER2 := false, SELL_ARMED_ER2_BAR := na, BUY_ARMED_ES2 := false, BUY_ARMED_ES2_BAR := na
